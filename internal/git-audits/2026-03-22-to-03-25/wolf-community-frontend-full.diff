@@ -0,0 +1,16 @@
+/**
+ * H3 cell boundary → GeoJSON ring (lng, lat), closed ring.
+ */
+import { cellToBoundary, type H3Index } from "h3-js";
+
+export function h3ToGeoJsonPolygon(h3Index: H3Index): number[][] {
+  const boundary = cellToBoundary(h3Index, true);
+  if (boundary.length > 0) {
+    const first = boundary[0];
+    const last = boundary.at(-1);
+    if (last && (first[0] !== last[0] || first[1] !== last[1])) {
+      return [...boundary.map((c) => [c[0], c[1]]), [first[0], first[1]]];
+    }
+  }
+  return boundary.map((c) => [c[0], c[1]]);
+}
