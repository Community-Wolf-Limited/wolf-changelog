+/**
+ * Horizontal pill/chip selector for safety intents — ported from enterprise.
+ */
+
+import { cn } from "@/lib/utils";
+import type { LucideIcon } from "lucide-react";
+import {
+  Car,
+  Home,
+  Moon,
+  Briefcase,
+  Palmtree,
+  Footprints,
+  TrendingUp,
+  Shield,
+  EyeOff,
+} from "lucide-react";
+import type { HexSafetyIntent } from "@/utils/cw-unified-crime-hex-api";
+
+export type HexIntentOrNone = HexSafetyIntent | "none";
+
+interface IntentOption {
+  intent: HexIntentOrNone;
+  label: string;
+  shortLabel: string;
+  icon: LucideIcon;
+  description: string;
+  focusAreas: string;
+  color: string;
+}
+
+const INTENT_OPTIONS: readonly IntentOption[] = [
+  {
+    intent: "none",
+    label: "None",
+    shortLabel: "None",
+    icon: EyeOff,
+    description: "No safety overlay — hex layer hidden.",
+    focusAreas: "",
+    color: "#6b7280",
+  },
+  {
+    intent: "overall",
+    label: "Overall",
+    shortLabel: "Overall",
+    icon: Shield,
+    description: "Balanced view — all 31 SAPS crime types weighted equally by severity.",
+    focusAreas: "Violent · Sexual · Property · Vehicle · Robbery · Drug · Commercial",
+    color: "#1a4f38",
+  },
+  {
+    intent: "travel",
+    label: "Travel / Transit",
+    shortLabel: "Travel",
+    icon: Car,
+    description: "Safe to drive through? Prioritises carjacking, vehicle hijacking and road-crime types.",
+    focusAreas: "Vehicle ×15 · Robbery ×8 · Violent ×4",
+    color: "#2563eb",
+  },
+  {
+    intent: "live",
+    label: "Live / Relocate",
+    shortLabel: "Live",
+    icon: Home,
+    description: "Safe to live here? Prioritises residential burglary, property crime and home robbery.",
+    focusAreas: "Property ×15 · Robbery ×14 · Violent ×12 · Sexual ×10",
+    color: "#16a34a",
+  },
+  {
+    intent: "sleep",
+    label: "Sleep / Night",
+    shortLabel: "Night",
+    icon: Moon,
+    description: "Safe at night? Prioritises rape, sexual assault, murder and late-night robbery.",
+    focusAreas: "Sexual ×15 · Violent ×15 · Robbery ×12 · Property ×6",
+    color: "#7c3aed",
+  },
+  {
+    intent: "business",
+    label: "Start a Business",
+    shortLabel: "Business",
+    icon: Briefcase,
+    description: "Safe for business? Prioritises commercial crime, non-residential robbery and shoplifting.",
+    focusAreas: "Commercial ×15 · Robbery ×15 · Property ×12 · Vehicle ×4",
+    color: "#d97706",
+  },
+  {
+    intent: "holiday",
+    label: "Holiday / Tourism",
+    shortLabel: "Holiday",
+    icon: Palmtree,
+    description: "Safe to visit? Prioritises street robbery, vehicle theft and tourist-targeted crime.",
+    focusAreas: "Robbery ×15 · Property ×13 · Vehicle ×11 · Sexual ×10 · Violent ×5",
+    color: "#0891b2",
+  },
+  {
+    intent: "walk",
+    label: "Walk / Commute",
+    shortLabel: "Walk",
+    icon: Footprints,
+    description: "Safe to walk? Prioritises street robbery, assault, sexual crime and drug zones.",
+    focusAreas: "Robbery ×15 · Violent ×14 · Sexual ×12 · Drug ×4",
+    color: "#be185d",
+  },
+  {
+    intent: "invest",
+    label: "Invest / Buy Property",
+    shortLabel: "Invest",
+    icon: TrendingUp,
+    description: "Property value protected? Prioritises residential burglary, arson, vandalism and murder trends.",
+    focusAreas: "Property ×12 · Violent ×12 · Drug ×8 · Vehicle ×7 · Robbery ×6",
+    color: "#92400e",
+  },
+] as const;
+
+export function SafetyIntentSelector({
+  value,
+  onChange,
+  compact = false,
+  disabled = false,
+}: Readonly<{
+  value: HexIntentOrNone;
+  onChange: (intent: HexIntentOrNone) => void;
+  compact?: boolean;
+  disabled?: boolean;
+}>) {
+  const activeOption = INTENT_OPTIONS.find((o) => o.intent === value);
+
+  return (
+    <div className="space-y-1.5">
+      {!compact && (
+        <p className="text-[10px] font-medium uppercase tracking-widest text-muted-foreground px-0.5">
+          Safety overlay
+        </p>
+      )}
+      <div className="flex flex-wrap gap-1">
+        {INTENT_OPTIONS.map((opt) => {
+          const Icon = opt.icon;
+          const isActive = value === opt.intent;
+          return (
+            <button
+              key={opt.intent}
+              type="button"
+              onClick={() => onChange(opt.intent)}
+              title={opt.description}
+              disabled={disabled}
+              className={cn(
+                "inline-flex items-center gap-1 rounded-full border px-2 py-1 text-[10px] font-medium transition-all",
+                disabled && "cursor-not-allowed opacity-50",
+                isActive
+                  ? "border-transparent shadow-sm"
+                  : "border-border text-muted-foreground hover:text-foreground hover:border-foreground/30",
+              )}
+              style={
+                isActive
+                  ? {
+                      backgroundColor: `${opt.color}18`,
+                      color: opt.color,
+                      borderColor: `${opt.color}50`,
+                    }
+                  : undefined
+              }
+            >
+              <Icon size={12} className="shrink-0" />
+              {compact ? opt.shortLabel : opt.label}
+            </button>
+          );
+        })}
+      </div>
+      {!compact && activeOption && activeOption.intent !== "none" && (
+        <div className="space-y-0.5 px-0.5">
+          <p className="text-[10px] text-muted-foreground">
+            {activeOption.description}
+          </p>
+          {activeOption.intent !== "overall" && activeOption.focusAreas && (
+            <p className="text-[9px] font-mono text-muted-foreground/70">
+              {activeOption.focusAreas}
+            </p>
+          )}
+        </div>
+      )}
+    </div>
+  );
+}
