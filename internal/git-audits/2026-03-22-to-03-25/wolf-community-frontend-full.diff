+          ))}
+        </div>
+      )}
+
+      {!item.totalCount && (
+        <p className="text-[10px] text-muted-foreground leading-relaxed">{tText}</p>
+      )}
+    </div>
+  );
+}
+
+// ─── Honeycomb Map (H3-aware SVG layout) ──────────────────────
+function HoneycombMap({ centerH3, neighbors, onSelect, selectedIndex }: Readonly<{
+  centerH3: string;
+  neighbors: CwUnifiedCrimeHexItem[];
+  onSelect: (i: number) => void;
+  selectedIndex: number | null;
+}>) {
+  const [hoveredIndex, setHoveredIndex] = useState<number | null>(null);
+  const [tooltipPos, setTooltipPos] = useState<{ x: number; y: number } | null>(null);
+  const svgRef = useRef<SVGSVGElement>(null);
+  const containerRef = useRef<HTMLDivElement>(null);
+
+  const R = 1;
+  const { positions: nCentres, vertexRotation } = useMemo(
+    () => computeH3Layout(centerH3, neighbors.map(n => n.h3Index)),
+    [centerH3, neighbors],
+  );
+  const hexPts = useMemo(() => makeHexPoints(vertexRotation), [vertexRotation]);
+
+  const D = R * Math.sqrt(3);
+  const pad = R + 0.25;
+  const vSize = (D + pad) * 2;
+  const vMin = -(D + pad);
+
+  return (
+    <div ref={containerRef} className="relative w-full flex-1 min-h-0 bg-muted/30 rounded-lg border border-border/30">
+      <svg
+        ref={svgRef}
+        viewBox={`${vMin} ${vMin} ${vSize} ${vSize}`}
+        className="w-full block overflow-visible"
+        style={{ maxHeight: "calc(85vh - 12rem)" }}
+        preserveAspectRatio="xMidYMid meet"
+      >
+        <defs>
+          <filter id="chd-hglow" x="-80%" y="-80%" width="260%" height="260%">
+            <feGaussianBlur stdDeviation="0.12" result="b"/>
+            <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
+          </filter>
+          <filter id="chd-hglow2" x="-80%" y="-80%" width="260%" height="260%">
+            <feGaussianBlur stdDeviation="0.22" result="b"/>
+            <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
+          </filter>
+        </defs>
+
+        <polygon points={hexPts(0, 0, R - 0.05)}
+          fill="currentColor" fillOpacity={0.04} stroke="currentColor" strokeOpacity={0.18}
+          strokeWidth="0.05" strokeDasharray="0.15 0.12"/>
+        <text x="0" y="0.08" textAnchor="middle" fill="currentColor" opacity={0.3} fontSize="0.25"
+          style={{ fontFamily: "monospace", letterSpacing: "0.02em" }}>YOU</text>
+
+        {nCentres.map((pos, i) => {
+          const n = neighbors[i];
+          if (!n) return null;
+          return (
+            <HexCell
+              key={n.h3Index}
+              item={n}
+              pos={pos}
+              selected={selectedIndex === i}
+              hovered={hoveredIndex === i}
+              hexR={R}
+              hexPts={hexPts}
+              onSelect={() => onSelect(i)}
+              onHover={h => {
+                setHoveredIndex(h ? i : null);
+                if (h && svgRef.current && containerRef.current) {
+                  const ctm = svgRef.current.getScreenCTM();
+                  if (ctm) {
+                    const sp = new DOMPoint(pos.x, pos.y).matrixTransform(ctm);
+                    const cr = containerRef.current.getBoundingClientRect();
+                    setTooltipPos({ x: sp.x - cr.left, y: sp.y - cr.top });
+                  }
+                } else {
+                  setTooltipPos(null);
+                }
+              }}
+            />
+          );
+        })}
+      </svg>
+
+      {hoveredIndex !== null && neighbors[hoveredIndex] && tooltipPos && (
+        <HoneycombTooltip
+          item={neighbors[hoveredIndex]}
+          isRightSide={nCentres[hoveredIndex]?.x > 0}
+          pos={tooltipPos}
+        />
+      )}
+    </div>
+  );
+}
