+/**
+ * Hex resolution utilities for the safety routing crime hex layer.
+ *
+ * The Go backend serves R8 hexes. The frontend pre-aggregates to R7 and R6
+ * at load time so zooming out doesn't render 1.56M polygons.
+ */
+
+import type { CwUnifiedCrimeHexItem } from "@/utils/cw-unified-crime-hex-api";
+import { cellToParent } from "h3-js";
+
+/**
+ * Map a Mapbox GL zoom level to the appropriate H3 resolution for display.
+ *   zoom >= 11  → R8 (native, ~460m edge)
+ *   zoom 9–10   → R7 (~1.2km edge)
+ *   zoom < 9    → R6 (~3.2km edge)
+ */
+export function zoomToHexResolution(zoom: number): number {
+  if (zoom >= 11) return 8;
+  if (zoom >= 9) return 7;
+  return 6;
+}
+
+/**
+ * Aggregate R8 hex items to a coarser resolution by grouping on parent H3 index.
+ * Uses area-weighted averaging for scores and sum for counts.
+ */
+export function aggregateHexesToResolution(
+  items: CwUnifiedCrimeHexItem[],
+  targetResolution: number,
+): CwUnifiedCrimeHexItem[] {
+  if (targetResolution >= 8) return items;
+
+  const groups = new Map<string, CwUnifiedCrimeHexItem[]>();
+
+  for (const item of items) {
+    const parentH3 = cellToParent(item.h3Index, targetResolution);
+    const group = groups.get(parentH3);
+    if (group) group.push(item);
+    else groups.set(parentH3, [item]);
+  }
+
+  const result: CwUnifiedCrimeHexItem[] = [];
+
+  for (const [parentH3, children] of groups) {
+    const n = children.length;
+    const totalCount = children.reduce((s, c) => s + c.totalCount, 0);
+    const avgColorIndex = Math.round(children.reduce((s, c) => s + c.colorIndex, 0) / n);
+    const avgLat = children.reduce((s, c) => s + (c.lat ?? 0), 0) / n;
+    const avgLng = children.reduce((s, c) => s + (c.lng ?? 0), 0) / n;
+
+    const cr = aggregateCrimeRisks(children);
+    const ct = aggregateCrimeTrends(children);
+    const ss = aggregateSafetyScores(children);
+    const poiModifier = averageOptionalField(children, "poiModifier");
+    const osmModifier = averageOptionalField(children, "osmModifier");
+
+    result.push({
+      h3Index: parentH3,
+      resolution: targetResolution,
+      totalCount,
+      drugCount: children.reduce((s, c) => s + c.drugCount, 0),
+      violentCount: children.reduce((s, c) => s + c.violentCount, 0),
+      propertyCount: children.reduce((s, c) => s + c.propertyCount, 0),
+      incidentTypeCounts: {},
+      colorIndex: avgColorIndex,
+      lat: avgLat,
+      lng: avgLng,
+      cr: Object.keys(cr).length > 0 ? cr : undefined,
+      ct: Object.keys(ct).length > 0 ? ct : undefined,
+      ss: Object.keys(ss).length > 0 ? ss : undefined,
+      poiModifier,
+      osmModifier,
+    } as CwUnifiedCrimeHexItem & { lat: number; lng: number });
+  }
+
+  return result;
+}
+
+function aggregateCrimeRisks(children: CwUnifiedCrimeHexItem[]): Record<string, number> {
+  const sums: Record<string, number> = {};
+  const counts: Record<string, number> = {};
+
+  for (const child of children) {
+    if (!child.cr) continue;
+    for (const [code, risk] of Object.entries(child.cr)) {
+      sums[code] = (sums[code] ?? 0) + risk;
+      counts[code] = (counts[code] ?? 0) + 1;
+    }
+  }
+
+  const result: Record<string, number> = {};
+  for (const code of Object.keys(sums)) {
+    result[code] = Math.round(sums[code] / counts[code]);
+  }
+  return result;
+}
+
+function aggregateCrimeTrends(children: CwUnifiedCrimeHexItem[]): Record<string, number> {
+  const sums: Record<string, number> = {};
+  const counts: Record<string, number> = {};
+
+  for (const child of children) {
+    if (!child.ct) continue;
+    for (const [code, trend] of Object.entries(child.ct)) {
+      sums[code] = (sums[code] ?? 0) + trend;
+      counts[code] = (counts[code] ?? 0) + 1;
+    }
+  }
+
+  const result: Record<string, number> = {};
+  for (const code of Object.keys(sums)) {
+    result[code] = Math.round(sums[code] / counts[code]);
+  }
+  return result;
+}
+
+function averageOptionalField(children: CwUnifiedCrimeHexItem[], field: "poiModifier" | "osmModifier"): number | undefined {
+  let sum = 0;
+  let count = 0;
+  for (const child of children) {
+    const v = child[field];
+    if (v != null) { sum += v; count++; }
+  }
+  return count > 0 ? sum / count : undefined;
+}
+
+/** Average per-intent safety scores so intent toggles work at R7/R6 zoom levels. */
+function aggregateSafetyScores(children: CwUnifiedCrimeHexItem[]): Record<string, number> {
+  const sums: Record<string, number> = {};
+  const counts: Record<string, number> = {};
+
+  for (const child of children) {
+    if (!child.ss) continue;
+    for (const [intent, score] of Object.entries(child.ss)) {
+      if (typeof score === "number") {
+        sums[intent] = (sums[intent] ?? 0) + score;
+        counts[intent] = (counts[intent] ?? 0) + 1;
+      }
+    }
+  }
+
+  const result: Record<string, number> = {};
+  for (const intent of Object.keys(sums)) {
+    result[intent] = Math.round(sums[intent] / counts[intent]);
+  }
+  return result;
+}
