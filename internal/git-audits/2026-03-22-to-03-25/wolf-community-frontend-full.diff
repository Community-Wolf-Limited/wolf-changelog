+// ─── Main export ──────────────────────────────────────────────
+export default function CrimeHexDrawer({ h3Index, hexData, open, onOpenChange }: Readonly<CrimeHexDrawerProps>) {
+  const [selectedNeighborIdx, setSelectedNeighborIdx] = useState<number | null>(null);
+  const [tab, setTab] = useState<string>("list");
+
+  useEffect(() => { setSelectedNeighborIdx(null); }, [h3Index]);
+
+  const { center, neighbors } = useMemo(() => {
