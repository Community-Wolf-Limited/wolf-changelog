+// ─── HoneycombTooltip ─────────────────────────────────────────
+function HoneycombTooltip({ item, isRightSide, pos }: Readonly<{
+  item: CwUnifiedCrimeHexItem;
+  isRightSide: boolean;
+  pos: { x: number; y: number };
+}>) {
+  const score = threatScore(item);
+  const { label: tLabel, color: tColor, text: tText } = getThreat(score);
+  const incidents = Object.entries(item.incidentTypeCounts).filter(([, v]) => v > 0).sort((a, b) => b[1] - a[1]);
+
+  return (
+    <div
+      className="absolute w-44 bg-card border rounded-lg p-3 shadow-xl z-30 animate-in fade-in slide-in-from-bottom-2 duration-150 pointer-events-none"
+      style={{
+        top: pos.y,
+        left: pos.x,
+        transform: isRightSide ? "translate(1rem, -50%)" : "translate(calc(-100% - 1rem), -50%)",
+        borderColor: `${tColor}40`,
+      }}
+    >
+      <div className="flex items-center gap-2 mb-2">
+        <div className="w-1.5 h-1.5 rounded-full shrink-0" style={{ background: tColor, boxShadow: `0 0 5px ${tColor}` }}/>
+        <span className="text-[10px] tracking-widest font-mono font-medium" style={{ color: tColor }}>{tLabel}</span>
+      </div>
+
+      <div className="flex justify-between gap-2 mb-2">
+        {CAT_KEYS.map(k => {
+          const cfg = CAT[k];
+          const val = getCatCount(item, k);
+          return (
+            <div key={k} className="text-center flex-1">
+              <cfg.Icon size={10} style={{ color: val > 0 ? cfg.color : undefined }} className={cn("mx-auto mb-0.5", !val && "opacity-20")}/>
+              <div className="text-xs font-bold font-mono" style={{ color: val > 0 ? cfg.color : undefined }}>
+                {val > 0 ? val : "—"}
+              </div>
+              <div className="text-[8px] text-muted-foreground tracking-wide">{cfg.label}</div>
+            </div>
+          );
+        })}
+      </div>
+
+      {item.totalCount > 0 && (
+        <div className="flex items-center gap-1.5 bg-wolf-green/10 rounded px-2 py-1 mb-2">
+          <TrendingUp size={9} className="text-wolf-green shrink-0"/>
+          <span className="text-[10px] font-mono text-wolf-green/80">~{item.totalCount * ANNUALISE} projected/yr</span>
+        </div>
+      )}
+
+      {incidents.length > 0 && (
+        <div>
+          <div className="text-[9px] text-muted-foreground tracking-widest mb-1">TOP INCIDENTS</div>
