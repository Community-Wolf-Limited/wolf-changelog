+              </span>
+            </div>
+            {c && (
+              <Badge variant="outline" className="text-xs py-0.5" style={{ color, borderColor: `${color}40` }}>{label}</Badge>
+            )}
+          </div>
+          <Button variant="outline" onClick={() => onOpenChange(false)}>
+            Close
+          </Button>
+        </div>
+
+        <div className="h-[calc(85vh-80px)] overflow-hidden flex flex-col px-6 py-4">
+          <Separator className="mb-2"/>
+          <Tabs value={tab} onValueChange={v => { setTab(v); setSelectedNeighborIdx(null); }} className="flex-1 min-h-0 flex flex-col">
+            <TabsList className="grid w-full grid-cols-2 shrink-0">
+              <TabsTrigger value="list" className="flex items-center gap-2 text-xs">
+                <LayoutList size={14}/>
+                Details + List
+              </TabsTrigger>
+              <TabsTrigger value="map" className="flex items-center gap-2 text-xs">
+                <Hexagon size={14}/>
+                Map View
+              </TabsTrigger>
+            </TabsList>
+
+            <TabsContent value="list" className="flex-1 min-h-0 mt-3">
+              <ScrollArea className="h-[calc(85vh-180px)]">
+                <div className="space-y-4 pb-6">
+                  {/* Selected hex detail card */}
+                  <Card>
+                    <CardContent className="p-4">
+                      <div className="flex items-center justify-between mb-3">
+                        <Badge variant="outline" className="text-xs" style={{ color, borderColor: `${color}40` }}>{label}</Badge>
+                        <code className="text-[10px] text-muted-foreground">{getH3DisplayText(c, h3Index)}</code>
+                      </div>
+                      {c ? (
+                        <div className="space-y-3">
+                          <div className="flex items-stretch gap-4">
+                            <div className="flex-1 min-w-0 flex items-center justify-center">
+                              <ThreatArc score={score} color={color}/>
+                            </div>
+                            <Separator orientation="vertical" className="self-stretch"/>
+                            <div className="flex-[2.5] min-w-0 flex items-start justify-evenly rounded-lg border border-border/50 bg-muted/30 p-2">
+                              <CatBar catKey="violent"  value={c.violentCount}  max={maxCat}/>
+                              <Separator orientation="vertical" className="h-8 self-center"/>
+                              <CatBar catKey="property" value={c.propertyCount} max={maxCat}/>
+                              <Separator orientation="vertical" className="h-8 self-center"/>
+                              <CatBar catKey="drug"     value={c.drugCount}     max={maxCat}/>
+                            </div>
+                          </div>
+                          <Chips counts={c.incidentTypeCounts} limit={2}/>
+                          {c.totalCount > 0 && <QuarterlyBanner totalCount={c.totalCount}/>}
+                        </div>
+                      ) : (
+                        <p className="text-sm text-muted-foreground py-4">
+                          {h3Index ? "No crime data for this cell." : "Tap a hex on the map to inspect it."}
+                        </p>
+                      )}
+                    </CardContent>
+                  </Card>
+
+                  {/* Neighbor list */}
+                  {neighbors.length > 0 && (
+                    <div className="space-y-2">
+                      <h4 className="text-sm font-medium text-muted-foreground px-1">Adjacent Cells</h4>
+                      <div className="space-y-1.5">
+                        {[...neighbors].sort((a, b) => b.totalCount - a.totalCount).map(n => (
+                          <NeighborListRow key={n.h3Index} item={n}/>
+                        ))}
+                      </div>
+                    </div>
+                  )}
+                  {neighbors.length === 0 && (
+                    <p className="text-sm text-muted-foreground text-center py-4">No neighbor data.</p>
+                  )}
+                </div>
+              </ScrollArea>
+            </TabsContent>
+
+            <TabsContent value="map" className="flex-1 min-h-0 mt-3 relative">
+              {neighbors.length > 0 && h3Index ? (
+                <HoneycombMap
+                  centerH3={h3Index}
+                  neighbors={neighbors}
+                  onSelect={i => setSelectedNeighborIdx(prev => prev === i ? null : i)}
+                  selectedIndex={selectedNeighborIdx}
+                />
