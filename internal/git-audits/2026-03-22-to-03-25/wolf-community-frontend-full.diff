+/**
+ * IndexedDB cache for full crime hex data (~1.56M items).
+ * Enables instant page loads when data is fresh; avoids re-fetching on every navigation.
+ */
+
+const DB_NAME = "wolf-hex-cache";
+const DB_VERSION = 1;
+const STORE_NAME = "hexes";
+const CACHE_KEY = "all";
+const TTL_MS = 60 * 60 * 1000; // 1 hour
+const CACHE_SCHEMA_VERSION = 2;
+
+export interface HexCacheEntry<T = unknown> {
+  data: T[];
+  storedAt: number;
+  schemaVersion?: number;
+}
+
+function openDb(): Promise<IDBDatabase> {
+  return new Promise((resolve, reject) => {
+    const req = indexedDB.open(DB_NAME, DB_VERSION);
+    req.onerror = () => reject(req.error);
+    req.onsuccess = () => resolve(req.result);
+    req.onupgradeneeded = (e) => {
+      const db = (e.target as IDBOpenDBRequest).result;
+      if (!db.objectStoreNames.contains(STORE_NAME)) {
+        db.createObjectStore(STORE_NAME, { keyPath: "key" });
+      }
+    };
+  });
+}
+
+export async function getHexCache(): Promise<HexCacheEntry | null> {
+  try {
+    const db = await openDb();
+    return new Promise((resolve, reject) => {
+      const tx = db.transaction(STORE_NAME, "readonly");
+      const store = tx.objectStore(STORE_NAME);
+      const req = store.get(CACHE_KEY);
+      req.onerror = () => {
+        db.close();
+        reject(req.error);
+      };
+      req.onsuccess = () => {
+        db.close();
+        const entry = req.result as (HexCacheEntry & { key?: string }) | undefined;
+        if (!entry?.data?.length) {
+          resolve(null);
+          return;
+        }
+        if ((entry.schemaVersion ?? 1) < CACHE_SCHEMA_VERSION) {
+          resolve(null);
+          return;
+        }
+        const age = Date.now() - entry.storedAt;
+        if (age > TTL_MS) {
+          resolve(null);
+          return;
+        }
+        resolve(entry);
+      };
+    });
+  } catch {
+    return null;
+  }
+}
+
+export async function setHexCache(data: unknown[]): Promise<void> {
+  try {
+    const db = await openDb();
+    return new Promise((resolve, reject) => {
+      const tx = db.transaction(STORE_NAME, "readwrite");
+      const store = tx.objectStore(STORE_NAME);
+      const entry: HexCacheEntry & { key: string } = {
+        key: CACHE_KEY,
+        data,
+        storedAt: Date.now(),
+        schemaVersion: CACHE_SCHEMA_VERSION,
+      };
+      const req = store.put(entry);
+      req.onerror = () => {
+        db.close();
+        reject(req.error);
+      };
+      req.onsuccess = () => {
+        db.close();
+        resolve();
+      };
+    });
+  } catch {
+    // Non-fatal
+  }
+}
