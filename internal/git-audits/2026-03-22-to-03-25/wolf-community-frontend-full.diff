+/**
+ * Viewport capping and bounds filter for crime hex (aligned with enterprise).
+ */
+
+import type { CwUnifiedCrimeHexItem, HexSafetyIntent } from "@/utils/cw-unified-crime-hex-api";
+
+export function capItemsForDisplay(items: CwUnifiedCrimeHexItem[], max: number): CwUnifiedCrimeHexItem[] {
+  if (items.length <= max) return items;
+  const step = items.length / max;
+  const out: CwUnifiedCrimeHexItem[] = [];
+  for (let i = 0; i < max; i++) {
+    const idx = Math.floor(i * step);
+    out.push(items[idx]);
+  }
+  return out;
+}
+
+export function filterHexItemsByMapBounds(
+  items: CwUnifiedCrimeHexItem[],
+  west: number,
+  south: number,
+  east: number,
+  north: number,
+): CwUnifiedCrimeHexItem[] {
+  return items.filter((i) => i.lng != null && i.lat != null && i.lng >= west && i.lng <= east && i.lat >= south && i.lat <= north);
+}
+
+/** Map item → display row with safetyScore for GeoJSON. Uses the selected intent's pre-computed score from Go backend. */
+export function scoreCrimeHexItemsForDisplay(
+  items: CwUnifiedCrimeHexItem[],
+  intent: HexSafetyIntent = "travel",
+): Array<CwUnifiedCrimeHexItem & { safetyScore?: number }> {
+  return items.map((i) => ({
+    ...i,
+    safetyScore: i.ss?.[intent] ?? i.ss?.overall ?? 100 - Math.min(100, i.colorIndex * 6),
+  }));
+}
