index 0000000..53d8cb7
--- /dev/null
+++ b/src/pages/live-map/CrimeHexDrawer.tsx
@@ -0,0 +1,769 @@
+import { useState, useEffect, useMemo, useRef } from "react";
+import { gridDisk, cellToLatLng, cellToBoundary } from "h3-js";
+import { Button } from "@/components/ui/button";
+import { Tabs, TabsList, TabsTrigger, TabsContent } from "@/components/ui/tabs";
+import { Card, CardContent } from "@/components/ui/card";
+import { Badge } from "@/components/ui/badge";
+import { Separator } from "@/components/ui/separator";
+import { ScrollArea } from "@/components/ui/scroll-area";
+import {
+  Zap, Home, Pill, AlertTriangle, TrendingUp, Clock, X,
+  Hexagon, ChevronDown, LayoutList,
+} from "lucide-react";
+import { cn } from "@/lib/utils";
+import type { CwUnifiedCrimeHexItem } from "@/utils/cw-unified-crime-hex-api";
+
+// ─── types ────────────────────────────────────────────────────
+interface CrimeHexDrawerProps {
+  readonly h3Index: string | null;
+  readonly hexData: CwUnifiedCrimeHexItem[];
+  readonly open: boolean;
+  readonly onOpenChange: (open: boolean) => void;
+}
+
+// ─── constants & utils ────────────────────────────────────────
+const ANNUALISE = 4;
+
+const CAT = {
+  violent:  { label: "Violent",  color: "#dc2626", Icon: Zap,  description: "Assault, robbery, murder, sexual offences" },
+  property: { label: "Property", color: "#1a4f38", Icon: Home, description: "Burglary, break-ins, theft" },
+  drug:     { label: "Drug",     color: "#6b7280", Icon: Pill, description: "Drug-related offences" },
+} as const;
+
+type CatKey = keyof typeof CAT;
+const CAT_KEYS: readonly CatKey[] = ["violent", "property", "drug"];
+
+function getNeighborIndices(centerH3: string): string[] {
+  try { return gridDisk(centerH3, 1).filter(h => h !== centerH3); }
+  catch { return []; }
+}
+
+function threatScore(item: CwUnifiedCrimeHexItem | null): number {
+  if (!item) return 0;
+  return Math.min(100, item.violentCount * 14 + item.propertyCount * 7 + item.drugCount * 6);
+}
+
+function getThreat(score: number) {
+  if (score >= 70) return { label: "Critical",  color: "#dc2626", dim: "rgba(220,38,38,0.12)",  variant: "destructive" as const, text: "Extreme danger zone. Avoid if possible." };
+  if (score >= 45) return { label: "High",      color: "#d97706", dim: "rgba(217,119,6,0.12)",  variant: "default" as const,     text: "Significantly elevated crime activity." };
+  if (score >= 20) return { label: "Moderate",   color: "#1a4f38", dim: "rgba(26,79,56,0.12)",   variant: "secondary" as const,   text: "Noticeable crime presence. Stay alert." };
+  if (score > 0)   return { label: "Low",        color: "#2d7a5a", dim: "rgba(45,122,90,0.10)",  variant: "outline" as const,     text: "Minor activity recorded." };
+  return             { label: "Clear",      color: "#6b7280", dim: "rgba(107,114,128,0.06)", variant: "outline" as const,     text: "No incidents recorded in this cell." };
+}
+
+function getCatCount(item: CwUnifiedCrimeHexItem, key: CatKey): number {
+  if (key === "violent") return item.violentCount;
+  if (key === "property") return item.propertyCount;
+  return item.drugCount;
+}
+
+function getH3DisplayText(c: CwUnifiedCrimeHexItem | null, h3Index: string | null): string {
+  if (c) return `…${c.h3Index.slice(-10)}`;
+  if (h3Index) return "No data";
+  return "No hex selected";
+}
+
+// ─── hex style helpers (theme-aware via currentColor) ─────────
+function hexFillAttrs(selected: boolean, hovered: boolean, hasCrime: boolean, dim: string, color: string) {
+  if (selected) return { fill: dim, fillOpacity: 1 };
+  if (hovered) return { fill: `${color}20`, fillOpacity: 1 };
+  if (hasCrime) return { fill: "currentColor", fillOpacity: 0.04 };
+  return { fill: "currentColor", fillOpacity: 0.012 };
+}
+
+function hexStrokeAttrs(hasCrime: boolean, highlighted: boolean, color: string) {
+  if (!hasCrime) return { stroke: "currentColor", strokeOpacity: 0.08 };
+  if (highlighted) return { stroke: color, strokeOpacity: 1 };
+  return { stroke: color, strokeOpacity: 0.33 };
+}
+
+function hexStrokeWidth(selected: boolean, hovered: boolean): number {
+  if (selected) return 0.08;
+  if (hovered) return 0.06;
+  return 0.03;
+}
+
+// ─── H3 layout: compute positions from actual coordinates ─────
+interface HexPosition { x: number; y: number; angle: number }
+
+function computeH3Layout(
+  centerH3: string,
+  neighborH3s: string[],
+): { positions: HexPosition[]; vertexRotation: number } {
+  const R = 1;
+  const D = R * Math.sqrt(3);
+  const fallbackRotation = -Math.PI / 6;
+
+  if (neighborH3s.length === 0) {
+    return { positions: [], vertexRotation: fallbackRotation };
+  }
+
+  try {
+    const [cLat, cLng] = cellToLatLng(centerH3);
+    const cosLat = Math.cos(cLat * Math.PI / 180);
+
+    const boundary = cellToBoundary(centerH3);
+    const [v0Lat, v0Lng] = boundary[0];
+    const vDx = (v0Lng - cLng) * cosLat;
+    const vDy = -(v0Lat - cLat);
+    const vertexRotation = Math.atan2(vDy, vDx);
+
+    // 6 canonical slot angles — each neighbor faces an edge midpoint,
+    // exactly 30° offset from vertex 0, then every 60° after that.
+    const slots = Array.from({ length: 6 }, (_, k) =>
+      vertexRotation + Math.PI / 6 + k * Math.PI / 3,
+    );
+
+    // Compute raw angles from H3 coordinates
+    const rawAngles = neighborH3s.map(n => {
+      const [nLat, nLng] = cellToLatLng(n);
+      const dx = (nLng - cLng) * cosLat;
+      const dy = -(nLat - cLat);
+      return Math.atan2(dy, dx);
+    });
+
+    // Build every (neighbor, slot) pair scored by angular distance
+    const pairs: { ni: number; si: number; diff: number }[] = [];
+    for (let ni = 0; ni < rawAngles.length; ni++) {
+      for (let si = 0; si < 6; si++) {
+        let diff = Math.abs(rawAngles[ni] - slots[si]);
+        if (diff > Math.PI) diff = 2 * Math.PI - diff;
+        pairs.push({ ni, si, diff });
+      }
+    }
+    pairs.sort((a, b) => a.diff - b.diff);
+
+    // Greedy unique assignment — closest pairs first, no double-booking
+    const assigned = new Array<number>(rawAngles.length).fill(-1);
+    const taken = new Set<number>();
+    for (const { ni, si } of pairs) {
+      if (assigned[ni] !== -1 || taken.has(si)) continue;
+      assigned[ni] = si;
+      taken.add(si);
+    }
+
+    const positions = neighborH3s.map((_, i) => {
+      const angle = slots[assigned[i]];
+      return { x: D * Math.cos(angle), y: D * Math.sin(angle), angle };
+    });
+
+    return { positions, vertexRotation };
+  } catch {
+    const positions = neighborH3s.map((_, i) => {
+      const angle = fallbackRotation + Math.PI / 6 + i * Math.PI / 3;
+      return { x: D * Math.cos(angle), y: D * Math.sin(angle), angle };
+    });
+    return { positions, vertexRotation: fallbackRotation };
+  }
+}
+
+function makeHexPoints(vertexRotation: number): (cx: number, cy: number, r: number) => string {
+  return (cx, cy, r) =>
+    Array.from({ length: 6 }, (_, i) => {
+      const a = (Math.PI / 3) * i + vertexRotation;
+      return `${cx + r * Math.cos(a)},${cy + r * Math.sin(a)}`;
+    }).join(" ");
+}
+
+// ─── HexCell style computation (extracted for complexity) ─────
+function computeHexCellStyles(
+  hovered: boolean, selected: boolean, hasCrime: boolean,
+  hexR: number, color: string, dim: string,
+) {
+  const highlighted = selected || hovered;
+  const fa = hexFillAttrs(selected, hovered, hasCrime, dim, color);
+  const sa = hexStrokeAttrs(hasCrime, highlighted, color);
+  return {
+    highlighted,
+    fill: fa.fill,
+    fillOpacity: fa.fillOpacity,
+    stroke: sa.stroke,
+    strokeOpacity: sa.strokeOpacity,
+    strokeW: hexStrokeWidth(selected, hovered),
+    dotR: hexR * (hovered ? 0.14 : 0.11),
+    dotOpacity: hasCrime ? 1 : 0.25,
+    dotFilter: hasCrime ? `drop-shadow(0 0 0.12px ${color})` : undefined,
+    countFill: "currentColor" as const,
+    countOpacity: hasCrime ? 1 : 0.2,
+    countSize: hovered ? hexR * 0.52 : hexR * 0.44,
+    connStroke: hasCrime ? color : "currentColor",
+    connStrokeOpacity: hasCrime ? 0.19 : 0.04,
+    connWidth: hovered ? 0.04 : 0.02,
+    connDash: hovered ? undefined as string | undefined : "0.06 0.06",
+    glowStrokeW: hovered ? 0.12 : 0.08,
+    glowOpacity: hovered ? 0.45 : 0.3,
+  };
+}
+
+// ─── ThreatArc (SVG gauge — keeps inline styles) ──────────────
+function ThreatArc({ score, color }: Readonly<{ score: number; color: string }>) {
+  const r = 46, cx = 60, cy = 60, start = -210, span = 240;
+  const rad = (a: number) => a * Math.PI / 180;
+  const pt  = (a: number) => ({ x: cx + r * Math.cos(rad(a)), y: cy + r * Math.sin(rad(a)) });
+  const arc = (s: number, e: number) => {
+    const sp = pt(s), ep = pt(e); return `M${sp.x} ${sp.y}A${r} ${r} 0 ${e - s > 180 ? 1 : 0} 1 ${ep.x} ${ep.y}`;
+  };
+  const filled = start + span * (score / 100);
+  const ticks = Array.from({ length: 11 }, (_, i) => {
+    const a = start + (span * i) / 10;
+    const ip = pt(a);
+    const tickOuter = r + (i % 5 === 0 ? 7 : 4);
+    return { a, ip, op: { x: cx + tickOuter * Math.cos(rad(a)), y: cy + tickOuter * Math.sin(rad(a)) }, major: i % 5 === 0 };
+  });
+  return (
+    <svg viewBox="0 0 120 86" className="overflow-visible w-full h-auto max-h-[140px]" preserveAspectRatio="xMidYMid meet">
+      <defs>
+        <filter id="chd-gf"><feGaussianBlur stdDeviation="2.5" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
+        <linearGradient id="chd-ag" gradientUnits="userSpaceOnUse" x1="14" y1="60" x2="106" y2="60">
+          <stop offset="0%" stopColor="#1a4f38"/><stop offset="50%" stopColor="#d97706"/><stop offset="100%" stopColor="#dc2626"/>
+        </linearGradient>
+      </defs>
+      <path d={arc(start, start + span)} fill="none" stroke="currentColor" strokeWidth="4.5" strokeLinecap="round" opacity={0.08}/>
+      {score > 0 && <path d={arc(start, filled)} fill="none" stroke="url(#chd-ag)" strokeWidth="4.5" strokeLinecap="round" filter="url(#chd-gf)"/>}
+      {ticks.map(t => (
+        <line key={t.a} x1={t.ip.x} y1={t.ip.y} x2={t.op.x} y2={t.op.y}
+          stroke="currentColor" opacity={t.major ? 0.22 : 0.07} strokeWidth={t.major ? 1.5 : 1}/>
+      ))}
+      {score > 0 && <circle cx={pt(filled).x} cy={pt(filled).y} r="4" fill={color} style={{ filter: `drop-shadow(0 0 5px ${color})` }}/>}
+      <text x={cx} y={56} textAnchor="middle" fill="currentColor" fontSize="20" fontWeight="700">{score}</text>
+      <text x={cx} y={70} textAnchor="middle" fill="currentColor" fontSize="7" opacity={0.35}
+        style={{ letterSpacing: "2px" }}>THREAT</text>
+    </svg>
+  );
+}
+
+// ─── CatBar (custom visualization — keeps inline for SVG-like rendering) ──
+function CatBar({ catKey, value, max }: Readonly<{ catKey: CatKey; value: number; max: number }>) {
+  const cfg = CAT[catKey];
+  const hasValue = value > 0;
+  const pct = hasValue ? Math.max(12, (value / max) * 100) : 0;
+  return (
+    <div className="flex-1 flex flex-col items-center text-center gap-1 py-2 px-1">
+      <cfg.Icon size={18} className={cn("mb-1", hasValue ? "" : "opacity-25")} style={{ color: hasValue ? cfg.color : undefined }}/>
+      <div className="h-12 w-6 rounded bg-muted/50 relative overflow-hidden border border-border/30">
+        <div
+          className="absolute bottom-0 left-0 right-0 rounded transition-all duration-700"
+          style={{ height: `${pct}%`, background: hasValue ? cfg.color : "transparent", boxShadow: hasValue ? `0 0 8px ${cfg.color}60` : "none" }}
+        />
+      </div>
+      <span className={cn("text-sm font-bold font-mono", !hasValue && "text-muted-foreground/30")} style={{ color: hasValue ? cfg.color : undefined }}>
+        {hasValue ? value : "—"}
+      </span>
+      {hasValue && (
+        <span className="text-[10px] text-muted-foreground font-mono">~{value * ANNUALISE}/yr</span>
+      )}
+      <span className="text-[10px] text-muted-foreground tracking-wider">{cfg.label}</span>
+    </div>
+  );
+}
+
+// ─── Chips (incident type badges) ─────────────────────────────
+function Chips({ counts, limit = 2 }: Readonly<{ counts: Record<string, number>; limit?: number }>) {
+  const [exp, setExp] = useState(false);
+  const entries = Object.entries(counts).filter(([, n]) => n > 0).sort((a, b) => b[1] - a[1]);
+  if (!entries.length) return <span className="text-xs text-muted-foreground">No incidents</span>;
+  const shown = exp ? entries : entries.slice(0, limit);
+  return (
+    <div className="space-y-1.5">
+      <div className="text-[10px] text-muted-foreground tracking-widest font-medium">INCIDENT TYPES</div>
+      <div className="flex flex-wrap gap-1.5">
+        {shown.map(([t, n]) => (
+          <Badge key={t} variant="outline" className="font-normal text-xs gap-1.5 py-0.5">
+            {t}
+            <span className="bg-muted rounded-full px-1.5 text-[10px] font-mono font-semibold">×{n}</span>
+          </Badge>
+        ))}
+        {entries.length > limit && (
+          <button type="button" onClick={() => setExp(e => !e)}
+            className="text-xs text-muted-foreground border border-border rounded-full px-2.5 py-0.5 hover:bg-accent transition-colors">
+            {exp ? "less" : `+${entries.length - limit}`}
+          </button>
+        )}
+      </div>
+    </div>
+  );
+}
+
+// ─── Quarterly context banner ─────────────────────────────────
+function QuarterlyBanner({ totalCount }: Readonly<{ totalCount: number }>) {
+  const projected = totalCount * ANNUALISE;
+  return (
+    <div className="flex items-start gap-2 bg-wolf-green/5 border border-wolf-green/20 rounded-lg p-2.5 mt-3">
+      <Clock size={12} className="text-wolf-green shrink-0 mt-0.5"/>
+      <div>
+        <div className="text-[10px] text-wolf-green font-medium tracking-wide mb-0.5">QUARTERLY SNAPSHOT</div>
+        <p className="text-xs text-muted-foreground leading-relaxed">
+          Data covers ~1 quarter. Projected annual total:{" "}
+          <span className="text-wolf-green font-semibold">~{projected} incidents</span>.
+          {projected >= 20 && " This area has elevated year-round risk."}
+        </p>
+      </div>
+    </div>
+  );
+}
+
+// ─── CategoryDots (SVG sub-component) ─────────────────────────
+function CategoryDots({ x, y, r, hovered, item }: Readonly<{
+  x: number; y: number; r: number; hovered: boolean; item: CwUnifiedCrimeHexItem;
+}>) {
+  const cy = y + r * (hovered ? 0.66 : 0.58);
+  const dotR = r * (hovered ? 0.1 : 0.09);
+  return (
+    <g>
+      {item.violentCount  > 0 && <circle cx={x - r * 0.22} cy={cy} r={dotR} fill={CAT.violent.color}  style={{ transition: "all 0.15s" }}/>}
+      {item.propertyCount > 0 && <circle cx={x}             cy={cy} r={dotR} fill={CAT.property.color} style={{ transition: "all 0.15s" }}/>}
+      {item.drugCount     > 0 && <circle cx={x + r * 0.22} cy={cy} r={dotR} fill={CAT.drug.color}     style={{ transition: "all 0.15s" }}/>}
+    </g>
+  );
+}
+
+// ─── HexCell (SVG — keeps inline styles) ──────────────────────
+function HexCell({ item, pos, selected, hovered, hexR, hexPts, onSelect, onHover }: Readonly<{
+  item: CwUnifiedCrimeHexItem;
+  pos: HexPosition;
+  selected: boolean;
+  hovered: boolean;
+  hexR: number;
+  hexPts: (cx: number, cy: number, r: number) => string;
+  onSelect: () => void;
+  onHover: (h: boolean) => void;
+}>) {
+  const score = threatScore(item);
+  const { color } = getThreat(score);
+  const hasCrime = item.totalCount > 0;
+  const ri = hexR - 0.08;
+  const s = computeHexCellStyles(hovered, selected, hasCrime, hexR, color, getThreat(score).dim);
+
+  return (
+    <g onClick={onSelect} onMouseEnter={() => onHover(true)} onMouseLeave={() => onHover(false)}
+      style={{ cursor: "pointer" }}>
+      {s.highlighted && (
+        <polygon points={hexPts(pos.x, pos.y, ri + 0.18)}
+          fill="none" stroke={color} strokeWidth={s.glowStrokeW} opacity={s.glowOpacity}
+          filter="url(#chd-hglow2)"/>
+      )}
+      {selected && (
+        <polygon points={hexPts(pos.x, pos.y, ri + 0.08)}
+          fill="none" stroke={color} strokeWidth="0.07" opacity="0.6"
+          filter="url(#chd-hglow)"/>
+      )}
+      <polygon points={hexPts(pos.x, pos.y, ri)}
+        fill={s.fill} fillOpacity={s.fillOpacity} stroke={s.stroke} strokeOpacity={s.strokeOpacity} strokeWidth={s.strokeW}/>
+      <circle cx={pos.x} cy={pos.y - hexR * 0.42} r={s.dotR}
+        fill={color} opacity={s.dotOpacity}
+        style={{ transition: "r 0.15s", filter: s.dotFilter }}/>
+      <text x={pos.x} y={pos.y + hexR * 0.14} textAnchor="middle"
+        fill={s.countFill} opacity={s.countOpacity} fontSize={s.countSize} fontWeight="700"
+        style={{ transition: "font-size 0.15s" }}>
+        {item.totalCount}
+      </text>
+      {hovered && hasCrime && (
+        <text x={pos.x} y={pos.y + hexR * 0.42} textAnchor="middle"
+          fill="currentColor" opacity={0.5} fontSize={hexR * 0.2}
+          style={{ fontFamily: "monospace" }}>
+          ~{item.totalCount * ANNUALISE}/yr
+        </text>
+      )}
+      <CategoryDots x={pos.x} y={pos.y} r={hexR} hovered={hovered} item={item}/>
