index 0000000..4d8d756
--- /dev/null
+++ b/src/utils/crime-hex-geojson.ts
@@ -0,0 +1,109 @@
+/**
+ * Crime hex → GeoJSON for map.
+ * Color palette and scoring logic matches enterprise frontend exactly.
+ */
+
+import type { CwUnifiedCrimeHexItem } from "@/utils/cw-unified-crime-hex-api";
+import { h3ToGeoJsonPolygon } from "@/utils/h3-geo";
+
+export type HexItemForGeoJson = CwUnifiedCrimeHexItem & {
+  safetyScore?: number;
+  reportRisk?: number | null;
+};
+
+const NO_DATA_HEX_COLOR = "#9ca3af";
+const VERY_LOW_HEX_COLOR = "#bbf7d0";
+const ZERO_CRIME_HEX_COLOR = "#16a34a";
+
+const VERY_LOW_RISK_THRESHOLD = 4;
+const NO_DATA_SAFETY_SCORE = -1;
+
+function hexRenderState(score: number | undefined): "nodata" | "zero" | "verylow" | "normal" {
+  if (score == null || score === NO_DATA_SAFETY_SCORE || Number.isNaN(score)) return "nodata";
+  if (score === 100) return "zero";
+  if (score >= 100 - VERY_LOW_RISK_THRESHOLD) return "verylow";
+  return "normal";
+}
+
+const SCORE_COLOR_STOPS: [number, string][] = [
+  [94, "#065f46"],
+  [87, "#047857"],
+  [80, "#059669"],
+  [73, "#10b981"],
+  [66, "#34d399"],
+  [59, "#84cc16"],
+  [52, "#a3e635"],
+  [45, "#facc15"],
+  [38, "#fbbf24"],
+  [31, "#f59e0b"],
+  [24, "#f97316"],
+  [17, "#ea580c"],
+  [10, "#dc2626"],
+  [5,  "#b91c1c"],
+  [1,  "#991b1b"],
+  [0,  "#7f1d1d"],
+];
+
+function hexToRgb(hex: string): [number, number, number] {
+  const m = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
+  return m ? [Number.parseInt(m[1], 16), Number.parseInt(m[2], 16), Number.parseInt(m[3], 16)] : [0, 0, 0];
+}
+
+function rgbToHex(r: number, g: number, b: number): string {
+  return "#" + [r, g, b].map((x) => Math.round(Math.max(0, Math.min(255, x))).toString(16).padStart(2, "0")).join("");
+}
+
+function getScoreMapColorSmooth(score: number): string {
+  const s = Math.max(0, Math.min(100, score));
+  const visual = 100 * Math.pow(s / 100, 1.7);
+  const stops = [...SCORE_COLOR_STOPS].sort((a, b) => b[0] - a[0]);
+  for (let i = 0; i < stops.length - 1; i++) {
+    const [hi, cHi] = stops[i];
+    const [lo, cLo] = stops[i + 1];
+    if (visual <= hi && visual >= lo) {
+      const t = hi === lo ? 1 : (visual - lo) / (hi - lo);
+      const [rHi, gHi, bHi] = hexToRgb(cHi);
+      const [rLo, gLo, bLo] = hexToRgb(cLo);
+      return rgbToHex(rLo + t * (rHi - rLo), gLo + t * (gHi - gLo), bLo + t * (bHi - bLo));
+    }
+  }
+  return visual >= 95 ? stops[0][1] : stops.at(-1)?.[1] ?? "#7f1d1d";
+}
+
+export function crimeHexToGeoJson(items: HexItemForGeoJson[]): GeoJSON.FeatureCollection {
+  const features: GeoJSON.Feature<GeoJSON.Polygon>[] = [];
+  for (const item of items) {
+    const coords = h3ToGeoJsonPolygon(item.h3Index);
+    if (coords.length < 3) continue;
+    const score = item.safetyScore;
+    const state = hexRenderState(score);
+    let fillColor: string;
+    switch (state) {
+      case "nodata":
+        fillColor = NO_DATA_HEX_COLOR;
+        break;
+      case "zero":
+        fillColor = ZERO_CRIME_HEX_COLOR;
+        break;
+      case "verylow":
+        fillColor = VERY_LOW_HEX_COLOR;
+        break;
+      default:
+        fillColor = getScoreMapColorSmooth(score ?? 0);
+    }
+    features.push({
+      type: "Feature",
+      id: item.h3Index,
+      geometry: { type: "Polygon", coordinates: [coords] },
+      properties: {
+        h3Index: item.h3Index,
+        fillColor,
+        totalCount: item.totalCount,
+        reportRisk: item.reportRisk == null ? null : Math.max(0, Math.min(100, item.reportRisk)),
+        hasReports: (item.reportRisk ?? 0) > 0 ? 1 : 0,
+        noData: state === "nodata" ? 1 : 0,
+      },
+    });
+  }
+  return { type: "FeatureCollection", features };
+}
