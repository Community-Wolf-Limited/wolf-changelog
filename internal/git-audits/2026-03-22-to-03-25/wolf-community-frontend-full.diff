+                <p className="text-sm text-muted-foreground text-center py-8">No neighbor data.</p>
+              )}
+              {selectedNeighbor && (
+                <NeighborDetail item={selectedNeighbor} onClose={() => setSelectedNeighborIdx(null)}/>
+              )}
+            </TabsContent>
+          </Tabs>
+        </div>
+      </div>
+    </div>
+  );
+}
