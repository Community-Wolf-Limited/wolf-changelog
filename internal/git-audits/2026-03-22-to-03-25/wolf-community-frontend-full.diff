+  cwUnifiedCrimeHexNational: { name: string; tooltip: string };
+  precinctBoundaries: { name: string; tooltip: string };
+  reports: { name: string; tooltip: string };
+  hotspots: { name: string; tooltip: string };
+  heatmap: { name: string; tooltip: string };
+  precinctStations: { name: string; tooltip: string };
+};
+
+/** Mirrors MapPage `mapFilters` state shape */
+export type CommunityMapPageFilters = {
+  layers: {
+    cwUnifiedCrimeHexNational: boolean;
+    reports: boolean;
+    precinctBoundaries: boolean;
+    precinctStations: boolean;
+    heatmap: boolean;
+    hotspots: boolean;
+  };
+  filters: {
+    excludedTypes: string[];
+  };
+};
+
+export type MapLayersToggleKey = keyof CommunityMapPageFilters["layers"];
+
+export function getHeavyLayerLoadingLabel(
+  nationalHexLoading: boolean,
+  nationalHexStatus: string,
+  precinctLoading: boolean,
+): string {
+  if (nationalHexLoading) return nationalHexStatus || "Loading Crime Risk (SA)…";
+  if (precinctLoading) return "Loading SAPS boundaries…";
+  return "Loading map data…";
+}
+
+export function getHeavyLoadIslandTitle(
+  nationalHexLoading: boolean,
+  precinctLoading: boolean,
+): string {
+  if (nationalHexLoading) return "Loading Crime Risk (SA)";
+  if (precinctLoading) return "Loading SAPS boundaries";
+  return "";
+}
+
+export function getPrecinctProgressLabel(progress: PrecinctStreamProgress | null): string | null {
+  if (!progress) return null;
+  if (progress.total) return `${progress.loaded} / ${progress.total} precincts`;
+  return `${progress.loaded} precincts`;
+}
