+/**
+ * CW Crime Hex API (organisation-agnostic; kebab-case backend).
+ * Separate from hex-grid; used only for the live map crime hex layer.
+ */
+
+import { cellToLatLng } from "h3-js";
+import { api, getBackendApiUrl } from "@/utils/api";
+import { getHexCache, setHexCache } from "@/utils/hex-idb-cache";
+import { getSafetyRouterAuth, getSafetyRouterBaseUrl } from "@/utils/safety-routing-api";
+
+export type HexSafetyIntent =
+  | "overall"
+  | "travel"
+  | "walk"
+  | "live"
+  | "sleep"
+  | "business"
+  | "holiday"
+  | "invest";
+
+export interface CwUnifiedCrimeHexItem {
+  h3Index: string;
+  resolution: number;
+  totalCount: number;
+  drugCount: number;
+  violentCount: number;
+  propertyCount: number;
+  incidentTypeCounts: Record<string, number>;
+  colorIndex: number;
+  /** True when totalCount === 0 but a neighbor has crime */
+  hasCrimeNeighbor?: boolean;
+  /** Per-crime-type risk scores (0-100), keyed by 2-letter code (e.g. "MU", "CJ"). From Go backend cr field. */
+  cr?: Record<string, number>;
+  /** Per-crime-type quarter-over-quarter trend (-100..+100), keyed by 2-letter code. From Go backend ct field. */
+  ct?: Record<string, number>;
+  /** Post-average POI proximity modifier. */
+  poiModifier?: number;
+  /** Post-average OSM density modifier. */
+  osmModifier?: number;
+  /** Per-intent safety scores (0-100, pre-POI/OSM) from Go backend. Key = intent. */
+  ss?: Record<string, number>;
+  /** Hex centroid latitude (from Go backend `la` field). */
+  lat?: number;
+  /** Hex centroid longitude (from Go backend `ln` field). */
+  lng?: number;
+}
+
+export interface CwUnifiedCrimeHexDataResponse {
+  success: boolean;
+  data: CwUnifiedCrimeHexItem[];
+  minValue: number;
+  maxValue: number;
+}
+
+export interface CwUnifiedCrimeHexConfig {
+  colors: string[];
+  categoryColorIndex: Record<string, number>;
+  updatedAt?: string;
+}
+
+export interface CwUnifiedCrimeHexConfigResponse {
+  success: boolean;
+  data: CwUnifiedCrimeHexConfig | null;
+}
+
+export interface CwUnifiedCrimeHexFetchParams {
+  west: number;
+  south: number;
+  east: number;
+  north: number;
+  resolution: number;
+  crimeCategories?: ("Drug" | "Violent" | "Property")[];
+}
+
+export async function getCwUnifiedCrimeHexData(
+  params: CwUnifiedCrimeHexFetchParams,
+  token?: string
+): Promise<CwUnifiedCrimeHexDataResponse> {
+  const q = new URLSearchParams({
+    west: String(params.west),
+    south: String(params.south),
+    east: String(params.east),
+    north: String(params.north),
+    resolution: String(params.resolution),
+  });
+  if (params.crimeCategories?.length) {
+    q.set("crimeCategory", params.crimeCategories.join(","));
+  }
+  const res = await api.get<CwUnifiedCrimeHexDataResponse>(
+    `/cw-unified-crime-hex?${q.toString()}`,
+    { token }
+  );
+  return res;
+}
+
+export async function getCwUnifiedCrimeHexConfig(
+  token?: string
+): Promise<CwUnifiedCrimeHexConfigResponse> {
+  return api.get<CwUnifiedCrimeHexConfigResponse>("/cw-unified-crime-hex/config", {
+    token,
+  });
+}
+
+/** Stream viewport hex data as NDJSON for progressive rendering (250 per batch). */
+export interface CwUnifiedCrimeHexStreamProgress {
+  loaded: number;
+  total: number | null;
+}
+
+function buildStreamUrl(params: CwUnifiedCrimeHexFetchParams): string {
+  const q = new URLSearchParams({
+    west: String(params.west),
+    south: String(params.south),
+    east: String(params.east),
+    north: String(params.north),
+    resolution: String(params.resolution),
+  });
+  if (params.crimeCategories?.length) {
+    q.set("crimeCategory", params.crimeCategories.join(","));
+  }
+  const base = getBackendApiUrl().replace(/\/+$/, "");
+  return `${base}/cw-unified-crime-hex/stream?${q.toString()}`;
+}
+
+function tryParseMeta(line: string): number | null {
+  try {
+    const meta = JSON.parse(line) as { _meta?: boolean; total?: number };
+    if (meta?._meta && typeof meta.total === "number") return meta.total;
+  } catch { /* not meta */ }
+  return null;
+}
+
+function tryParseItem(line: string, resolution: number): CwUnifiedCrimeHexItem | null {
+  try {
+    const raw = JSON.parse(line) as { h3Index?: string; colorIndex?: number; totalCount?: number };
+    if (!raw?.h3Index) return null;
+    return {
+      h3Index: raw.h3Index,
+      resolution,
+      totalCount: raw.totalCount ?? 0,
+      drugCount: 0,
+      violentCount: 0,
+      propertyCount: 0,
+      incidentTypeCounts: {},
+      colorIndex: raw.colorIndex ?? 0,
+    };
+  } catch { return null; }
+}
+
+interface StreamState {
+  items: CwUnifiedCrimeHexItem[];
+  total: number | null;
+  lastFlushed: number;
+}
+
+function processNdjsonLines(lines: string[], resolution: number, state: StreamState): void {
+  for (const trimmed of lines.map((l) => l.trim()).filter(Boolean)) {
+    if (state.total === null) {
+      const parsed = tryParseMeta(trimmed);
+      if (parsed !== null) { state.total = parsed; continue; }
+    }
+    const item = tryParseItem(trimmed, resolution);
+    if (item) state.items.push(item);
+  }
+}
+
+export async function getCwUnifiedCrimeHexStream(
+  params: CwUnifiedCrimeHexFetchParams,
+  onBatch: (items: CwUnifiedCrimeHexItem[], progress: CwUnifiedCrimeHexStreamProgress, isComplete?: boolean) => void,
+  token?: string
+): Promise<void> {
+  const url = buildStreamUrl(params);
+  const headers: Record<string, string> = { Accept: "application/x-ndjson" };
+  if (token) headers.Authorization = `Bearer ${token}`;
+  const res = await fetch(url, { headers, cache: "no-store" });
+  if (!res.ok) throw new Error(`Crime hex stream failed: ${res.status}`);
+  const reader = res.body?.getReader();
+  if (!reader) return;
+
+  const decoder = new TextDecoder();
+  let buffer = "";
+  const FLUSH_EVERY = 250;
+  const state: StreamState = { items: [], total: null, lastFlushed: 0 };
+
+  for (;;) {
+    const { done, value } = await reader.read();
+    if (done) break;
+    buffer += decoder.decode(value, { stream: true });
+    const lines = buffer.split("\n");
+    buffer = lines.pop() ?? "";
+    processNdjsonLines(lines, params.resolution, state);
+    if (state.items.length - state.lastFlushed >= FLUSH_EVERY) {
+      state.lastFlushed = state.items.length;
+      onBatch(state.items.slice(), { loaded: state.items.length, total: state.total }, false);
+    }
+  }
+  if (state.items.length > state.lastFlushed || state.items.length > 0) {
+    onBatch(state.items.slice(), { loaded: state.items.length, total: state.total }, true);
+  }
+}
+
+/** Raw crime point from backend - frontend does all hex logic */
+export interface CwUnifiedCrimePoint {
+  lat: number;
+  lng: number;
+  crime_category: string;
+  incident_type: string;
+}
+
+export interface CwUnifiedCrimePointsResponse {
+  success: boolean;
+  data: CwUnifiedCrimePoint[];
+}
+
+export async function getCwUnifiedCrimePoints(
+  token?: string
+): Promise<CwUnifiedCrimePointsResponse> {
+  return api.get<CwUnifiedCrimePointsResponse>("/cw-unified-crime-hex/points", {
+    token,
+  });
+}
+
+/* ── Full hex cache from Go safety router (/hexes/all) ───────────── */
+
+interface GoHexSlimItem {
+  h: string;
+  ci: number;
+  tc: number;
+  la: number;
+  ln: number;
+  cr?: Record<string, number>;
+  ct?: Record<string, number>;
+  pm?: number;
+  om?: number;
+  ss?: Record<string, number>;
+}
+
+function goSlimToItem(g: GoHexSlimItem): CwUnifiedCrimeHexItem {
+  return {
+    h3Index: g.h,
+    resolution: 8,
+    totalCount: g.tc,
+    drugCount: 0,
+    violentCount: 0,
+    propertyCount: 0,
+    incidentTypeCounts: {},
+    colorIndex: g.ci,
+    lat: g.la,
+    lng: g.ln,
+    cr: g.cr,
+    ct: g.ct,
+    poiModifier: g.pm,
+    osmModifier: g.om,
+    ss: g.ss,
+  };
+}
+
+/**
+ * Stream-parse a JSON array response into individually-parsed items without
+ * ever building the full decompressed string (which exceeds V8's ~512 MB cap).
+ *
+ * Uses native `indexOf` on the known top-level delimiter `},{"h":` which is
+ * safe because Go marshals hexSlimItem with `H3` (`json:"h"`) as the first
+ * field, and no nested Record keys start with `"h"`.  This is orders of
+ * magnitude faster than a JS-level character-by-character state machine.
+ *
+ * @param mapper  Optional transform applied to each parsed object inline,
+ *                avoiding a second full-array allocation for `.map()`.
+ * @param onBatch Called every ~10 000 items so callers can render progressively.
+ */
+async function streamParseJsonArray<TRaw, TOut = TRaw>(
+  res: Response,
+  onProgress?: (pct: number, statusText?: string) => void,
+  mapper?: (raw: TRaw) => TOut,
+  onBatch?: (items: TOut[], total: number) => void,
+): Promise<TOut[]> {
+  const hexCount = Number(res.headers.get("X-Hex-Count") ?? 0);
+  onProgress?.(5, `Downloading ${hexCount ? hexCount.toLocaleString() + " hexes" : "hex data"}…`);
+
+  const reader = res.body?.getReader();
+  if (!reader) throw new Error("Response body is not readable (streaming not supported)");
+
+  const DELIM = '},{"h":';
+  const BATCH_SIZE = 10_000;
+
+  const decoder = new TextDecoder();
+  const items: TOut[] = [];
+  let buffer = "";
+  let lastBatch = 0;
+
+  for (;;) {
+    const { done, value } = await reader.read();
+    if (done) break;
+
+    buffer += decoder.decode(value, { stream: true });
+    buffer = extractObjects(buffer, DELIM, items, mapper);
+
+    if (items.length - lastBatch >= BATCH_SIZE) {
+      lastBatch = items.length;
+      reportProgress(items.length, hexCount, onProgress);
+      onBatch?.(items, hexCount);
+      await new Promise<void>((r) => setTimeout(r, 0));
+    }
+  }
+
+  buffer += decoder.decode();
+  parseFinalObject(buffer, items, mapper);
+
+  return items;
+}
+
+function extractObjects<TRaw, TOut>(
+  buffer: string,
+  delim: string,
+  items: TOut[],
+  mapper?: (raw: TRaw) => TOut,
+): string {
+  let idx: number;
+  while ((idx = buffer.indexOf(delim)) !== -1) {
+    const fragment = buffer.slice(0, idx + 1);
+    buffer = buffer.slice(idx + 2);
+
+    const brace = fragment.indexOf("{");
+    if (brace >= 0) {
+      try {
+        const obj = JSON.parse(fragment.slice(brace)) as TRaw;
+        items.push(mapper ? mapper(obj) : (obj as unknown as TOut));
+      } catch { /* skip malformed */ }
+    }
+  }
+  return buffer;
+}
+
+function parseFinalObject<TRaw, TOut>(
+  buffer: string,
+  items: TOut[],
+  mapper?: (raw: TRaw) => TOut,
+): void {
+  let trimmed = buffer.trim();
+  if (trimmed.endsWith("]")) trimmed = trimmed.slice(0, -1);
+  const brace = trimmed.indexOf("{");
+  if (brace < 0) return;
+  try {
+    const obj = JSON.parse(trimmed.slice(brace)) as TRaw;
+    items.push(mapper ? mapper(obj) : (obj as unknown as TOut));
+  } catch { /* skip */ }
+}
+
+function reportProgress(
+  count: number,
+  total: number,
+  onProgress?: (pct: number, statusText?: string) => void,
+): void {
+  if (!onProgress) return;
+  if (total > 0) {
+    const pct = Math.min(90, Math.round((count / total) * 90));
+    onProgress(pct, `Parsed ${count.toLocaleString()} / ${total.toLocaleString()} hexes…`);
+  } else {
+    onProgress(50, `Parsed ${count.toLocaleString()} hexes…`);
+  }
+}
+
+/** Full South Africa bbox for wolf-server fallback when Go router /hexes/all is unavailable. */
+const SA_BBOX = { west: 16, south: -35, east: 33, north: -22 };
+
+/**
+ * Fetch the full hex collection (Go `/hexes/all` payload).
+ *
+ * **Production:** `GET /pathfinder/hexes/all` (Vercel rewrite → pathfinder.communitywolf.com).
+ * Same-origin request avoids CORS entirely.
+ *
+ * **Local dev:** Direct to Go router via `VITE_SAFETY_ROUTER_URL` or Vite proxy.
+ *
+ * **Fallback:** Mongo viewport API via wolf-server (`getCwUnifiedCrimeHexData`) when pathfinder
+ * returns 401, 404, or 503.
+ */
+export async function getAllCrimeHex(
+  token?: string,
+  onProgress?: (pct: number, statusText?: string) => void,
+  onBatch?: (items: CwUnifiedCrimeHexItem[], total: number) => void,
+): Promise<CwUnifiedCrimeHexItem[]> {
+  onProgress?.(0, "Checking local cache…");
+  const cached = await getHexCache();
+  if (cached?.data?.length) {
+    onProgress?.(50, `Restoring ${cached.data.length.toLocaleString()} hexes from cache…`);
+    onBatch?.(cached.data as CwUnifiedCrimeHexItem[], cached.data.length);
+    await new Promise((r) => setTimeout(r, 0)); // yield to let UI update
+    onProgress?.(100, `Loaded ${cached.data.length.toLocaleString()} hexes (cached)`);
+    return cached.data as CwUnifiedCrimeHexItem[];
+  }
+
+  const routerUrl = getSafetyRouterBaseUrl();
+  const url = `${routerUrl}/hexes/all`;
+  const auth = getSafetyRouterAuth(token);
+  const headers: Record<string, string> = { Accept: "application/json" };
+  if (auth) headers.Authorization = `Bearer ${auth}`;
+
+  onProgress?.(0, "Connecting to safety router…");
+  const res = await fetch(url, { headers, cache: "no-store" });
+
+  if (res.ok) {
+    const items = await streamParseJsonArray<GoHexSlimItem, CwUnifiedCrimeHexItem>(
+      res,
+      onProgress,
+      goSlimToItem,
+      onBatch,
+    );
+    onProgress?.(100, `Loaded ${items.length.toLocaleString()} hexes`);
+    void setHexCache(items);
+    return items;
+  }
+
+  // Fallback to wolf-server when Go router unavailable (404/503) or unauthorized (401)
+  if (res.status === 401 || res.status === 404 || res.status === 503) {
+    onProgress?.(
+      0,
+      res.status === 401 ? "Auth required, trying wolf-server…" : "Safety router unavailable, trying wolf-server…",
+    );
+    try {
+      const fallback = await getCwUnifiedCrimeHexData({ ...SA_BBOX, resolution: 8 }, token);
+      const rawItems = fallback?.data ?? [];
+      const items = rawItems.map((d) => {
+        let lat = d.lat;
+        let lng = d.lng;
+        if (lat == null || lng == null) {
+          try {
+            [lat, lng] = cellToLatLng(d.h3Index);
+          } catch {
+            /* skip invalid h3 */
+          }
+        }
+        return { ...d, lat, lng } as CwUnifiedCrimeHexItem;
+      });
+      onProgress?.(100, `Loaded ${items.length.toLocaleString()} hexes (wolf-server)`);
+      void setHexCache(items);
+      return items;
+    } catch (err) {
+      throw new Error(
+        `Safety router unavailable and wolf-server fallback failed: ${err instanceof Error ? err.message : String(err)}`,
+      );
+    }
+  }
+
+  throw new Error(`Safety router /hexes/all failed: ${res.status}`);
+}
+
+/* ── Hex score/breakdown from Go backend ───────────────────────────── */
+
+/** Request body for POST /hexes/score (toggle-based re-scoring). */
