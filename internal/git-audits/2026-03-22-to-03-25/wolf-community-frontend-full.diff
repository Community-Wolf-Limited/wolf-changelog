+/**
+ * Go safety router (wolf-safety-router) — direct client for /hexes/all etc.
+ * Community app uses API key only (no Clerk).
+ *
+ * **Production (Vercel):** Uses `/pathfinder` same-origin rewrite (vercel.json) to proxy to
+ * `pathfinder.communitywolf.com`. This avoids CORS entirely — the browser sees a same-origin
+ * request and Vercel's edge proxies it to Hetzner.
+ *
+ * **Local dev:** Set `VITE_SAFETY_ROUTER_URL=http://localhost:8090` (or the pathfinder URL)
+ * to hit the Go router directly.
+ */
+
+const VERCEL_PROXY_PATH = "/pathfinder";
+const DIRECT_PATHFINDER_URL = "https://pathfinder.communitywolf.com";
+
+export function getSafetyRouterBaseUrl(): string {
+  if (!import.meta.env.DEV) return VERCEL_PROXY_PATH;
+  const env = (import.meta.env.VITE_SAFETY_ROUTER_URL as string | undefined)?.trim();
+  if (env) return env.replace(/\/+$/, "");
+  return DIRECT_PATHFINDER_URL;
+}
+
+export function getSafetyRouterAuth(_clerkToken?: string | null): string | undefined {
+  return (import.meta.env.VITE_SAFETY_ROUTER_API_KEY as string | undefined) || undefined;
+}
