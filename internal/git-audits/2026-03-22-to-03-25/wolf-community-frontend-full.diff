+          {item.propertyCount > 0 && <span className="text-xs font-mono flex items-center gap-0.5" style={{ color: CAT.property.color }}><Home size={10}/>{item.propertyCount}</span>}
+          {item.drugCount     > 0 && <span className="text-xs font-mono flex items-center gap-0.5" style={{ color: CAT.drug.color }}><Pill size={10}/>{item.drugCount}</span>}
