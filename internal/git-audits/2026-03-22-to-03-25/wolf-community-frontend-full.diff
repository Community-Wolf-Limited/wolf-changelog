@@ -0,0 +1,29 @@
+/**
+ * OSM / POI list for live map.
+ *
+ * Uses `GET /global/poi` — the "global" org ID bypasses org-ownership checks
+ * on wolf-server (organisationOwnershipMiddleware). POI data comes from
+ * Overpass/OpenStreetMap so it's the same regardless of organisation.
+ */
+import { api } from "@/utils/api";
+import type { POIMarker } from "@/types/poi.type";
+
+const POI_ORG_PATH = "global";
+
+export async function fetchOsmPoisForViewport(
+  lat: number,
+  lng: number,
+  radiusKm: number
+): Promise<POIMarker[]> {
+  const res = await api.get<{ pois: POIMarker[]; poiCount?: number }>(`/${POI_ORG_PATH}/poi`, {
+    query: {
+      lat: String(lat),
+      lng: String(lng),
+      radius: String(radiusKm),
+      onlyCoordinates: "true",
+      limit: "500",
+    },
+  });
+  const list = res.pois ?? [];
+  return list.map((p) => ({ ...p, source: "osm" as const }));
+}
