@@ -0,0 +1,118 @@
+/**
+ * Mapbox layer helpers — z-order aligned with enterprise live map.
+ */
+import type mapboxgl from "mapbox-gl";
+
+export const CW_UNIFIED_CRIME_HEX_NATIONAL_SOURCE_ID = "cw-unified-crime-hex-national";
+export const CW_UNIFIED_CRIME_HEX_NATIONAL_LAYER_ID = "cw-unified-crime-hex-national-fill";
+export const CW_UNIFIED_CRIME_HEX_NATIONAL_OUTLINE_LAYER_ID = "cw-unified-crime-hex-national-outline";
+
+const MARKER_ANCHOR_ID = "markers";
+
+export function addNationalCrimeHexSourceAndLayer(map: mapboxgl.Map): void {
+  if (map.getSource(CW_UNIFIED_CRIME_HEX_NATIONAL_SOURCE_ID)) return;
+  map.addSource(CW_UNIFIED_CRIME_HEX_NATIONAL_SOURCE_ID, {
+    type: "geojson",
+    data: { type: "FeatureCollection", features: [] },
+    promoteId: "h3Index",
+  });
+  map.addLayer(
+    {
+      id: CW_UNIFIED_CRIME_HEX_NATIONAL_LAYER_ID,
+      type: "fill",
+      source: CW_UNIFIED_CRIME_HEX_NATIONAL_SOURCE_ID,
+      layout: { visibility: "none" },
+      paint: {
+        "fill-color": ["get", "fillColor"],
+        "fill-opacity": 0.55,
+        "fill-outline-color": "transparent",
+      },
+    },
+    MARKER_ANCHOR_ID
+  );
+  map.addLayer(
+    {
+      id: CW_UNIFIED_CRIME_HEX_NATIONAL_OUTLINE_LAYER_ID,
+      type: "line",
+      source: CW_UNIFIED_CRIME_HEX_NATIONAL_SOURCE_ID,
+      layout: { visibility: "none" },
+      paint: {
+        "line-color": ["case", ["==", ["get", "hasReports"], 1], "#ef4444", "rgba(80,80,80,0.15)"],
+        "line-width": ["case", ["==", ["get", "hasReports"], 1], 2, 0.3],
+      },
+    },
+    CW_UNIFIED_CRIME_HEX_NATIONAL_LAYER_ID
+  );
+}
+
+export function addPoiMarkersSourceAndLayers(map: mapboxgl.Map): void {
+  if (map.getSource("poi-markers")) return;
+  map.addSource("poi-markers", {
+    type: "geojson",
+    data: { type: "FeatureCollection", features: [] },
+  });
+  map.addLayer({
+    id: "poi-markers-osm",
+    type: "symbol",
+    source: "poi-markers",
+    filter: ["==", ["get", "source"], "osm"],
+    layout: {
+      "icon-image": ["coalesce", ["get", "iconId"], ["literal", "map-icon-poi-default-3b82f6"]],
+      "icon-size": [
+        "case",
+        ["==", ["get", "isSelected"], true],
+        1.25,
+        ["case", ["==", ["get", "isLoading"], true], 1.5, 0.6],
+      ],
+      "icon-allow-overlap": true,
+      "icon-ignore-placement": true,
+      "icon-anchor": "bottom",
+    },
+  });
+}
+
+const notTypeFiltered = ["!", ["get", "isTypeFiltered"]] as ["!", unknown[]];
+
+export function addReportHeatmapAndHotspotLayers(map: mapboxgl.Map): void {
+  map.addLayer({
+    id: "report-hotspots",
+    type: "circle",
+    source: "markers",
+    layout: { visibility: "none" },
+    filter: ["all", ["!", ["get", "isFiltered"]], notTypeFiltered],
+    paint: {
+      "circle-radius": ["interpolate", ["linear"], ["zoom"], 8, 80, 12, 200, 16, 400],
+      "circle-opacity": 0.12,
+      "circle-color": "#ef4444",
+    },
+  });
+  map.addLayer({
+    id: "report-heatmap",
+    type: "heatmap",
+    source: "markers",
+    maxzoom: 16,
+    layout: { visibility: "none" },
+    filter: ["all", ["!", ["get", "isFiltered"]], notTypeFiltered],
+    paint: {
+      "heatmap-weight": 1,
+      "heatmap-intensity": ["interpolate", ["linear"], ["zoom"], 0, 1, 12, 2, 16, 1.5],
+      "heatmap-color": [
+        "interpolate",
+        ["linear"],
+        ["heatmap-density"],
+        0,
+        "rgba(0,0,0,0)",
+        0.2,
+        "rgba(239,68,68,0.4)",
+        0.4,
+        "rgba(249,115,22,0.6)",
+        0.6,
+        "rgba(234,179,8,0.7)",
+        1,
+        "rgba(220,38,38,0.85)",
+      ],
+      "heatmap-radius": ["interpolate", ["linear"], ["zoom"], 0, 15, 10, 25, 14, 50],
+      "heatmap-opacity": ["interpolate", ["linear"], ["zoom"], 7, 0.8, 14, 0.5, 18, 0.2],
+    },
+  });
+}
