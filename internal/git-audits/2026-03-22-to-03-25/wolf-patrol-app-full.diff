+export default function RouteEditScreen() {
+  const insets = useSafeAreaInsets();
+  const { id } = useLocalSearchParams<{ id: string }>();
+  useRequirePatrolFieldAccessRedirect();
+
+  const [name, setName] = useState("");
+  const [description, setDescription] = useState("");
+  const [patrolMode, setPatrolMode] = useState<PatrolMode>("rigid");
+  const [loading, setLoading] = useState(true);
+  const [saving, setSaving] = useState(false);
+
+  const load = useCallback(async () => {
+    if (!id) {
+      setLoading(false);
+      return;
+    }
+    const r = await fetchRoute(id);
+    if (r) {
+      setName(r.name);
+      setDescription(r.description ?? "");
+      if (r.patrolMode === "semi_rigid" || r.patrolMode === "random" || r.patrolMode === "rigid") {
+        setPatrolMode(r.patrolMode);
+      }
+    }
+    setLoading(false);
+  }, [id]);
+
+  useFocusEffect(
+    useCallback(() => {
+      setLoading(true);
+      fetchCapabilities().catch(() => {});
+      load().catch(() => {});
+    }, [load])
+  );
+
+  const save = async () => {
+    if (!id || !name.trim()) return;
+    setSaving(true);
+    try {
+      const updated = await updateRoute(id, {
+        name: name.trim(),
+        description: description.trim(),
+        patrolMode,
+      });
+      if (updated) {
+        Haptics.notificationAsync(Haptics.NotificationFeedbackType.Success).catch(() => {});
+        Alert.alert("Saved", "Route updated.", [{ text: "OK", onPress: () => router.back() }]);
+      } else {
+        Alert.alert("Error", "Could not update route.");
+      }
+    } finally {
+      setSaving(false);
+    }
+  };
+
+  if (loading) {
+    return (
+      <View style={[styles.center, { paddingTop: insets.top }]}>
+        <ActivityIndicator size="large" color={BRAND.primary} />
+      </View>
+    );
+  }
+
+  return (
+    <ScreenWrapper style={styles.flex}>
+      <ScrollView contentContainerStyle={[styles.scroll, { paddingTop: insets.top + 16, paddingBottom: 32 }]}>
+        <Text style={styles.title}>Edit route</Text>
+        <Text style={styles.label}>Name</Text>
+        <TextInput
+          style={styles.input}
+          value={name}
+          onChangeText={setName}
+          placeholder="Route name"
+          placeholderTextColor={BRAND.mutedForeground}
+        />
+        <Text style={styles.label}>Description</Text>
+        <TextInput
+          style={[styles.input, styles.inputMultiline]}
+          value={description}
+          onChangeText={setDescription}
+          placeholder="Description"
+          placeholderTextColor={BRAND.mutedForeground}
+          multiline
+        />
+        <Text style={styles.label}>Patrol mode</Text>
+        <View style={styles.row}>
+          {(["rigid", "semi_rigid", "random"] as const).map((m) => (
+            <TouchableOpacity
+              key={m}
+              style={[styles.chip, patrolMode === m && styles.chipActive]}
+              onPress={() => setPatrolMode(m)}
+            >
+              <Text style={[styles.chipText, patrolMode === m && styles.chipTextActive]}>{m.replaceAll("_", " ")}</Text>
+            </TouchableOpacity>
+          ))}
+        </View>
+        <TouchableOpacity style={styles.primary} onPress={() => void save()} disabled={saving}>
+          {saving ? <ActivityIndicator color={BRAND.primaryForeground} /> : <Text style={styles.primaryText}>Save</Text>}
+        </TouchableOpacity>
+        <TouchableOpacity style={styles.secondary} onPress={() => router.back()}>
+          <Text style={styles.secondaryText}>Cancel</Text>
+        </TouchableOpacity>
+      </ScrollView>
+    </ScreenWrapper>
+  );
+}
