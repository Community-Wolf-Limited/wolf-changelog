+      <Text style={styles.title}>Patrol schedules</Text>
+      <Text style={styles.sub}>Read-only from your organisation (requires network). Pull down to refresh.</Text>
+      {loading ? (
+        <ActivityIndicator color={BRAND.primary} style={{ marginTop: 24 }} />
+      ) : (
+        <FlatList
+          data={items}
+          keyExtractor={(item) => item._id}
