+++ b/hooks/useEnforcePatrolFieldAccessTabs.ts
@@ -0,0 +1,27 @@
+import { useEffect } from "react";
+import { router, useSegments } from "expo-router";
+import { usePatrolFieldAccessUnlocked } from "@/hooks/usePatrolFieldAccessUnlocked";
+
+/**
+ * Tab route names that must redirect to Access when field access is not unlocked.
+ * Excludes `index` so the home tab can still show LockedHomeView (scope copy + CTA).
+ */
+const PROTECTED_TAB_NAMES = new Set(["routes", "sites", "schedules"]);
+
+/**
+ * Central guard for the (tabs) group: if the user lands on Home/Routes/Sites/Schedules
+ * without unlocked field access (hidden tab bar, swipe, deep link, race), force Access.
+ * Complements per-screen redirects and API-side 403s.
+ */
+export function useEnforcePatrolFieldAccessTabs(): void {
+  const unlocked = usePatrolFieldAccessUnlocked();
+  const segments = useSegments();
+
+  useEffect(() => {
+    if (unlocked) return;
+    const tabName = segments[1];
+    if (tabName != null && PROTECTED_TAB_NAMES.has(String(tabName))) {
+      router.replace("/(tabs)/access" as never);
+    }
+  }, [unlocked, segments]);
+}
