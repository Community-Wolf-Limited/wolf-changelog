@@ -0,0 +1,60 @@
+import { create } from "zustand";
+
+export interface GrantCapabilitiesPayload {
+  grantVersion: number | null;
+  patrolGrantRequired: boolean;
+  grantScope: string | null;
+  needsDeviceAcknowledgment: boolean;
+  grantStatus: string | null;
+  grantId: string | null;
+  expiresAt: string | null;
+  trackingMode: "always" | "patrol_only" | null;
+}
+
+interface GrantVersionState {
+  grantVersion: number | null;
+  patrolGrantRequired: boolean;
+  grantScope: string | null;
+  needsDeviceAcknowledgment: boolean;
+  /** Server grant status when active grant exists (e.g. active) */
+  grantStatus: string | null;
+  grantId: string | null;
+  expiresAt: string | null;
+  /** Idle GPS policy from control room; null until first capabilities fetch. */
+  trackingMode: "always" | "patrol_only" | null;
+  setFromCapabilities: (payload: GrantCapabilitiesPayload) => void;
+  /** Clear grant fields immediately (e.g. push: revoked/denied) before server round-trip. */
+  revokeFieldAccessLocal: () => void;
+}
+
+export const useGrantVersionStore = create<GrantVersionState>((set) => ({
+  grantVersion: null,
+  patrolGrantRequired: true,
+  grantScope: null,
+  needsDeviceAcknowledgment: false,
+  grantStatus: null,
+  grantId: null,
+  expiresAt: null,
+  trackingMode: null,
+  setFromCapabilities: (payload) =>
+    set({
+      grantVersion: payload.grantVersion,
+      patrolGrantRequired: payload.patrolGrantRequired,
+      grantScope: payload.grantScope,
+      needsDeviceAcknowledgment: payload.needsDeviceAcknowledgment,
+      grantStatus: payload.grantStatus,
+      grantId: payload.grantId,
+      expiresAt: payload.expiresAt,
+      trackingMode: payload.trackingMode,
+    }),
+  revokeFieldAccessLocal: () =>
+    set({
+      grantVersion: null,
+      grantScope: null,
+      needsDeviceAcknowledgment: false,
+      grantStatus: null,
+      grantId: null,
+      expiresAt: null,
+      trackingMode: null,
+    }),
+}));
