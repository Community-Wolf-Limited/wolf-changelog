new file mode 100644
index 0000000..15e0c21
--- /dev/null
+++ b/services/push/register-push.ts
@@ -0,0 +1,89 @@
+import * as Notifications from "expo-notifications";
+import * as Device from "expo-device";
+import Constants from "expo-constants";
+import { getApiClient } from "@/services/api/client";
+import { useGrantVersionStore } from "@/store/grant-version-store";
+import { fetchCapabilities } from "@/services/api/capabilities-api";
+
+Notifications.setNotificationHandler({
+  handleNotification: async () => ({
+    shouldPlaySound: true,
+    shouldSetBadge: false,
+    shouldShowBanner: true,
+    shouldShowList: true,
+  }),
+});
+
+/**
+ * Registers for push notifications and POSTs the Expo token to the server.
+ * Safe to call multiple times; updates token if it changed.
+ */
+export async function registerAndUploadExpoPushToken(): Promise<void> {
+  if (!Device.isDevice) {
+    return;
+  }
+  try {
+    const { status: existing } = await Notifications.getPermissionsAsync();
+    let finalStatus = existing;
+    if (existing !== "granted") {
+      const { status } = await Notifications.requestPermissionsAsync();
+      finalStatus = status;
+    }
+    if (finalStatus !== "granted") {
+      return;
+    }
+
+    const projectId =
+      (Constants.expoConfig?.extra?.eas?.projectId as string | undefined) ??
+      (Constants.easConfig?.projectId as string | undefined);
+    const tokenRes = await Notifications.getExpoPushTokenAsync(
+      projectId ? { projectId } : undefined
+    );
+    const expoPushToken = tokenRes.data;
+    if (!expoPushToken) return;
+
+    const client = getApiClient();
+    await client.post("/device-auth/push-token", { expoPushToken });
+  } catch {
+    // Non-fatal: push is optional
+  }
+}
+
+export type NotificationSubscription = { remove: () => void };
+
+const GRANT_REVOKE_TYPES = new Set([
+  "patrol_grant_revoked",
+  "patrol_grant_denied",
+  "patrol_grant_expired",
+]);
+
+/** Subscribe to notification taps for grant-related pushes (navigates to Access). */
+export function addNotificationResponseListener(onNavigateToAccess: () => void): NotificationSubscription {
+  const sub = Notifications.addNotificationResponseReceivedListener((response) => {
+    const data = response.notification.request.content.data as { type?: string };
+    const t = data?.type;
+    if (
+      t === "patrol_grant_approved" ||
+      t === "patrol_grant_denied" ||
+      t === "patrol_grant_revoked"
+    ) {
+      if (t && GRANT_REVOKE_TYPES.has(t)) {
+        useGrantVersionStore.getState().revokeFieldAccessLocal();
+        fetchCapabilities().catch(() => {
+          /* non-fatal */
+        });
+      }
+      onNavigateToAccess();
+    }
+  });
+  return { remove: () => sub.remove() };
+}
+
+export function addForegroundNotificationListener(
+  onNotification: (notification: Notifications.Notification) => void
+): NotificationSubscription {
+  const sub = Notifications.addNotificationReceivedListener((notification) => {
+    onNotification(notification);
+  });
+  return { remove: () => sub.remove() };
+}
