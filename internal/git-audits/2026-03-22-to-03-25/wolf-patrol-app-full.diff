+export default function RouteDetailScreen() {
+  const insets = useSafeAreaInsets();
+  const { id } = useLocalSearchParams<{ id: string }>();
+  const staff = useAuthStore((s) => s.staff);
+  const canWrite = useCanWritePatrolConfig();
+  useRequirePatrolFieldAccessRedirect();
+  const grantScope = useGrantVersionStore((s) => s.grantScope);
+
+  const [route, setRoute] = useState<PatrolRoute | null>(null);
+  const [patrols, setPatrols] = useState<Patrol[]>([]);
+  const [loading, setLoading] = useState(true);
+  const [refreshing, setRefreshing] = useState(false);
+
+  const load = useCallback(async () => {
+    if (!id) {
+      setLoading(false);
+      return;
+    }
+    const r = await fetchRoute(id);
+    setRoute(r);
+    const listOrg = useGrantVersionStore.getState().grantScope === "org_wide";
+    const all = await fetchPatrols(!listOrg);
+    const sameRoute = all.filter((p) => {
+      const rid = p.routeId;
+      if (rid && typeof rid === "object" && "_id" in rid) {
+        return String((rid as { _id: string })._id) === id;
+      }
+      return false;
+    });
+    setPatrols(sameRoute);
+    setLoading(false);
+  }, [id]);
+
+  useFocusEffect(
+    useCallback(() => {
+      setLoading(true);
+      fetchCapabilities().catch(() => {});
+      load().catch(() => {});
+    }, [load])
+  );
+
+  const onRefresh = async () => {
+    setRefreshing(true);
+    await fetchCapabilities();
+    await load();
+    setRefreshing(false);
+  };
+
+  if (loading && !route) {
+    return (
+      <View style={[styles.center, { paddingTop: insets.top }]}>
+        <ActivityIndicator size="large" color={BRAND.primary} />
+      </View>
+    );
+  }
+
+  if (!route) {
+    return (
+      <ScreenWrapper style={[styles.pad, { paddingTop: insets.top + 24 }]}>
+        <Text style={styles.title}>Route not found</Text>
+        <TouchableOpacity style={styles.secondaryButton} onPress={() => router.back()}>
+          <Text style={styles.secondaryButtonText}>Back</Text>
+        </TouchableOpacity>
+      </ScreenWrapper>
+    );
+  }
+
+  const checkpoints = route.checkpoints ?? [];
+  const coordinates = checkpoints
+    .map((c) => c.location)
+    .filter((l) => l?.latitude != null && l?.longitude != null)
+    .map((l) => ({ latitude: l.latitude, longitude: l.longitude }));
+
+  let mapRegion = WIDE_REGION;
+  if (coordinates.length > 0) {
+    mapRegion = getRegionForPosition(coordinates[0].latitude, coordinates[0].longitude, 120);
+  }
+
+  const isCreator = Boolean(route.createdByStaffId && staff?.id && route.createdByStaffId === staff.id);
+
+  const confirmDelete = () => {
+    if (!id) return;
+    Alert.alert("Delete route?", "This soft-deletes the patrol route.", [
+      { text: "Cancel", style: "cancel" },
+      {
+        text: "Delete",
+        style: "destructive",
+        onPress: () => {
+          void (async () => {
+            const ok = await deleteRoute(id);
+            if (ok) {
+              void Haptics.notificationAsync(Haptics.NotificationFeedbackType.Success);
+              router.back();
+            } else {
+              Alert.alert("Error", "Could not delete route.");
+            }
+          })();
+        },
+      },
+    ]);
+  };
+
+  return (
+    <ScreenWrapper style={styles.flex}>
+      <ScrollView
+        contentContainerStyle={[styles.scroll, { paddingTop: insets.top + 16, paddingBottom: 32 }]}
+        refreshControl={
+          <RefreshControl refreshing={refreshing} onRefresh={() => void onRefresh()} tintColor={BRAND.primary} />
+        }
+      >
+        <Text style={styles.title}>{route.name}</Text>
+        {route.description ? <Text style={styles.sub}>{route.description}</Text> : null}
+        {route.patrolMode ? (
+          <Text style={styles.meta}>Mode: {route.patrolMode}</Text>
+        ) : null}
+
+        <View style={styles.mapWrap}>
+          <MapView style={styles.map} region={mapRegion} scrollEnabled zoomEnabled pitchEnabled={false} rotateEnabled={false}>
+            {coordinates.length > 1 && (
+              <Polyline coordinates={coordinates} strokeColor={BRAND.primary} strokeWidth={4} />
+            )}
+            {checkpoints.map((cp) =>
+              cp.location?.latitude != null && cp.location?.longitude != null ? (
+                <Marker
+                  key={cp.number}
+                  coordinate={{ latitude: cp.location.latitude, longitude: cp.location.longitude }}
+                  title={cp.name || `Checkpoint ${cp.number}`}
+                />
+              ) : null
+            )}
+          </MapView>
+        </View>
+
+        <Text style={styles.section}>Checkpoints</Text>
+        {checkpoints.length === 0 ? (
+          <Text style={styles.muted}>No checkpoints.</Text>
+        ) : (
+          checkpoints.map((cp) => (
+            <View key={cp.number} style={styles.card}>
+              <Text style={styles.cardTitle}>
+                {cp.number}. {cp.name || "Checkpoint"}
+              </Text>
+              {cp.location ? (
+                <Text style={styles.cardMeta}>
+                  {cp.location.latitude.toFixed(5)}, {cp.location.longitude.toFixed(5)}
+                </Text>
+              ) : null}
+            </View>
+          ))
+        )}
+
+        <Text style={styles.section}>Patrol assignments using this route</Text>
+        {patrols.length === 0 ? (
+          <Text style={styles.muted}>
+            {grantScope === "org_wide"
+              ? "No patrols linked to this route (or none visible)."
+              : "No patrols assigned to you on this route."}
+          </Text>
+        ) : (
+          patrols.map((p) => (
+            <TouchableOpacity key={p._id} style={styles.card} onPress={() => router.push(`/patrol/${p._id}` as never)}>
+              <Text style={styles.cardTitle}>{p.name}</Text>
+              <Text style={styles.cardMeta}>{p.status}</Text>
+            </TouchableOpacity>
+          ))
+        )}
+
+        {isCreator && canWrite ? (
+          <View style={styles.ownerRow}>
+            <TouchableOpacity style={styles.outlineButton} onPress={() => router.push(`/route/edit/${id}` as never)}>
+              <Text style={styles.outlineButtonText}>Edit route</Text>
+            </TouchableOpacity>
+            <TouchableOpacity style={styles.dangerButton} onPress={confirmDelete}>
+              <Text style={styles.dangerButtonText}>Delete route</Text>
+            </TouchableOpacity>
+          </View>
+        ) : null}
+
+        <TouchableOpacity style={styles.secondaryButton} onPress={() => router.back()}>
+          <Text style={styles.secondaryButtonText}>Back</Text>
+        </TouchableOpacity>
+      </ScrollView>
+    </ScreenWrapper>
+  );
+}
+
+const styles = StyleSheet.create({
+  flex: { flex: 1 },
+  pad: { flex: 1, padding: 24 },
+  scroll: { paddingHorizontal: 24 },
+  center: { flex: 1, justifyContent: "center", alignItems: "center" },
+  title: { fontSize: 24, fontWeight: "bold", color: BRAND.foreground },
+  sub: { fontSize: 15, color: BRAND.mutedForeground, marginTop: 8 },
+  meta: { fontSize: 13, color: BRAND.mutedForeground, marginTop: 6 },
+  mapWrap: {
+    height: 240,
+    borderRadius: 12,
+    overflow: "hidden",
+    borderWidth: 1,
+    borderColor: BRAND.border,
+    marginTop: 16,
+    marginBottom: 16,
+  },
+  map: { flex: 1 },
+  section: { fontSize: 18, fontWeight: "600", color: BRAND.foreground, marginTop: 8, marginBottom: 10 },
+  muted: { fontSize: 14, color: BRAND.mutedForeground, marginBottom: 12 },
+  card: {
+    padding: 14,
+    backgroundColor: BRAND.muted,
+    borderRadius: 12,
+    borderWidth: 1,
+    borderColor: BRAND.border,
+    marginBottom: 10,
+  },
+  cardTitle: { fontSize: 16, fontWeight: "600", color: BRAND.foreground },
+  cardMeta: { fontSize: 13, color: BRAND.mutedForeground, marginTop: 4 },
+  secondaryButton: {
+    marginTop: 20,
+    padding: 16,
+    backgroundColor: BRAND.muted,
+    borderRadius: 12,
+    alignItems: "center",
+  },
+  secondaryButtonText: { color: BRAND.foreground, fontSize: 16, fontWeight: "600" },
+  ownerRow: { flexDirection: "row", gap: 12, marginTop: 8, marginBottom: 8, flexWrap: "wrap" },
+  outlineButton: {
+    flex: 1,
+    minWidth: 120,
+    padding: 14,
+    borderRadius: 12,
+    borderWidth: 1,
+    borderColor: BRAND.border,
+    alignItems: "center",
+    backgroundColor: BRAND.muted,
+  },
+  outlineButtonText: { fontSize: 15, fontWeight: "600", color: BRAND.foreground },
+  dangerButton: {
+    flex: 1,
+    minWidth: 120,
+    padding: 14,
+    borderRadius: 12,
+    alignItems: "center",
+    backgroundColor: "#fef2f2",
