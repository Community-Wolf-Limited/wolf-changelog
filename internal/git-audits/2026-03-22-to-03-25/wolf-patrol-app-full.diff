new file mode 100644
index 0000000..77f81d4
--- /dev/null
+++ b/hooks/usePatrolFieldAccessUnlocked.ts
@@ -0,0 +1,15 @@
+import { useGrantVersionStore } from "@/store/grant-version-store";
+
+/**
+ * True when the user may use Home, Routes, Sites (not locked to Access-only).
+ * Matches `useCanWritePatrolConfig` semantics: grant not required, or active grant fully acknowledged.
+ */
+export function usePatrolFieldAccessUnlocked(): boolean {
+  const patrolGrantRequired = useGrantVersionStore((s) => s.patrolGrantRequired);
+  const grantVersion = useGrantVersionStore((s) => s.grantVersion);
+  const needsAck = useGrantVersionStore((s) => s.needsDeviceAcknowledgment);
+  if (!patrolGrantRequired) return true;
+  if (grantVersion == null) return false;
+  if (needsAck) return false;
+  return true;
+}
diff --git a/hooks/useRequirePatrolFieldAccessRedirect.ts b/hooks/useRequirePatrolFieldAccessRedirect.ts
new file mode 100644
index 0000000..fe847cd
--- /dev/null
+++ b/hooks/useRequirePatrolFieldAccessRedirect.ts
@@ -0,0 +1,17 @@
+import { useCallback } from "react";
+import { router } from "expo-router";
+import { useFocusEffect } from "@react-navigation/native";
+import { usePatrolFieldAccessUnlocked } from "@/hooks/usePatrolFieldAccessUnlocked";
+
+/** Redirects to Access tab when patrol field access is not unlocked (deep links / stack screens). */
+export function useRequirePatrolFieldAccessRedirect(): void {
+  const unlocked = usePatrolFieldAccessUnlocked();
+
+  useFocusEffect(
+    useCallback(() => {
+      if (!unlocked) {
+        router.replace("/(tabs)/access" as never);
+      }
+    }, [unlocked])
+  );
+}
