diff --git a/app/(tabs)/access.tsx b/app/(tabs)/access.tsx
new file mode 100644
index 0000000..bc1e7e2
--- /dev/null
+++ b/app/(tabs)/access.tsx
@@ -0,0 +1,553 @@
+import { useCallback, useEffect, useMemo, useState } from "react";
+import {
+  StyleSheet,
+  Text,
+  View,
+  TextInput,
+  TouchableOpacity,
+  ActivityIndicator,
+  Alert,
+  ScrollView,
+  RefreshControl,
+} from "react-native";
+import { Ionicons } from "@expo/vector-icons";
+import { useSafeAreaInsets } from "react-native-safe-area-context";
+import { useFocusEffect } from "@react-navigation/native";
+import { ScreenWrapper } from "@/components/ScreenWrapper";
+import { getApiClient } from "@/services/api/client";
+import { fetchCapabilities } from "@/services/api/capabilities-api";
+import { useGrantVersionStore } from "@/store/grant-version-store";
+import { BRAND } from "@/constants/brand";
+
+interface ProposalRow {
+  _id: string;
+  entity: string;
+  action: string;
+  status: string;
+  requestedAt?: string;
+}
+
+interface PermissionGrantRow {
+  _id: string;
+  status: string;
+  scope?: string;
+  requestedAt?: string;
+  updatedAt?: string;
+}
+
+function grantBadgeLabel(params: {
+  readonly grantVersion: number | null;
+  readonly grantStatus: string | null;
+  readonly grantScope: string | null;
+  readonly needsAck: boolean;
+  readonly pendingRequest: boolean;
+}): { badge: string; detail: string } {
+  const { grantVersion, grantStatus, grantScope, needsAck, pendingRequest } = params;
+  if (needsAck && grantStatus === "active") {
+    return { badge: "Approved — tap Accept", detail: "Control room approved; you must accept on this device." };
+  }
+  if (grantStatus === "active" && grantVersion != null) {
+    return {
+      badge: "Active",
+      detail: `Version ${String(grantVersion)} · ${grantScope?.replaceAll("_", " ") ?? "—"}`,
+    };
+  }
+  if (pendingRequest) {
+    return { badge: "Request pending", detail: "Waiting for control room review." };
+  }
+  if (grantStatus === "pending") {
+    return { badge: "Pending approval", detail: "Your access request is with the control room." };
+  }
+  return { badge: "No active grant", detail: "Request access below or pull to refresh." };
+}
+
+export default function FieldAccessScreen() {
+  const insets = useSafeAreaInsets();
+  const grantVersion = useGrantVersionStore((s) => s.grantVersion);
+  const patrolGrantRequired = useGrantVersionStore((s) => s.patrolGrantRequired);
+  const needsDeviceAcknowledgment = useGrantVersionStore((s) => s.needsDeviceAcknowledgment);
+  const grantScope = useGrantVersionStore((s) => s.grantScope);
+  const grantStatus = useGrantVersionStore((s) => s.grantStatus);
+  const grantId = useGrantVersionStore((s) => s.grantId);
+  const expiresAt = useGrantVersionStore((s) => s.expiresAt);
+  const [scope, setScope] = useState<"own_device_created" | "org_wide">("own_device_created");
+  const [reason, setReason] = useState("");
+  const [loading, setLoading] = useState(false);
+  const [proposals, setProposals] = useState<ProposalRow[]>([]);
+  const [proposalsLoading, setProposalsLoading] = useState(true);
+  const [permissionGrants, setPermissionGrants] = useState<PermissionGrantRow[]>([]);
+  const [refreshing, setRefreshing] = useState(false);
+
+  const loadProposals = async () => {
+    setProposalsLoading(true);
+    try {
+      const client = getApiClient();
+      const res = await client.get<{ success: boolean; data: ProposalRow[] }>("/device-auth/patrol-proposals");
+      setProposals(Array.isArray(res.data?.data) ? res.data.data : []);
+    } catch {
+      setProposals([]);
+    } finally {
+      setProposalsLoading(false);
+    }
+  };
+
+  const loadPermissionGrants = async () => {
+    try {
+      const client = getApiClient();
+      const res = await client.get<{ success: boolean; data: PermissionGrantRow[] }>("/device-auth/permission-requests");
+      setPermissionGrants(Array.isArray(res.data?.data) ? res.data.data : []);
+    } catch {
+      setPermissionGrants([]);
+    }
+  };
+
+  const refreshAll = useCallback(async () => {
+    setRefreshing(true);
+    try {
+      await fetchCapabilities();
+      await loadProposals();
+      await loadPermissionGrants();
+    } finally {
+      setRefreshing(false);
+    }
+  }, []);
+
+  useFocusEffect(
+    useCallback(() => {
+      void fetchCapabilities();
+      void loadProposals();
+      void loadPermissionGrants();
+    }, [])
+  );
+
+  const acknowledgeGrant = async () => {
+    setLoading(true);
+    try {
+      const client = getApiClient();
+      await client.post("/device-auth/grants/acknowledge");
+      await fetchCapabilities();
+      await loadPermissionGrants();
+      Alert.alert("Accepted", "Field access is active on this device.");
+    } catch (e: unknown) {
+      const msg = e && typeof e === "object" && "message" in e ? String((e as { message: unknown }).message) : "Failed";
+      Alert.alert("Error", msg);
+    } finally {
+      setLoading(false);
+    }
+  };
+
+  const submitRequest = async () => {
+    setLoading(true);
+    try {
+      const client = getApiClient();
+      await client.post("/device-auth/permission-requests", {
+        requestedScope: scope,
+        reason: reason.trim() || undefined,
+      });
+      Alert.alert("Request sent", "Your control room will review access for this device.");
+      setReason("");
+      await fetchCapabilities();
+      await loadProposals();
+      await loadPermissionGrants();
+    } catch (e: unknown) {
+      const msg = e && typeof e === "object" && "message" in e ? String((e as { message: unknown }).message) : "Failed";
+      Alert.alert("Error", msg);
+    } finally {
+      setLoading(false);
+    }
+  };
+
+  const pendingProposals = proposals.filter((p) => p.status === "pending");
+  const hasPendingPermissionRequest = permissionGrants.some((g) => g.status === "pending");
+
+  const { badge, detail } = grantBadgeLabel({
+    grantVersion,
+    grantStatus,
+    grantScope,
+    needsAck: needsDeviceAcknowledgment,
+    pendingRequest: hasPendingPermissionRequest && grantStatus !== "active",
+  });
+
+  const grantVersionLabel =
+    grantVersion === null || grantVersion === undefined ? "—" : String(grantVersion);
+
+  const proposalQueueSection = () => {
+    if (proposalsLoading) {
+      return <ActivityIndicator color={BRAND.primary} style={{ marginTop: 12 }} />;
+    }
+    if (pendingProposals.length === 0) {
+      return <Text style={styles.proposalsEmpty}>No pending proposals.</Text>;
+    }
+    return (
+      <View style={styles.proposalsList}>
+        {pendingProposals.map((p) => (
+          <View key={p._id} style={styles.proposalRow}>
+            <Text style={styles.proposalMain}>
+              {p.action} {p.entity}
+            </Text>
+            <Text style={styles.proposalMeta}>
+              {p.requestedAt ? new Date(p.requestedAt).toLocaleString() : p._id}
+            </Text>
+          </View>
+        ))}
+      </View>
+    );
+  };
+
+  const [expiryTick, setExpiryTick] = useState(0);
+  useEffect(() => {
+    if (expiresAt == null || expiresAt === "") return;
+    const t = setInterval(() => {
+      setExpiryTick((x) => x + 1);
+    }, 30000);
+    return () => clearInterval(t);
+  }, [expiresAt]);
+
+  const expiryDisplay = useMemo(() => {
+    if (expiresAt == null || expiresAt === "") return { text: "No expiry set", urgent: false };
+    const end = new Date(expiresAt).getTime();
+    const ms = end - Date.now();
+    if (ms <= 0) return { text: "Access expired — request again from control room", urgent: true };
+    const h = Math.floor(ms / 3600000);
+    const m = Math.floor((ms % 3600000) / 60000);
+    return {
+      text: `Expires in ${h}h ${m}m · ${new Date(expiresAt).toLocaleString()}`,
+      urgent: ms < 3600000,
+    };
+  }, [expiresAt, expiryTick]); // expiryTick forces recompute every 30s while expiry is shown
+
+  const lostAccessBanner = useMemo(() => {
+    if (!patrolGrantRequired) return null;
+    if (grantStatus === "revoked") {
+      return "Your field access was revoked by the control room. Request access again if you still need it.";
+    }
+    if (grantStatus === "denied") {
+      return "Your access request was denied. Contact your control room if you need help.";
+    }
+    if (grantStatus === "expired") {
+      return "Your field access grant has expired. Request access again from the control room.";
+    }
+    if (expiresAt != null && expiresAt !== "" && new Date(expiresAt).getTime() <= Date.now()) {
+      return "Your field access has expired — contact your control room to request a new grant.";
+    }
+    return null;
+  }, [patrolGrantRequired, grantStatus, expiresAt, expiryTick]);
+
+  const showOnboardingHero =
+    patrolGrantRequired &&
+    !needsDeviceAcknowledgment &&
+    grantVersion == null &&
+    grantStatus !== "active" &&
+    !hasPendingPermissionRequest;
+
+  const showWaitingHero = hasPendingPermissionRequest && grantStatus !== "active";
+
+  return (
+    <ScreenWrapper style={[styles.container, { paddingTop: insets.top + 16 }]}>
+      <ScrollView
+        contentContainerStyle={styles.scroll}
+        keyboardShouldPersistTaps="handled"
+        refreshControl={<RefreshControl refreshing={refreshing} onRefresh={() => void refreshAll()} tintColor={BRAND.primary} />}
+      >
+        <Text style={styles.title}>Field access</Text>
+
+        {lostAccessBanner ? (
+          <View style={styles.lostAccessBanner}>
+            <Ionicons name="warning" size={22} color="#991b1b" style={{ marginRight: 10 }} />
+            <Text style={styles.lostAccessBannerText}>{lostAccessBanner}</Text>
+          </View>
+        ) : null}
+
+        <Text style={styles.sub}>
+          {patrolGrantRequired
+            ? "Sites and routes you add from this app are saved directly once you have an approved grant (they are not held in a separate proposal queue). Request access below if you do not have one yet."
+            : "Grant checks are relaxed in this environment."}
+        </Text>
+
+        <Text style={styles.hintMuted}>
+          Pull down to refresh. This tab also refreshes when you open it. You may receive a push when access changes (if
+          enabled). Your organisation’s Activity log in Enterprise shows configuration changes.
+        </Text>
+
+        {showOnboardingHero && (
+          <View style={styles.heroCard}>
+            <Ionicons name="key-outline" size={40} color={BRAND.primary} />
+            <Text style={styles.heroTitle}>Get started with field access</Text>
+            <Text style={styles.heroBody}>
+              Choose your scope below and request access. When the control room approves, return here to accept on this
+              device — then Routes and Sites unlock.
+            </Text>
+          </View>
+        )}
+
+        {showWaitingHero && (
+          <View style={styles.waitingCard}>
+            <Text style={styles.waitingTitle}>Waiting for control room</Text>
+            <Text style={styles.waitingBody}>
+              Your request is in review. Pull down to refresh or wait for a notification.
+            </Text>
+          </View>
+        )}
+
+        {needsDeviceAcknowledgment && (
+          <View style={styles.ackBanner}>
+            <Text style={styles.ackTitle}>Control room approved your access</Text>
+            <Text style={styles.ackSub}>Accept on this device to use patrol field actions (sites/routes).</Text>
+            <TouchableOpacity style={styles.ackButton} onPress={() => void acknowledgeGrant()} disabled={loading}>
+              {loading ? (
+                <ActivityIndicator color={BRAND.primaryForeground} />
+              ) : (
+                <Text style={styles.ackButtonText}>Accept field access</Text>
+              )}
+            </TouchableOpacity>
+          </View>
+        )}
+
+        <View style={styles.statusBox}>
+          <View style={styles.statusHeaderRow}>
+            <Text style={styles.statusLabel}>Field access status</Text>
+            <View style={styles.badgeWrap}>
+              <Text style={styles.badgeText}>{badge}</Text>
+            </View>
+          </View>
+          <Text style={styles.statusDetail}>{detail}</Text>
+          <View style={styles.statusGrid}>
+            <Text style={styles.statusGridLabel}>Grant version</Text>
+            <Text style={styles.statusGridValue}>{grantVersionLabel}</Text>
+            <Text style={styles.statusGridLabel}>Scope</Text>
+            <Text style={styles.statusGridValue}>{grantScope ? grantScope.replaceAll("_", " ") : "—"}</Text>
+            <Text style={styles.statusGridLabel}>API status</Text>
+            <Text style={styles.statusGridValue}>{grantStatus ?? "—"}</Text>
+            <Text style={styles.statusGridLabel}>Expiry</Text>
+            <Text style={[styles.statusGridValue, expiryDisplay.urgent && styles.statusGridValueUrgent]}>
+              {expiryDisplay.text}
+            </Text>
+            {grantId ? (
+              <>
+                <Text style={styles.statusGridLabel}>Grant ID</Text>
+                <Text style={styles.statusGridValueSmall} numberOfLines={1} ellipsizeMode="middle">
+                  {grantId}
+                </Text>
+              </>
+            ) : null}
+          </View>
+        </View>
+
+        <Text style={styles.label}>Requested scope</Text>
+        <View style={styles.row}>
+          {(["own_device_created", "org_wide"] as const).map((s) => (
+            <TouchableOpacity
+              key={s}
+              style={[styles.chip, scope === s && styles.chipActive]}
+              onPress={() => setScope(s)}
+            >
+              <Text style={[styles.chipText, scope === s && styles.chipTextActive]}>{s.replaceAll("_", " ")}</Text>
+            </TouchableOpacity>
+          ))}
+        </View>
+        <View style={styles.scopeExplainBox}>
+          <Text style={styles.scopeExplainTitle}>Own device</Text>
+          <Text style={styles.scopeExplainBody}>
+            {`After approval, create and edit sites, routes, and schedules that originate from this device. Other guards' data may stay read-only unless the control room gives org-wide access.`}
+          </Text>
+          <Text style={[styles.scopeExplainTitle, { marginTop: 12 }]}>Organisation-wide</Text>
+          <Text style={styles.scopeExplainBody}>
+            Broader access to patrol configuration across the organisation (subject to control room policy).
+          </Text>
+        </View>
+
+        {grantStatus === "active" && grantVersion != null && !needsDeviceAcknowledgment ? (
+          <View style={styles.yourAccessCard}>
+            <Text style={styles.yourAccessTitle}>Your access</Text>
+            <Text style={styles.yourAccessBody}>
+              You have an active grant (v{String(grantVersion)}) with scope{" "}
+              <Text style={{ fontWeight: "700" }}>{grantScope?.replaceAll("_", " ") ?? "—"}</Text>. You can use Home,
+              Routes, and Sites per that scope. Revocation or expiry returns you to this tab.
+            </Text>
+          </View>
+        ) : null}
+
+        <Text style={styles.label}>Reason (optional)</Text>
+        <TextInput
+          style={styles.input}
+          placeholder="Why do you need this access?"
+          placeholderTextColor={BRAND.mutedForeground}
+          value={reason}
+          onChangeText={setReason}
+          multiline
+        />
+
+        <TouchableOpacity style={styles.button} onPress={() => void submitRequest()} disabled={loading}>
+          {loading ? (
+            <ActivityIndicator color={BRAND.primaryForeground} />
+          ) : (
+            <Text style={styles.buttonText}>Request access</Text>
+          )}
+        </TouchableOpacity>
+
+        <Text style={styles.proposalsTitle}>Optional proposal queue</Text>
+        <Text style={styles.sub}>
+          Only appears if your device submitted changes via the proposal API. Normal site and route creation does not use
+          this list — it goes live after grant + Accept, and is visible in Enterprise under patrol field activity.
+        </Text>
+        {proposalQueueSection()}
+      </ScrollView>
+    </ScreenWrapper>
+  );
+}
+
+const styles = StyleSheet.create({
+  container: { flex: 1, paddingHorizontal: 24 },
+  scroll: { paddingBottom: 32 },
+  lostAccessBanner: {
+    flexDirection: "row",
+    alignItems: "flex-start",
+    padding: 14,
+    borderRadius: 12,
+    backgroundColor: "#fef2f2",
+    borderWidth: 1,
+    borderColor: "#fecaca",
+    marginBottom: 16,
