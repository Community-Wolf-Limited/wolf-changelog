+import AsyncStorage from "@react-native-async-storage/async-storage";
+import { submitHeartbeat } from "@/services/api/patrol-event-api";
+import { getCurrentPosition } from "@/services/gps/NativeGPSService";
+import { ACTIVE_EVENT_KEY } from "@/services/gps/BackgroundLocationTask";
+
+/**
+ * Foreground tick: idle GPS when field access is unlocked and tracking is not patrol-only.
+ * Skips when a patrol is active (background task + execute screen handle that path).
+ */
+export async function runIdleLocationHeartbeatTick(options: {
+  unlocked: boolean;
+  patrolGrantRequired: boolean;
+  trackingMode: "always" | "patrol_only" | null;
+}): Promise<void> {
+  if (!options.unlocked) return;
+  if (options.patrolGrantRequired && options.trackingMode === "patrol_only") return;
+  const active = await AsyncStorage.getItem(ACTIVE_EVENT_KEY);
+  if (active) return;
+  const pos = await getCurrentPosition({ maxRetries: 1 });
+  if (!pos) return;
+  await submitHeartbeat({
+    latitude: pos.latitude,
+    longitude: pos.longitude,
+    accuracy: pos.accuracy ?? undefined,
+  });
+}
