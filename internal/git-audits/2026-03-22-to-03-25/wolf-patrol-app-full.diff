--- /dev/null
+++ b/hooks/useCanWritePatrolConfig.ts
@@ -0,0 +1,12 @@
+import { useGrantVersionStore } from "@/store/grant-version-store";
+
+/** True when the user may create sites/routes (grant not required, or active grant fully acknowledged). */
+export function useCanWritePatrolConfig(): boolean {
+  const patrolGrantRequired = useGrantVersionStore((s) => s.patrolGrantRequired);
+  const grantVersion = useGrantVersionStore((s) => s.grantVersion);
+  const needsAck = useGrantVersionStore((s) => s.needsDeviceAcknowledgment);
+  if (!patrolGrantRequired) return true;
+  if (grantVersion == null) return false;
+  if (needsAck) return false;
+  return true;
+}
