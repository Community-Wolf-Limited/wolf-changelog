+        </View>
+      )}
+
+      {hasActive && stats?.activePatrolEvent ? (
+        <ActivePatrolCard routeName={stats.activePatrolEvent.routeName} eventId={stats.activePatrolEvent.eventId} />
+      ) : null}
+
+      {hasActive ? (
+        <Text style={styles.sectionHintMuted}>Finish or pause your active patrol above to see the next scheduled run.</Text>
+      ) : (
+        <>
+          <Text style={styles.sectionTitle}>Upcoming patrols</Text>
+          <NextPatrolHero
+            next={next}
+            upcoming={upcoming}
+            loading={upcomingLoading}
+            distanceKm={distanceKm}
+          />
+        </>
       )}
     </ScreenWrapper>
   );
 }
 
