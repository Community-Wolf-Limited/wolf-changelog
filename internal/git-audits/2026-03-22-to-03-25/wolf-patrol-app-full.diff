+} from "react-native";
+import { useSafeAreaInsets } from "react-native-safe-area-context";
+import { useFocusEffect } from "@react-navigation/native";
+import { Ionicons } from "@expo/vector-icons";
+import { router } from "expo-router";
+import { ScreenWrapper } from "@/components/ScreenWrapper";
+import { fetchRoutes, type PatrolRoute } from "@/services/api/route-api";
+import { fetchCapabilities } from "@/services/api/capabilities-api";
+import { useCanWritePatrolConfig } from "@/hooks/useCanWritePatrolConfig";
+import { usePatrolFieldAccessUnlocked } from "@/hooks/usePatrolFieldAccessUnlocked";
+import { useRequirePatrolFieldAccessRedirect } from "@/hooks/useRequirePatrolFieldAccessRedirect";
+import { useGrantVersionStore } from "@/store/grant-version-store";
+import { BRAND } from "@/constants/brand";
+import * as Haptics from "expo-haptics";
+
+function checkpointCount(route: PatrolRoute): number {
+  return route.checkpoints?.length ?? 0;
+}
+
+export default function RoutesTabScreen() {
+  const insets = useSafeAreaInsets();
+  const unlocked = usePatrolFieldAccessUnlocked();
+  useRequirePatrolFieldAccessRedirect();
+  const canWrite = useCanWritePatrolConfig();
+  const patrolGrantRequired = useGrantVersionStore((s) => s.patrolGrantRequired);
+  const needsAck = useGrantVersionStore((s) => s.needsDeviceAcknowledgment);
+  const grantScope = useGrantVersionStore((s) => s.grantScope);
+  const [items, setItems] = useState<PatrolRoute[]>([]);
+  const [loading, setLoading] = useState(true);
+  const [refreshing, setRefreshing] = useState(false);
+
+  const load = useCallback(async () => {
+    const rows = await fetchRoutes();
+    setItems(rows);
+    setLoading(false);
+  }, []);
+
+  useFocusEffect(
+    useCallback(() => {
+      if (!unlocked) {
+        setLoading(false);
+        setItems([]);
+        return;
+      }
+      fetchCapabilities().catch(() => {});
+      load().catch(() => {});
+    }, [load, unlocked])
+  );
+
+  const handleRefresh = async () => {
+    setRefreshing(true);
+    await fetchCapabilities();
+    await load();
+    setRefreshing(false);
+  };
+
+  const onAddRoute = () => {
+    Haptics.impactAsync(Haptics.ImpactFeedbackStyle.Light).catch(() => {});
+    if (!canWrite && patrolGrantRequired) {
+      if (needsAck) {
+        Alert.alert("Accept access first", "Open the Access tab and tap Accept field access.", [
+          { text: "OK" },
+          { text: "Go to Access", onPress: () => router.push("/(tabs)/access" as never) },
+        ]);
+        return;
+      }
+      Alert.alert("Field access required", "Request access from the Access tab, then try again.", [
+        { text: "OK" },
+        { text: "Go to Access", onPress: () => router.push("/(tabs)/access" as never) },
+      ]);
+      return;
+    }
+    router.push("/route/create" as never);
+  };
+
+  const scopeHint =
+    grantScope === "org_wide"
+      ? "Showing organisation routes."
+      : "Showing routes you created (this staff account).";
+
+  if (!unlocked) {
+    return null;
+  }
+
+  return (
+    <ScreenWrapper style={[styles.container, { paddingTop: insets.top + 16 }]}>
+      <View style={styles.headerRow}>
+        <Text style={styles.title}>Patrol routes</Text>
+        <TouchableOpacity style={styles.addBtn} onPress={onAddRoute} accessibilityRole="button">
+          <Ionicons name="add-circle-outline" size={22} color={BRAND.primaryForeground} />
+          <Text style={styles.addBtnText}>Add route</Text>
+        </TouchableOpacity>
+      </View>
+      <Text style={styles.sub}>{scopeHint} Pull down to refresh.</Text>
+
+      {loading ? (
+        <ActivityIndicator color={BRAND.primary} style={{ marginTop: 24 }} />
+      ) : (
+        <FlatList
+          data={items}
+          keyExtractor={(item) => item._id}
+          contentContainerStyle={styles.list}
+          refreshControl={
+            <RefreshControl
+              refreshing={refreshing}
+              onRefresh={() => {
+                handleRefresh().catch(() => {});
+              }}
+              tintColor={BRAND.primary}
+            />
+          }
+          renderItem={({ item }) => (
+            <TouchableOpacity style={styles.card} onPress={() => router.push(`/route/${item._id}` as never)}>
+              <Text style={styles.cardTitle}>{item.name}</Text>
+              <Text style={styles.cardMeta}>
+                {checkpointCount(item)} checkpoints
+                {item.patrolMode ? ` · ${item.patrolMode}` : ""}
+                {item.routeType ? ` · ${item.routeType}` : ""}
+              </Text>
+            </TouchableOpacity>
+          )}
+          ListEmptyComponent={
+            <View style={styles.empty}>
+              <Ionicons name="map-outline" size={48} color={BRAND.mutedForeground} />
+              <Text style={styles.emptyText}>No routes yet</Text>
+              <Text style={styles.emptyHint}>
+                {canWrite || !patrolGrantRequired
+                  ? "Create a route with the button above, or open Sites to pick a site first."
+                  : "Request field access on the Access tab to create routes from this device."}
+              </Text>
+            </View>
+          }
+        />
+      )}
+    </ScreenWrapper>
+  );
+}
+
+const styles = StyleSheet.create({
+  container: { flex: 1, paddingHorizontal: 24 },
+  headerRow: {
+    flexDirection: "row",
+    justifyContent: "space-between",
+    alignItems: "center",
+    marginBottom: 8,
+  },
+  title: { fontSize: 22, fontWeight: "700", color: BRAND.foreground },
+  addBtn: {
+    flexDirection: "row",
+    alignItems: "center",
+    gap: 6,
+    backgroundColor: BRAND.primary,
+    paddingHorizontal: 14,
+    paddingVertical: 10,
+    borderRadius: BRAND.borderRadius,
+  },
+  addBtnText: { color: BRAND.primaryForeground, fontWeight: "600", fontSize: 14 },
+  sub: { fontSize: 14, color: BRAND.mutedForeground, marginBottom: 16 },
+  list: { paddingBottom: 32 },
+  card: {
+    padding: 16,
+    backgroundColor: BRAND.muted,
+    borderRadius: 12,
+    borderWidth: 1,
+    borderColor: BRAND.border,
+    marginBottom: 12,
+    shadowColor: "#000",
+    shadowOffset: { width: 0, height: 1 },
+    shadowOpacity: 0.06,
+    shadowRadius: 3,
+    elevation: 2,
+  },
+  cardTitle: { fontSize: 16, fontWeight: "600", color: BRAND.foreground },
+  cardMeta: { fontSize: 13, color: BRAND.mutedForeground, marginTop: 6 },
+  empty: { alignItems: "center", marginTop: 48, paddingHorizontal: 16 },
+  emptyText: { fontSize: 16, fontWeight: "600", color: BRAND.foreground, marginTop: 12 },
+  emptyHint: { fontSize: 13, color: BRAND.mutedForeground, marginTop: 8, textAlign: "center", lineHeight: 20 },
+});
