new file mode 100644
index 0000000..77a42e3
--- /dev/null
+++ b/hooks/useIdleLocationTracking.ts
@@ -0,0 +1,59 @@
+import { useCallback, useEffect } from "react";
+import { AppState } from "react-native";
+import { fetchCapabilities } from "@/services/api/capabilities-api";
+import { runIdleLocationHeartbeatTick } from "@/services/gps/IdleLocationService";
+import {
+  startIdleBackgroundHeartbeatIfNeeded,
+  stopIdleBackgroundHeartbeat,
+} from "@/services/gps/BackgroundLocationTask";
+import { useGrantVersionStore } from "@/store/grant-version-store";
+import { usePatrolFieldAccessUnlocked } from "@/hooks/usePatrolFieldAccessUnlocked";
+
+const FOREGROUND_INTERVAL_MS = 20_000;
+
+/**
+ * Streams idle GPS when the org allows it (trackingMode always) and no patrol is active.
+ * Patrol execution continues to use POST .../patrol-events/:id/location.
+ */
+export function useIdleLocationTracking(): void {
+  const unlocked = usePatrolFieldAccessUnlocked();
+  const patrolGrantRequired = useGrantVersionStore((s) => s.patrolGrantRequired);
+  const trackingMode = useGrantVersionStore((s) => s.trackingMode);
+  const tick = useCallback(() => {
+    runIdleLocationHeartbeatTick({
+      unlocked,
+      patrolGrantRequired,
+      trackingMode,
+    }).catch(() => {});
+  }, [unlocked, patrolGrantRequired, trackingMode]);
+
+  useEffect(() => {
+    const sub = AppState.addEventListener("change", (next) => {
+      if (next === "active") {
+        fetchCapabilities().catch(() => {});
+        startIdleBackgroundHeartbeatIfNeeded().catch(() => {});
+      }
+    });
+    return () => sub.remove();
+  }, []);
+
+  useEffect(() => {
+    fetchCapabilities()
+      .then(async () => {
+        if (trackingMode === "patrol_only" || !unlocked) {
+          await stopIdleBackgroundHeartbeat();
+        } else {
+          await startIdleBackgroundHeartbeatIfNeeded();
+        }
+      })
+      .catch(() => {});
+  }, [trackingMode, unlocked]);
+
+  useEffect(() => {
+    const id = setInterval(() => {
+      if (AppState.currentState !== "active") return;
+      tick();
+    }, FOREGROUND_INTERVAL_MS);
+    return () => clearInterval(id);
+  }, [tick]);
+}
