+
+  async getEntitlementItems() {
+    const [account, entitlements, usage] = await Promise.all([
+      this.repository.getBillingAccount(),
+      this.getEntitlements(),
+      this.getUsageSnapshot(),
+    ]);
+
+    const lineItems = account?.lineItemQuantities ?? {};
+    const statusText = account?.status ?? "none";
+    const buildStatus = (enabled: boolean, overLimit: boolean) => {
+      if (!enabled) {
+        return "inactive";
+      }
+      if (overLimit) {
+        return "over-limit";
+      }
+      if (statusText === "trialing") {
+        return "trial";
+      }
+      if (statusText === "past_due" || statusText === "unpaid") {
+        return "unpaid";
+      }
+      return "active";
+    };
+
+    const platformLimit = entitlements?.maxSeats ?? 0;
+    const accessLimit = lineItems["access-control"] ?? 0;
+    const patrolLimit = lineItems["patrol-management"] ?? 0;
+    const groupLimit = lineItems["group-agents"] ?? 0;
+    const intelligenceEnabled = entitlements?.features.intelligence ?? false;
+
+    return [
+      {
+        key: "platform",
+        label: ENTITLEMENT_LABELS.platform,
+        enabled: entitlements?.platform ?? false,
+        usage: usage.platformUsers,
+        limit: platformLimit,
+        overLimit: platformLimit > 0 ? usage.platformUsers > platformLimit : false,
+        status: buildStatus(
+          entitlements?.platform ?? false,
+          platformLimit > 0 ? usage.platformUsers > platformLimit : false
+        ),
+      },
+      {
+        key: "intelligence",
+        label: ENTITLEMENT_LABELS.intelligence,
+        enabled: intelligenceEnabled,
+        usage: intelligenceEnabled ? 1 : 0,
+        limit: intelligenceEnabled ? 1 : 0,
+        overLimit: false,
+        status: buildStatus(intelligenceEnabled, false),
+      },
+      {
+        key: "access-control",
+        label: ENTITLEMENT_LABELS.accessControl,
+        enabled: entitlements?.features.accessControl ?? false,
+        usage: usage.accessControlUsers,
+        limit: accessLimit,
+        overLimit: accessLimit > 0 ? usage.accessControlUsers > accessLimit : false,
+        status: buildStatus(
+          entitlements?.features.accessControl ?? false,
+          accessLimit > 0 ? usage.accessControlUsers > accessLimit : false
+        ),
+      },
+      {
+        key: "patrol-management",
+        label: ENTITLEMENT_LABELS.patrolManagement,
+        enabled: entitlements?.features.patrolManagement ?? false,
+        usage: usage.patrolUsers,
+        limit: patrolLimit,
+        overLimit: patrolLimit > 0 ? usage.patrolUsers > patrolLimit : false,
+        status: buildStatus(
+          entitlements?.features.patrolManagement ?? false,
+          patrolLimit > 0 ? usage.patrolUsers > patrolLimit : false
+        ),
+      },
+      {
+        key: "group-agents",
+        label: ENTITLEMENT_LABELS.groupAgents,
+        enabled: entitlements?.features.groupAgents ?? false,
+        usage: usage.activeAgentGroups,
+        limit: groupLimit,
+        overLimit: groupLimit > 0 ? usage.activeAgentGroups > groupLimit : false,
+        status: buildStatus(
+          entitlements?.features.groupAgents ?? false,
+          groupLimit > 0 ? usage.activeAgentGroups > groupLimit : false
+        ),
+      },
+    ];
+  }
+
+  async getSummaryView(): Promise<BillingSummaryView> {
+    await this.repository.ensureCatalogSeed();
+    const [account, entitlements, usage, catalogMap] = await Promise.all([
+      this.repository.getBillingAccount(),
+      this.getEntitlements(),
+      this.getUsageSnapshot(),
+      this.getCatalogMap(),
+    ]);
+    const latestDraft = await this.repository.getLatestCheckoutDraft();
+
+    const lineItemQuantities = account?.lineItemQuantities ?? {};
+    const lineItems = this.buildSummaryLineItems(lineItemQuantities, catalogMap);
+    const monthlySubtotalCents = lineItems.reduce(
+      (total, item) => total + item.totalAmountCents,
+      0
+    );
+    const seatsIncluded = entitlements?.maxSeats ?? 0;
+    const seatsUsed = usage.platformUsers;
+    const seatsOverLimit =
+      seatsIncluded > 0 && seatsUsed > seatsIncluded ? seatsUsed - seatsIncluded : 0;
+
+    return {
+      statusLabel: account?.status ?? "none",
+      currency: "ZAR",
+      monthlySubtotalCents,
+      seatsIncluded,
+      seatsUsed,
+      seatsOverLimit,
+      currentPeriodEndsAt: account?.currentPeriodEnd?.toISOString() ?? null,
+      trialEndsAt: null,
+      graceEndsAt: account?.graceUntil?.toISOString() ?? null,
+      isTrial: account?.status === "trialing",
+      isUnpaid: account?.status === "past_due" || account?.status === "unpaid",
+      isGracePeriod:
+        Boolean(account?.graceUntil) &&
+        (account?.graceUntil?.getTime() ?? 0) > Date.now(),
+      isOverLimit: seatsOverLimit > 0,
+      lineItems,
+      billingMode: account?.stripeSubscriptionId
+        ? "stripe"
+        : entitlements?.overridden
+          ? "manual"
+          : "none",
+      usingOverrides: entitlements?.overridden ?? false,
+      usage,
+      latestDraft: latestDraft
+        ? {
+            draftId: latestDraft._id?.toString() ?? "",
+            status: latestDraft.status,
+            createdAt: latestDraft.createdAt.toISOString(),
+            updatedAt: latestDraft.updatedAt.toISOString(),
+            seatCount: latestDraft.seatCount,
+            amountSubtotalCents: latestDraft.amountSubtotal,
+            stripeCheckoutSessionId: latestDraft.stripeCheckoutSessionId ?? null,
+          }
+        : null,
+    };
+  }
+
+  async createCheckoutDraft(
+    payload: CreateCheckoutDraftInput,
+    createdByUserId?: ObjectId
+  ): Promise<BillingCheckoutDraftDocument> {
+    const lineItemQuantities = this.buildLineItemQuantities(payload.lineItems);
+    const seatCount =
+      ((lineItemQuantities["platform-base"] ?? 0) * 2) +
+      (lineItemQuantities["platform-additional-seat"] ?? 0);
+
+    const catalogMap = await this.getCatalogMap();
+    const amountSubtotal = this.computeSubtotal(lineItemQuantities, catalogMap);
+
+    const draft = await this.repository.createCheckoutDraft({
+      organisationId: this.getRequiredOrganisationId(),
+      createdByUserId,
+      seatCount,
+      lineItemQuantities,
+      amountSubtotal,
+      status: "draft",
+      successUrl: payload.successUrl,
+      cancelUrl: payload.cancelUrl,
+    });
+
+    await this.repository.upsertBillingAccount({
+      lastCheckoutDraftId: draft._id,
+      seatCount: draft.seatCount,
+    });
+
+    await this.repository.createEventLog({
+      organisationId: this.getRequiredOrganisationId(),
+      source: "api",
+      eventType: "billing.checkout-draft.created",
+      status: "processed",
+      payload: {
+        checkoutDraftId: draft._id?.toString(),
+        amountSubtotal: draft.amountSubtotal,
+        seatCount: draft.seatCount,
+        lineItemQuantities: draft.lineItemQuantities,
+      },
+      processedAt: new Date(),
+    });
+
+    return draft;
+  }
+
+  async createCheckoutSession(payload: CreateCheckoutSessionInput): Promise<{
+    checkoutSessionId: string;
+    url: string | null;
+  }> {
+    const draftId = new ObjectId(payload.draftId);
+    const draft = await this.repository.getCheckoutDraftById(draftId);
+    if (!draft) {
+      throw new Error("Checkout draft not found");
+    }
+
+    const stripeLineItems = await this.ensureStripeLineItems(draft.lineItemQuantities);
+    if (stripeLineItems.length === 0) {
+      throw new Error("No active billing line items available for checkout");
+    }
+
+    const existingAccount = await this.repository.getBillingAccount();
+    const stripeCustomerId = await this.ensureStripeCustomer(existingAccount);
+    const stripe = this.getStripeClient();
+    const organisationId = this.getRequiredOrganisationId();
+
+    const successUrl = this.getReturnUrl(
+      payload.successUrl,
+      draft.successUrl,
+      AppConfig.STRIPE_CHECKOUT_SUCCESS_URL
+    );
+    const cancelUrl = this.getReturnUrl(
+      payload.cancelUrl,
+      draft.cancelUrl,
+      AppConfig.STRIPE_CHECKOUT_CANCEL_URL
+    );
+
+    const checkoutSession = await stripe.checkout.sessions.create({
+      mode: "subscription",
+      customer: stripeCustomerId,
+      line_items: stripeLineItems,
+      success_url: successUrl,
+      cancel_url: cancelUrl,
+      allow_promotion_codes: true,
+      metadata: {
+        organisationId: organisationId.toString(),
+        billingDraftId: draftId.toString(),
+      },
+      subscription_data: {
+        metadata: {
+          organisationId: organisationId.toString(),
+        },
+      },
+    });
+
+    await this.repository.markDraftCheckoutCreated(draftId, checkoutSession.id);
+    await this.repository.upsertBillingAccount({
+      stripeCustomerId,
+      stripeCheckoutSessionId: checkoutSession.id,
+      seatCount: draft.seatCount,
+      lastCheckoutDraftId: draftId,
+      status: existingAccount?.status ?? "none",
+    });
+
+    await this.repository.createEventLog({
+      organisationId,
+      source: "api",
+      eventType: "billing.checkout-session.created",
+      eventId: checkoutSession.id,
+      status: "processed",
+      payload: {
+        checkoutDraftId: draftId.toString(),
+        stripeCheckoutSessionId: checkoutSession.id,
+      },
+      processedAt: new Date(),
+    });
+
+    return {
+      checkoutSessionId: checkoutSession.id,
+      url: checkoutSession.url,
+    };
+  }
+
+  async regenerateCheckoutSession(
+    payload: RegenerateCheckoutSessionInput = {}
+  ): Promise<{
+    checkoutSessionId: string;
+    url: string | null;
+    draftId: string;
+  }> {
+    const latestDraft =
+      payload.draftId && ObjectId.isValid(payload.draftId)
+        ? await this.repository.getCheckoutDraftById(new ObjectId(payload.draftId))
+        : await this.repository.getLatestCheckoutDraft();
+
+    if (!latestDraft?._id) {
+      throw new Error("No billing draft is available to regenerate");
+    }
+
+    const session = await this.createCheckoutSession({
+      draftId: latestDraft._id.toString(),
+    });
+
+    return {
+      ...session,
+      draftId: latestDraft._id.toString(),
+    };
+  }
+
+  async createPortalSession(payload: CreatePortalSessionInput): Promise<{
