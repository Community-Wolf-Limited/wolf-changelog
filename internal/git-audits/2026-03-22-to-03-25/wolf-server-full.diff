diff --git a/server/scripts/sync-enterprise-collection-alignment.ts b/server/scripts/sync-enterprise-collection-alignment.ts
new file mode 100644
index 0000000..f1fe3ee
--- /dev/null
+++ b/server/scripts/sync-enterprise-collection-alignment.ts
@@ -0,0 +1,232 @@
+/**
+ * Align enterprise-wolf-development <-> enterprise-wolf-production collection *names*
+ * and *indexes* (no document copy). Does not touch billing-* or vision-run-logs.
+ *
+ * - Dev gets (from prod): configurations, custom-areas, cw_crime_hex_compute_progress,
+ *   data-visualisations, osm-by-hex, remarketing-campaigns
+ * - Prod gets (from dev): device-permission-grants, patrol-change-proposals,
+ *   patrol-field-audit-logs
+ *
+ * Requires DATABASE_URI (enterprise dev) and DATABASE_URI_PRODUCTION (enterprise prod)
+ * on the same Atlas cluster host.
+ *
+ * Usage:
+ *   npx tsx server/scripts/sync-enterprise-collection-alignment.ts           # dry-run
+ *   npx tsx server/scripts/sync-enterprise-collection-alignment.ts --apply   # writes
+ */
+
+import { config } from "dotenv";
+import { dirname, resolve } from "node:path";
+import { fileURLToPath } from "node:url";
+import type { Collection, CreateIndexesOptions, Db, Document, IndexDescription } from "mongodb";
+import { MongoClient } from "mongodb";
+
+const __dirname = dirname(fileURLToPath(import.meta.url));
+config({ path: resolve(__dirname, "../../.env") });
+
+const ENTERPRISE_DEV_DB = "enterprise-wolf-development";
+const ENTERPRISE_PROD_DB = "enterprise-wolf-production";
+
+/** Prod has these; ensure they exist on dev (+ indexes from prod). */
+const COLLECTIONS_DEV_NEEDS_FROM_PROD = [
+  "configurations",
+  "custom-areas",
+  "cw_crime_hex_compute_progress",
+  "data-visualisations",
+  "osm-by-hex",
+  "remarketing-campaigns",
+] as const;
+
+/** Dev has these; ensure they exist on prod (+ indexes from dev). Patrol / device governance. */
+const COLLECTIONS_PROD_NEEDS_FROM_DEV = [
+  "device-permission-grants",
+  "patrol-change-proposals",
+  "patrol-field-audit-logs",
+] as const;
+
+function parseClusterHost(uri: string): string {
+  const at = uri.indexOf("@");
+  if (at === -1) return "";
+  const rest = uri.slice(at + 1);
+  const slash = rest.indexOf("/");
+  const hostPart = slash === -1 ? rest : rest.slice(0, slash);
+  return hostPart.split("?")[0].trim();
+}
+
+function indexOptionsFromDescription(idx: IndexDescription): CreateIndexesOptions {
+  const skip = new Set(["v", "key", "ns"]);
+  const opts: Record<string, unknown> = {};
+  for (const [k, v] of Object.entries(idx)) {
+    if (skip.has(k)) continue;
+    opts[k] = v;
+  }
+  return opts as CreateIndexesOptions;
+}
+
+async function collectionExists(db: Db, name: string): Promise<boolean> {
+  const found = await db.listCollections({ name }, { nameOnly: true }).toArray();
+  return found.length > 0;
+}
+
+async function targetIndexNameSet(
+  target: Db,
+  collectionName: string,
+  tgtCol: Collection
+): Promise<Set<string>> {
+  if (!(await collectionExists(target, collectionName))) {
+    return new Set();
+  }
+  const names = (await tgtCol.indexes())
+    .map((i) => i.name)
+    .filter((n): n is string => n !== undefined);
+  return new Set(names);
+}
+
+function isBenignIndexError(e: unknown): boolean {
+  const err = e as { code?: number; message?: string };
+  return (
+    err.code === 85 ||
+    err.code === 86 ||
+    Boolean(err.message && /already exists/i.test(err.message))
+  );
+}
+
+async function syncIndexesFromTo(
+  source: Db,
+  target: Db,
+  collectionName: string,
+  dryRun: boolean
+): Promise<{ created: number; skipped: number }> {
+  const srcCol = source.collection(collectionName);
+  const tgtCol = target.collection(collectionName);
+  const sourceIndexes = await srcCol.indexes();
+  const targetIndexNames = await targetIndexNameSet(target, collectionName, tgtCol);
+
+  let created = 0;
+  let skipped = 0;
+
+  for (const idx of sourceIndexes) {
+    if (idx.name === "_id_") continue;
+    if (idx.name && targetIndexNames.has(idx.name)) {
+      skipped += 1;
+      continue;
+    }
+    if (dryRun) {
+      console.log(`    [dry-run] createIndex ${collectionName} / ${idx.name}`);
+      created += 1;
+      continue;
+    }
+    try {
+      await tgtCol.createIndex(idx.key as Document, indexOptionsFromDescription(idx));
+      created += 1;
+    } catch (e: unknown) {
+      if (isBenignIndexError(e)) {
+        skipped += 1;
+      } else {
+        throw e;
+      }
+    }
+  }
+  return { created, skipped };
+}
+
+async function ensureCollectionFromSource(
+  sourceDb: Db,
+  targetDb: Db,
+  collectionName: string,
+  dryRun: boolean
+): Promise<void> {
+  const existsOnSource = await collectionExists(sourceDb, collectionName);
+  if (!existsOnSource) {
+    throw new Error(
+      `Source DB "${sourceDb.databaseName}" has no collection "${collectionName}"; cannot copy structure.`
+    );
+  }
+
+  const existsOnTarget = await collectionExists(targetDb, collectionName);
+  if (existsOnTarget) {
+    console.log(`  collection already exists ${targetDb.databaseName}.${collectionName}`);
+  } else if (dryRun) {
+    console.log(`  [dry-run] createCollection ${targetDb.databaseName}.${collectionName}`);
+  } else {
+    await targetDb.createCollection(collectionName);
+    console.log(`  created collection ${targetDb.databaseName}.${collectionName}`);
+  }
+
+  const { created, skipped } = await syncIndexesFromTo(
+    sourceDb,
+    targetDb,
+    collectionName,
+    dryRun
+  );
+  console.log(`  indexes: +${created} created/synced, ${skipped} already present`);
+}
+
+async function main() {
+  const apply = process.argv.includes("--apply");
+  const dryRun = !apply;
+
+  const devUri = (process.env.DATABASE_URI ?? "").trim();
+  const prodUri = (process.env.DATABASE_URI_PRODUCTION ?? "").trim();
+
+  if (!devUri.startsWith("mongodb")) {
+    console.error("Set DATABASE_URI to enterprise dev (e.g. .../enterprise-wolf-development).");
+    process.exit(1);
+  }
+  if (!prodUri.startsWith("mongodb")) {
+    console.error(
+      "Set DATABASE_URI_PRODUCTION to enterprise prod (e.g. .../enterprise-wolf-production)."
+    );
+    process.exit(1);
+  }
+
+  const hostDev = parseClusterHost(devUri);
+  const hostProd = parseClusterHost(prodUri);
+  if (!hostDev || !hostProd || hostDev !== hostProd) {
+    console.error(
+      "DATABASE_URI and DATABASE_URI_PRODUCTION must target the same cluster host (Atlas)."
+    );
+    console.error("Dev host:", hostDev || "(unparsed)");
+    console.error("Prod host:", hostProd || "(unparsed)");
+    process.exit(1);
+  }
+
+  if (dryRun) {
+    console.log("DRY RUN (no writes). Pass --apply to create collections and indexes.\n");
+  } else {
+    console.log("APPLY: creating missing collections and indexes.\n");
+  }
+
+  const client = new MongoClient(devUri);
+  await client.connect();
+
+  try {
+    const devDb = client.db(ENTERPRISE_DEV_DB);
+    const prodDb = client.db(ENTERPRISE_PROD_DB);
+
+    console.log("--- Dev ← Prod (structure + indexes from production) ---\n");
+    for (const name of COLLECTIONS_DEV_NEEDS_FROM_PROD) {
+      console.log(`Collection: ${name}`);
+      await ensureCollectionFromSource(prodDb, devDb, name, dryRun);
+      console.log("");
+    }
+
+    console.log("--- Prod ← Dev (structure + indexes from development) ---\n");
+    for (const name of COLLECTIONS_PROD_NEEDS_FROM_DEV) {
+      console.log(`Collection: ${name}`);
+      await ensureCollectionFromSource(devDb, prodDb, name, dryRun);
+      console.log("");
+    }
+
+    console.log(dryRun ? "Dry run finished." : "Apply finished.");
+  } finally {
+    await client.close();
+  }
+}
+
+try {
+  await main();
+} catch (e) {
+  console.error(e);
+  process.exit(1);
+}
