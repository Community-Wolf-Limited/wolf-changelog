+import { Types } from "mongoose";
+import StaffLivePositionModel from "../schemas/staff-live-position.schema.js";
+import type { StaffLivePositionSource } from "../schemas/staff-live-position.schema.js";
+
+export async function upsertStaffLivePosition(params: {
+  organizationId: string;
+  staffId: string;
+  eventId: string | null;
+  source: StaffLivePositionSource;
+  location: {
+    latitude: number;
+    longitude: number;
+    accuracy?: number;
+    altitude?: number;
+    heading?: number;
+    speed?: number;
+    provider?: string;
+  };
+}): Promise<void> {
+  const now = new Date();
+  await StaffLivePositionModel.findOneAndUpdate(
+    {
+      organizationId: new Types.ObjectId(params.organizationId),
+      staffId: new Types.ObjectId(params.staffId),
+    },
+    {
+      $set: {
+        organizationId: new Types.ObjectId(params.organizationId),
+        staffId: new Types.ObjectId(params.staffId),
+        location: params.location,
+        eventId: params.eventId ? new Types.ObjectId(params.eventId) : null,
+        source: params.source,
+        timestamp: now,
+        updatedAt: now,
+      },
+    },
+    { upsert: true }
+  );
+}
