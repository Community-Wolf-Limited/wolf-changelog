+  organizationId: string,
+  orgOid: Types.ObjectId,
+  reviewerOid: Types.ObjectId,
+  staffOid: Types.ObjectId
+): Promise<ProposalStepResult> {
+  if (p.entity === "site" && p.action === "create") {
+    return applySiteCreateStep(payload, orgOid, staffOid, p.deviceId);
+  }
+  if (p.entity === "site" && p.action === "delete") {
+    return applySiteDeleteStep(p, payload, organizationId, orgOid, reviewerOid);
+  }
+  if (p.entity === "patrol_route" && p.action === "create") {
+    return applyPatrolRouteCreateStep(payload, orgOid, staffOid, p.deviceId);
+  }
+  if (p.entity === "patrol_route" && p.action === "delete") {
+    return applyPatrolRouteDeleteStep(p, payload, organizationId, orgOid, reviewerOid);
+  }
+  if (p.entity === "patrol_schedule" && p.action === "delete") {
+    return applyPatrolScheduleDeleteStep(p, payload, organizationId, orgOid, reviewerOid);
+  }
+  if (p.entity === "patrol" && p.action === "delete") {
+    return applyPatrolAssignmentDeleteStep(p, payload, organizationId, orgOid, reviewerOid);
+  }
+  return { error: "unsupported" };
