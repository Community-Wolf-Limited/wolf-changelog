+++ b/server/device-auth/patrol-field-governance.route.ts
@@ -0,0 +1,301 @@
+import { Router, Response, Request } from "express";
+import { Types } from "mongoose";
+import DevicePermissionGrantModel from "./device-permission-grant.schema.js";
+import PatrolChangeProposalModel from "./patrol-change-proposal.schema.js";
+import PatrolFieldAuditLogModel from "./patrol-field-audit.schema.js";
+import {
+  approvePermissionGrant,
+  applyPatrolChangeProposal,
+  denyPermissionGrant,
+  listPatrolConfigTrash,
+  listProposalsForOrg,
+  restorePatrolConfigEntity,
+  revokePermissionGrant,
+  updateGrantTrackingMode,
+  type PatrolConfigRestoreEntity,
+} from "./device-field-patrol.service.js";
+import StaffLivePositionModel from "../schemas/staff-live-position.schema.js";
+
+interface OrgParams {
+  organisationId: string;
+}
+
+type AuthedRequest = Request<OrgParams> & { user?: { id: string } };
+
+const router = Router({ mergeParams: true });
+
+/**
+ * GET /:organisationId/patrol-field-governance/permission-requests
+ */
+router.get("/permission-requests", async (req: AuthedRequest, res: Response) => {
+  const { organisationId } = req.params;
+  try {
+    const list = await DevicePermissionGrantModel.find({
+      organizationId: new Types.ObjectId(organisationId),
+      status: { $in: ["pending", "active", "revoked", "denied"] },
+    })
+      .sort({ updatedAt: -1 })
+      .limit(500)
+      .lean();
+    return res.json({ success: true, data: list });
+  } catch (e) {
+    console.error("permission-requests list", e);
+    return res.status(500).json({ success: false, error: "Failed to list permission requests" });
+  }
+});
+
+/**
+ * POST /:organisationId/patrol-field-governance/permission-requests/:grantId/approve
+ */
+router.post("/permission-requests/:grantId/approve", async (req: AuthedRequest, res: Response) => {
+  const { organisationId, grantId } = req.params as OrgParams & { grantId: string };
+  const { scope, expiresAt } = (req as { body?: { scope?: string; expiresAt?: string | null } }).body || {};
+  const uid = req.user?.id;
+  if (!uid) return res.status(401).json({ success: false, error: "Unauthorized" });
+  if (!scope || !["own_device_created", "org_wide"].includes(scope)) {
+    return res.status(400).json({ success: false, error: "scope must be own_device_created or org_wide" });
+  }
+  const exp = expiresAt ? new Date(expiresAt) : null;
+  const g = await approvePermissionGrant({
+    grantId,
+    organizationId: organisationId,
+    approverUserId: uid,
+    scope: scope as "own_device_created" | "org_wide",
+    expiresAt: exp,
+  });
+  if (!g) return res.status(404).json({ success: false, error: "Pending request not found" });
+  return res.json({ success: true, data: g });
+});
+
+/**
+ * POST /:organisationId/patrol-field-governance/permission-requests/:grantId/deny
+ */
+router.post("/permission-requests/:grantId/deny", async (req: AuthedRequest, res: Response) => {
+  const { organisationId, grantId } = req.params as OrgParams & { grantId: string };
+  const { reason } = (req as { body?: { reason?: string } }).body || {};
+  const uid = req.user?.id;
+  if (!uid) return res.status(401).json({ success: false, error: "Unauthorized" });
+  const g = await denyPermissionGrant({
+    grantId,
+    organizationId: organisationId,
+    reviewerUserId: uid,
+    reason,
+  });
+  if (!g) return res.status(404).json({ success: false, error: "Pending request not found" });
+  return res.json({ success: true, data: g });
+});
+
+/**
+ * POST /:organisationId/patrol-field-governance/grants/:grantId/revoke
+ */
+router.post("/grants/:grantId/revoke", async (req: AuthedRequest, res: Response) => {
+  const { organisationId, grantId } = req.params as OrgParams & { grantId: string };
+  const { reason } = (req as { body?: { reason?: string } }).body || {};
+  const uid = req.user?.id;
+  if (!uid) return res.status(401).json({ success: false, error: "Unauthorized" });
+  const g = await revokePermissionGrant({
+    grantId,
+    organizationId: organisationId,
+    actorUserId: uid,
+    reason,
+  });
+  if (!g) return res.status(404).json({ success: false, error: "Active grant not found" });
+  return res.json({ success: true, data: g });
+});
+
+/**
+ * GET /:organisationId/patrol-field-governance/staff-positions
+ * Last-known GPS for staff with an active field-access grant (bootstrap for live map).
+ */
+router.get("/staff-positions", async (req: AuthedRequest, res: Response) => {
+  const { organisationId } = req.params;
+  const uid = req.user?.id;
+  if (!uid) return res.status(401).json({ success: false, error: "Unauthorized" });
+  try {
+    const activeGrants = await DevicePermissionGrantModel.find({
+      organizationId: new Types.ObjectId(organisationId),
+      status: "active",
+    })
+      .select("staffId")
+      .lean();
+    const staffIds = activeGrants.map((g) => g.staffId);
+    if (staffIds.length === 0) {
+      return res.json({ success: true, data: { positions: [] } });
+    }
+    const rows = await StaffLivePositionModel.find({
+      organizationId: new Types.ObjectId(organisationId),
+      staffId: { $in: staffIds },
+    }).lean();
+    const positions = rows.map((r) => ({
+      staffId: r.staffId.toString(),
+      eventId: r.eventId ? r.eventId.toString() : null,
+      location: r.location,
+      timestamp: r.timestamp.toISOString(),
+      source: r.source,
+      updatedAt: r.updatedAt.toISOString(),
+    }));
+    return res.json({ success: true, data: { positions } });
+  } catch (e) {
+    console.error("staff-positions", e);
+    return res.status(500).json({ success: false, error: "Failed to load staff positions" });
+  }
+});
+
+/**
+ * PATCH /:organisationId/patrol-field-governance/grants/:grantId/tracking-mode
+ * Body: { trackingMode: "always" | "patrol_only" }
+ */
+router.patch("/grants/:grantId/tracking-mode", async (req: AuthedRequest, res: Response) => {
+  const { organisationId, grantId } = req.params as OrgParams & { grantId: string };
+  const uid = req.user?.id;
+  if (!uid) return res.status(401).json({ success: false, error: "Unauthorized" });
+  const { trackingMode } = (req as { body?: { trackingMode?: string } }).body || {};
+  if (trackingMode !== "always" && trackingMode !== "patrol_only") {
+    return res.status(400).json({ success: false, error: "trackingMode must be always or patrol_only" });
+  }
+  const g = await updateGrantTrackingMode({
+    grantId,
+    organizationId: organisationId,
+    actorUserId: uid,
+    trackingMode,
+  });
+  if (!g) return res.status(404).json({ success: false, error: "Active grant not found" });
+  return res.json({ success: true, data: g });
+});
+
+/**
+ * GET /:organisationId/patrol-field-governance/proposals
+ */
+router.get("/proposals", async (req: AuthedRequest, res: Response) => {
+  const { organisationId } = req.params;
+  const status = typeof req.query.status === "string" ? req.query.status : undefined;
+  try {
+    const data = await listProposalsForOrg(organisationId, status);
+    return res.json({ success: true, data });
+  } catch (e) {
+    console.error("proposals list", e);
+    return res.status(500).json({ success: false, error: "Failed to list proposals" });
+  }
+});
+
+/**
+ * POST /:organisationId/patrol-field-governance/proposals/:proposalId/approve
+ * Approve and apply the proposal (hash-checked).
+ */
+router.post("/proposals/:proposalId/approve", async (req: AuthedRequest, res: Response) => {
+  const { organisationId, proposalId } = req.params as OrgParams & { proposalId: string };
+  const uid = req.user?.id;
+  if (!uid) return res.status(401).json({ success: false, error: "Unauthorized" });
+  const result = await applyPatrolChangeProposal(proposalId, organisationId, uid);
+  if (!result.ok) {
+    const map: Record<string, number> = {
+      not_found: 404,
+      hash_mismatch: 409,
+      bad_payload: 400,
+      unsupported: 422,
+      apply_failed: 500,
+    };
+    const status = map[result.error] ?? 400;
+    return res.status(status).json({ success: false, error: result.error });
+  }
+  return res.json({ success: true, data: result.proposal });
+});
+
+/**
+ * GET /:organisationId/patrol-field-governance/trash
+ * Soft-deleted sites and patrol routes (for recovery UI).
+ */
+router.get("/trash", async (req: AuthedRequest, res: Response) => {
+  const { organisationId } = req.params;
+  try {
+    const data = await listPatrolConfigTrash(organisationId);
+    return res.json({ success: true, data });
+  } catch (e) {
+    console.error("patrol trash list", e);
+    return res.status(500).json({ success: false, error: "Failed to list trash" });
+  }
+});
+
+/**
+ * POST /:organisationId/patrol-field-governance/restore
+ * Body: { entity: "site" | "patrol_route" | "patrol_schedule" | "patrol", id: string }
+ */
+router.post("/restore", async (req: AuthedRequest, res: Response) => {
+  const { organisationId } = req.params;
+  const uid = req.user?.id;
+  if (!uid) return res.status(401).json({ success: false, error: "Unauthorized" });
+  const body = (req as { body?: { entity?: string; id?: string } }).body || {};
+  const entity = body.entity;
+  const id = body.id;
+  const allowed = ["site", "patrol_route", "patrol_schedule", "patrol"] as const;
+  if (!entity || !allowed.includes(entity as (typeof allowed)[number])) {
+    return res.status(400).json({
+      success: false,
+      error: "entity must be site, patrol_route, patrol_schedule, or patrol",
+    });
+  }
+  if (!id || typeof id !== "string") {
+    return res.status(400).json({ success: false, error: "id required" });
+  }
+  const result = await restorePatrolConfigEntity(
+    organisationId,
+    entity as PatrolConfigRestoreEntity,
+    id,
+    uid
+  );
+  if (!result.ok) {
+    return res.status(404).json({ success: false, error: "Not found or not deleted" });
+  }
+  return res.json({ success: true });
+});
+
+/**
+ * POST /:organisationId/patrol-field-governance/proposals/:proposalId/reject
+ */
+router.post("/proposals/:proposalId/reject", async (req: AuthedRequest, res: Response) => {
+  const { organisationId, proposalId } = req.params as OrgParams & { proposalId: string };
+  const { reason } = (req as { body?: { reason?: string } }).body || {};
+  const uid = req.user?.id;
+  if (!uid) return res.status(401).json({ success: false, error: "Unauthorized" });
+  const p = await PatrolChangeProposalModel.findOne({
+    _id: new Types.ObjectId(proposalId),
+    organizationId: new Types.ObjectId(organisationId),
+    status: "pending",
+  });
+  if (!p) return res.status(404).json({ success: false, error: "Proposal not found" });
+  p.status = "rejected";
+  p.reviewedByUserId = new Types.ObjectId(uid);
+  p.reviewedAt = new Date();
+  p.reviewReason = reason ?? null;
+  await p.save();
+  await PatrolFieldAuditLogModel.create({
+    organizationId: new Types.ObjectId(organisationId),
+    eventType: "proposal_rejected",
+    actorUserId: new Types.ObjectId(uid),
+    proposalId: p._id,
+    metadata: { reason },
+    createdAt: new Date(),
+  });
+  return res.json({ success: true, data: p });
+});
+
+/**
+ * GET /:organisationId/patrol-field-governance/audit-log
+ */
+router.get("/audit-log", async (req: AuthedRequest, res: Response) => {
+  const { organisationId } = req.params;
+  try {
+    const rows = await PatrolFieldAuditLogModel.find({
+      organizationId: new Types.ObjectId(organisationId),
+    })
+      .sort({ createdAt: -1 })
+      .limit(500)
+      .lean();
+    return res.json({ success: true, data: rows });
+  } catch (e) {
+    console.error("audit-log", e);
+    return res.status(500).json({ success: false, error: "Failed to load audit log" });
+  }
+});
+
+export default router;
