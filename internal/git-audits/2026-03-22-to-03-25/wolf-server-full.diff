+export type PatrolProposalEntity =
+  | "site"
+  | "patrol_route"
+  | "patrol_schedule"
+  | "patrol";
+export type PatrolProposalAction = "create" | "update" | "delete";
+export type PatrolProposalStatus = "pending" | "approved" | "rejected" | "cancelled" | "applied";
+
+export interface PatrolChangeProposalDocument {
+  _id: import("mongodb").ObjectId;
+  organizationId: import("mongodb").ObjectId;
+  staffId: import("mongodb").ObjectId;
+  deviceId?: string;
+  entity: PatrolProposalEntity;
+  action: PatrolProposalAction;
+  status: PatrolProposalStatus;
+  payload: Record<string, unknown>;
+  payloadCanonicalHash?: string;
+  targetEntityId?: import("mongodb").ObjectId | null;
+  idempotencyKey?: string;
+  requestedAt: Date;
+  reviewedByUserId?: import("mongodb").ObjectId | null;
+  reviewedAt?: Date | null;
+  reviewReason?: string | null;
+  appliedAt?: Date | null;
+  createdAt: Date;
+  updatedAt: Date;
+}
+
+const patrolChangeProposalSchema = new Schema<PatrolChangeProposalDocument>(
+  {
+    organizationId: { type: Schema.Types.ObjectId, required: true, ref: "Organisation", index: true },
+    staffId: { type: Schema.Types.ObjectId, required: true, ref: "Staff", index: true },
+    deviceId: { type: String, trim: true },
+    entity: {
+      type: String,
+      enum: ["site", "patrol_route", "patrol_schedule", "patrol"],
+      required: true,
+    },
+    action: {
+      type: String,
+      enum: ["create", "update", "delete"],
+      required: true,
+    },
+    status: {
+      type: String,
+      enum: ["pending", "approved", "rejected", "cancelled", "applied"],
+      default: "pending",
+      index: true,
+    },
+    payload: { type: Schema.Types.Mixed, required: true },
+    payloadCanonicalHash: { type: String },
+    targetEntityId: { type: Schema.Types.ObjectId, default: null },
+    idempotencyKey: { type: String },
+    requestedAt: { type: Date, default: Date.now },
+    reviewedByUserId: { type: Schema.Types.ObjectId, ref: "User", default: null },
+    reviewedAt: { type: Date, default: null },
+    reviewReason: { type: String, default: null },
+    appliedAt: { type: Date, default: null },
+  },
+  {
+    timestamps: true,
+    collection: DbConfig.PATROL_CHANGE_PROPOSALS_COLLECTION,
+    autoIndex: false,
+  }
+);
+
+patrolChangeProposalSchema.index({ organizationId: 1, status: 1, createdAt: -1 });
+patrolChangeProposalSchema.index(
+  { organizationId: 1, staffId: 1, idempotencyKey: 1 },
+  { unique: true, sparse: true }
+);
+
+const PatrolChangeProposalModel = db.model<PatrolChangeProposalDocument>(
+  "PatrolChangeProposal",
+  patrolChangeProposalSchema,
+  DbConfig.PATROL_CHANGE_PROPOSALS_COLLECTION
+);
+
+export default PatrolChangeProposalModel;
