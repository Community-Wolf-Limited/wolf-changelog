diff --git a/server/billing/billing-enforcement.service.ts b/server/billing/billing-enforcement.service.ts
new file mode 100644
index 0000000..97b4908
--- /dev/null
+++ b/server/billing/billing-enforcement.service.ts
@@ -0,0 +1,150 @@
+import { ObjectId } from "mongodb";
+import { BillingRepository } from "./billing.repository.js";
+import {
+  BillingEnforcementFeature,
+  BillingEnforcementResult,
+  BillingFeatures,
+} from "./billing.type.js";
+
+const ACCESS_CONTROL_SKILLS = new Set<string>([
+  "log_license_disc",
+  "log_licence_disc",
+  "log_license_disc_and_person_info",
+  "log_licence_disc_and_person_info",
+  "log_person_info",
+  "log_person_information",
+  "check_license_plate",
+  "check_licence_plate",
+]);
+
+function buildDefaultFeatures(): BillingFeatures {
+  return {
+    intelligence: false,
+    accessControl: false,
+    patrolManagement: false,
+    groupAgents: false,
+  };
+}
+
+export class BillingEnforcementService {
+  private readonly repository: BillingRepository;
+  private readonly organisationId: ObjectId;
+
+  constructor({ organisationId }: { organisationId: ObjectId | string }) {
+    this.organisationId =
+      typeof organisationId === "string"
+        ? new ObjectId(organisationId)
+        : organisationId;
+    this.repository = new BillingRepository({ organisationId: this.organisationId });
+  }
+
+  private async resolveEntitlementFeatures(): Promise<{
+    platform: boolean;
+    features: BillingFeatures;
+  }> {
+    const entitlements = await this.repository.getEntitlements();
+    if (!entitlements) {
+      return { platform: false, features: buildDefaultFeatures() };
+    }
+
+    return {
+      platform: entitlements.platform,
+      features: entitlements.features,
+    };
+  }
+
+  private async createSoftEvent(
+    eventType: string,
+    payload: Record<string, unknown>
+  ): Promise<void> {
+    await this.repository.createEventLog({
+      organisationId: this.organisationId,
+      source: "enforcement",
+      eventType,
+      status: "processed",
+      payload,
+      processedAt: new Date(),
+    });
+  }
+
+  private async evaluateFeatures(
+    requiredFeatures: BillingEnforcementFeature[],
+    context: string
+  ): Promise<BillingEnforcementResult> {
+    const { platform, features } = await this.resolveEntitlementFeatures();
+    const missingFeatures: BillingEnforcementFeature[] = [];
+
+    for (const feature of requiredFeatures) {
+      if (feature === "platform") {
+        if (!platform) {
+          missingFeatures.push(feature);
+        }
+        continue;
+      }
+
+      if (!features[feature]) {
+        missingFeatures.push(feature);
+      }
+    }
+
+    if (missingFeatures.length > 0) {
+      await this.createSoftEvent("billing.soft-enforcement.warning", {
+        context,
+        missingFeatures,
+      });
+    }
+
+    return {
+      allowed: true,
+      softLimited: missingFeatures.length > 0,
+      missingFeatures,
+      message:
+        missingFeatures.length > 0
+          ? `Missing billing features for ${context}: ${missingFeatures.join(", ")}`
+          : undefined,
+    };
+  }
+
+  private inferSkillRequirements(skills: string[]): BillingEnforcementFeature[] {
+    const requiredFeatures = new Set<BillingEnforcementFeature>(["platform"]);
+
+    for (const rawSkill of skills) {
+      const skill = rawSkill.toLowerCase();
+      if (skill.includes("patrol")) {
+        requiredFeatures.add("patrolManagement");
+      }
+      if (skill.includes("intelligence")) {
+        requiredFeatures.add("intelligence");
+      }
+      if (skill.includes("group")) {
+        requiredFeatures.add("groupAgents");
+      }
+      if (ACCESS_CONTROL_SKILLS.has(skill)) {
+        requiredFeatures.add("accessControl");
+      }
+    }
+
+    return Array.from(requiredFeatures);
+  }
+
+  async enforceStaffSkillAssignment(
+    skills: string[],
+    operation: "create" | "update"
+  ): Promise<BillingEnforcementResult> {
+    const requiredFeatures = this.inferSkillRequirements(skills);
+    return this.evaluateFeatures(requiredFeatures, `staff-skill-${operation}`);
+  }
+
+  async enforceAgentGroupMutation(
+    operation: "create" | "update"
+  ): Promise<BillingEnforcementResult> {
+    return this.evaluateFeatures(["platform", "groupAgents"], `agent-group-${operation}`);
+  }
+
+  async enforceIntelligenceReadAccess(): Promise<BillingEnforcementResult> {
+    return this.evaluateFeatures(
+      ["platform", "accessControl", "intelligence"],
+      "gatekeeper-intelligence-read"
+    );
+  }
+}
