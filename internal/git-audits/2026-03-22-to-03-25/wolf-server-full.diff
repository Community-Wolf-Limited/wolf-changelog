+
+  async recalculateEntitlements(reason: string): Promise<BillingEntitlementsDocument | null> {
+    const [account, overrides] = await Promise.all([
+      this.repository.getBillingAccount(),
+      this.repository.getActiveOverrides(),
+    ]);
+    const computed = this.calculateEntitlementsFromAccount(account, overrides);
+
+    const entitlements = await this.repository.upsertEntitlements(computed);
+    await this.repository.createEventLog({
+      organisationId: this.getRequiredOrganisationId(),
+      source: "system",
+      eventType: "billing.entitlements.recalculated",
+      status: "processed",
+      payload: {
+        reason,
+        platform: entitlements?.platform,
+        maxSeats: entitlements?.maxSeats,
+        features: entitlements?.features,
+      },
+      processedAt: new Date(),
+    });
+
+    return entitlements;
+  }
+
+  async createOverride(
+    payload: CreateBillingOverrideInput,
+    createdByUserId?: ObjectId
+  ): Promise<BillingEntitlementsDocument | null> {
+    await this.repository.createOverride({
+      organisationId: this.getRequiredOrganisationId(),
+      createdByUserId,
+      reason: payload.reason,
+      features: payload.features,
+      expiresAt: payload.expiresAt ? new Date(payload.expiresAt) : undefined,
+      isActive: payload.isActive,
+    });
+
+    return this.recalculateEntitlements("manual-override");
+  }
+
+  private async resolveOrganisationIdFromStripeEntities(input: {
+    metadataOrgId?: string;
+    subscriptionId?: string;
+    customerId?: string;
+  }): Promise<ObjectId | null> {
+    if (input.metadataOrgId && ObjectId.isValid(input.metadataOrgId)) {
+      return new ObjectId(input.metadataOrgId);
+    }
+
+    const globalRepository = new BillingRepository({});
+
+    if (input.subscriptionId) {
+      const bySubscription = await globalRepository.findAccountBySubscriptionId(
+        input.subscriptionId
+      );
+      if (bySubscription?.organisationId) {
+        return bySubscription.organisationId;
+      }
+    }
+
+    if (input.customerId) {
+      const byCustomer = await globalRepository.findAccountByCustomerId(input.customerId);
+      if (byCustomer?.organisationId) {
+        return byCustomer.organisationId;
+      }
+    }
+
+    return null;
+  }
+
+  async handleStripeWebhook(rawBody: Buffer, signature: string): Promise<{ received: true }> {
+    const stripe = this.getStripeClient();
+    const webhookSecret = AppConfig.STRIPE_WEBHOOK_SECRET;
+    if (!webhookSecret) {
+      throw new Error("Stripe webhook is not configured: STRIPE_WEBHOOK_SECRET is missing");
+    }
+
+    const event = stripe.webhooks.constructEvent(rawBody, signature, webhookSecret);
+    const globalRepository = new BillingRepository({});
+    const eventLogId = await globalRepository.createGlobalEventLog({
+      source: "webhook",
+      eventType: event.type,
+      eventId: event.id,
+      status: "received",
+      payload: {
+        id: event.id,
+        type: event.type,
+        object: event.data.object.object,
+      },
+    });
+
+    try {
+      if (event.type === "checkout.session.completed") {
+        const session = event.data.object as Stripe.Checkout.Session;
+        const organisationId = await this.resolveOrganisationIdFromStripeEntities({
+          metadataOrgId: session.metadata?.organisationId,
+          subscriptionId:
+            typeof session.subscription === "string"
+              ? session.subscription
+              : session.subscription?.id,
+          customerId:
+            typeof session.customer === "string" ? session.customer : session.customer?.id,
+        });
+
+        if (organisationId) {
+          const scopedRepository = new BillingRepository({ organisationId });
+          await scopedRepository.upsertBillingAccount({
+            stripeCustomerId:
+              typeof session.customer === "string"
+                ? session.customer
+                : session.customer?.id,
+            stripeSubscriptionId:
+              typeof session.subscription === "string"
+                ? session.subscription
+                : session.subscription?.id,
+            status: "active",
+            stripeCheckoutSessionId: session.id,
+          });
+
+          const subscriptionId =
+            typeof session.subscription === "string"
+              ? session.subscription
+              : session.subscription?.id;
+          if (subscriptionId) {
+            const subscription = await stripe.subscriptions.retrieve(subscriptionId);
+            await this.syncSubscriptionToAccount(subscription, organisationId);
+          } else {
+            const scopedService = new BillingService({ organisationId });
+            await scopedService.recalculateEntitlements("checkout-session-completed");
+          }
+        }
+      }
+
+      if (
+        event.type === "customer.subscription.created" ||
+        event.type === "customer.subscription.updated" ||
+        event.type === "customer.subscription.deleted"
+      ) {
+        const subscription = event.data.object as Stripe.Subscription;
+        const organisationId = await this.resolveOrganisationIdFromStripeEntities({
+          metadataOrgId: subscription.metadata?.organisationId,
+          subscriptionId: subscription.id,
+          customerId:
+            typeof subscription.customer === "string"
+              ? subscription.customer
+              : subscription.customer.id,
+        });
+
+        if (organisationId) {
+          await this.syncSubscriptionToAccount(subscription, organisationId);
+        }
+      }
+
+      await globalRepository.markEventProcessed(eventLogId);
+      return { received: true };
+    } catch (error) {
+      const errorMessage = error instanceof Error ? error.message : String(error);
+      await globalRepository.markEventFailed(eventLogId, errorMessage);
+      throw error;
+    }
+  }
+}
