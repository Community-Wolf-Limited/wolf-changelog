+export async function loadActivePatrolGrant(
+  staffId: string,
+  organizationId: string
+): Promise<LoadedPatrolGrant | null> {
+  const filter: Record<string, unknown> = {
+    staffId: new Types.ObjectId(staffId),
+    organizationId: new Types.ObjectId(organizationId),
+    status: "active",
+  };
+  const now = new Date();
+  const doc = await DevicePermissionGrantModel.findOne(filter)
+    .sort({ updatedAt: -1 })
+    .lean<DevicePermissionGrantDocument | null>();
+
+  if (!doc) return null;
+  if (doc.expiresAt && doc.expiresAt < now) return null;
+  const needsDeviceAcknowledgment =
+    doc.status === "active" && doc.requiresDeviceAck === true && doc.deviceAcknowledgedAt == null;
+  const trackingMode: DeviceGrantTrackingMode =
+    doc.trackingMode === "patrol_only" ? "patrol_only" : "always";
+  return {
+    grantId: doc._id.toString(),
+    scope: doc.scope,
+    grantVersion: doc.grantVersion,
+    status: doc.status,
+    expiresAt: doc.expiresAt ?? null,
+    needsDeviceAcknowledgment,
+    trackingMode,
+    raw: doc,
