+import { Request, Response, Router } from "express";
+import { ObjectId } from "mongodb";
+import { UserRole } from "../user/user.type.js";
+import {
+  createBillingOverrideSchema,
+  createCheckoutDraftSchema,
+  createCheckoutSessionSchema,
+  createPortalSessionSchema,
+  regenerateCheckoutSessionSchema,
+  recalculateEntitlementsSchema,
+} from "./billing.type.js";
+import { BillingService } from "./billing.service.js";
+
+const billingRouter = Router({ mergeParams: true });
+
+interface BillingRequest extends Request {
+  params: Request["params"] & { organisationId: string };
+}
+
+function createBillingServiceForRequest(req: BillingRequest): BillingService {
+  return new BillingService({ organisationId: req.params.organisationId });
+}
+
+function getUserRole(req: Request): UserRole | null {
+  try {
+    return req.container.resolve<UserRole>("userRole");
+  } catch {
+    return null;
+  }
+}
+
+function getResolvedUserId(req: Request): ObjectId | undefined {
+  try {
+    const resolved = req.container.resolve<ObjectId | string>("userId");
+    if (resolved instanceof ObjectId) {
+      return resolved;
+    }
+    if (typeof resolved === "string" && ObjectId.isValid(resolved)) {
+      return new ObjectId(resolved);
+    }
+    return undefined;
+  } catch {
+    return undefined;
+  }
+}
+
+function ensureAdminForWrite(req: Request, res: Response): boolean {
+  const userRole = getUserRole(req);
+  if (userRole !== UserRole.ADMIN) {
+    res.status(403).json({
+      message: "Only organisation admins can change billing settings",
+    });
+    return false;
+  }
+  return true;
+}
+
+function handleRouteError(error: unknown, res: Response): void {
+  const message = error instanceof Error ? error.message : "Unknown billing error";
+  res.status(400).json({ message });
+}
+
+billingRouter.get("/summary", async (req: BillingRequest, res: Response) => {
+  try {
+    const billingService = createBillingServiceForRequest(req);
+    const summary = await billingService.getSummaryView();
+    res.status(200).json(summary);
+  } catch (error) {
+    handleRouteError(error, res);
+  }
+});
+
+billingRouter.get("/entitlements", async (req: BillingRequest, res: Response) => {
+  try {
+    const billingService = createBillingServiceForRequest(req);
+    const entitlements = await billingService.getEntitlementItems();
+    res.status(200).json(entitlements);
+  } catch (error) {
+    handleRouteError(error, res);
+  }
+});
+
+billingRouter.post("/checkout-draft", async (req: BillingRequest, res: Response) => {
+  if (!ensureAdminForWrite(req, res)) {
+    return;
+  }
+
+  try {
+    const input = createCheckoutDraftSchema.parse(req.body);
+    const billingService = createBillingServiceForRequest(req);
+    const userId = getResolvedUserId(req);
+    const draft = await billingService.createCheckoutDraft(input, userId);
+    res.status(201).json({
+      draftId: draft._id?.toString(),
+      draft,
+    });
+  } catch (error) {
+    handleRouteError(error, res);
+  }
+});
+
+billingRouter.post("/checkout-session", async (req: BillingRequest, res: Response) => {
+  if (!ensureAdminForWrite(req, res)) {
+    return;
+  }
+
+  try {
+    const input = createCheckoutSessionSchema.parse(req.body);
+    const billingService = createBillingServiceForRequest(req);
+    const session = await billingService.createCheckoutSession(input);
+    res.status(201).json(session);
+  } catch (error) {
+    handleRouteError(error, res);
+  }
+});
+
+billingRouter.post(
+  "/checkout-session/regenerate",
+  async (req: BillingRequest, res: Response) => {
+    if (!ensureAdminForWrite(req, res)) {
+      return;
+    }
+
+    try {
+      const input = regenerateCheckoutSessionSchema.parse(req.body);
+      const billingService = createBillingServiceForRequest(req);
+      const session = await billingService.regenerateCheckoutSession(input);
+      res.status(201).json(session);
+    } catch (error) {
+      handleRouteError(error, res);
+    }
+  }
+);
+
+billingRouter.post("/portal-session", async (req: BillingRequest, res: Response) => {
+  if (!ensureAdminForWrite(req, res)) {
+    return;
+  }
+
+  try {
+    const input = createPortalSessionSchema.parse(req.body);
+    const billingService = createBillingServiceForRequest(req);
+    const session = await billingService.createPortalSession(input);
+    res.status(201).json(session);
+  } catch (error) {
+    handleRouteError(error, res);
+  }
+});
+
+billingRouter.post("/recalculate", async (req: BillingRequest, res: Response) => {
+  if (!ensureAdminForWrite(req, res)) {
+    return;
+  }
+
+  try {
+    const input = recalculateEntitlementsSchema.parse(req.body);
+    const billingService = createBillingServiceForRequest(req);
+    const entitlements = await billingService.recalculateEntitlements(
+      input.reason ?? "manual-recalculate"
+    );
+    res.status(200).json(entitlements);
+  } catch (error) {
+    handleRouteError(error, res);
+  }
+});
+
+billingRouter.post("/overrides", async (req: BillingRequest, res: Response) => {
+  if (!ensureAdminForWrite(req, res)) {
+    return;
+  }
+
+  try {
+    const input = createBillingOverrideSchema.parse(req.body);
+    const billingService = createBillingServiceForRequest(req);
+    const userId = getResolvedUserId(req);
+    const entitlements = await billingService.createOverride(input, userId);
+    res.status(201).json(entitlements);
+  } catch (error) {
+    handleRouteError(error, res);
+  }
+});
+
+export default billingRouter;
diff --git a/server/billing/billing.service.ts b/server/billing/billing.service.ts
new file mode 100644
index 0000000..1f573aa
--- /dev/null
+++ b/server/billing/billing.service.ts
@@ -0,0 +1,962 @@
+import Stripe from "stripe";
+import { ObjectId } from "mongodb";
+import { AppConfig } from "../config.js";
+import { BillingRepository } from "./billing.repository.js";
+import {
+  BillingAccountDocument,
+  BillingCatalogItem,
+  BillingCatalogKey,
+  BillingCheckoutDraftDocument,
+  BillingCheckoutLineItemInput,
+  BillingEntitlementsDocument,
+  BillingFeatures,
+  BillingOverrideDocument,
+  BillingSummaryResponse,
+  BillingSummaryView,
+  CreateBillingOverrideInput,
+  CreateCheckoutDraftInput,
+  CreateCheckoutSessionInput,
+  CreatePortalSessionInput,
+  RegenerateCheckoutSessionInput,
+} from "./billing.type.js";
+
+const PRODUCT_CODE_TO_CATALOG_KEY: Record<
+  BillingCheckoutLineItemInput["productCode"],
+  BillingCatalogKey
+> = {
+  platform: "platform-base",
+  "platform-additional-seat": "platform-additional-seat",
+  intelligence: "intelligence",
+  "access-control": "access-control",
+  "patrol-management": "patrol-management",
+  "group-agents": "group-agents",
+};
+
+const ACCESS_CONTROL_SKILLS = [
+  "log_license_disc",
+  "log_licence_disc",
+  "log_license_disc_and_person_info",
+  "log_licence_disc_and_person_info",
+  "log_person_info",
+  "log_person_information",
+  "check_license_plate",
+  "check_licence_plate",
+] as const;
+
+const PATROL_SKILL_REGEX = /patrol/i;
+
+const ENTITLEMENT_LABELS = {
+  platform: "Platform",
+  intelligence: "Intelligence",
+  accessControl: "Access Control",
+  patrolManagement: "Patrol Management",
+  groupAgents: "Group Agents",
+} as const;
+
+type LineItemQuantities = Partial<Record<BillingCatalogKey, number>>;
+
+function normalizeSubscriptionStatus(
+  status: string | null | undefined
+): BillingAccountDocument["status"] {
+  const fallback: BillingAccountDocument["status"] = "none";
+  if (!status) {
+    return fallback;
+  }
+
+  const allowedStatuses = new Set<BillingAccountDocument["status"]>([
+    "none",
+    "trialing",
+    "active",
+    "past_due",
+    "canceled",
+    "incomplete",
+    "incomplete_expired",
+    "unpaid",
+  ]);
+
+  if (allowedStatuses.has(status as BillingAccountDocument["status"])) {
+    return status as BillingAccountDocument["status"];
+  }
+
+  return fallback;
+}
+
+export class BillingService {
+  private readonly organisationId?: ObjectId;
+  private readonly repository: BillingRepository;
+  private readonly stripe: Stripe | null;
+
+  constructor({ organisationId }: { organisationId?: ObjectId | string } = {}) {
+    if (typeof organisationId === "string") {
+      this.organisationId = new ObjectId(organisationId);
+    } else {
+      this.organisationId = organisationId;
+    }
+
+    this.repository = new BillingRepository({ organisationId: this.organisationId });
+    this.stripe = AppConfig.STRIPE_SECRET_KEY
+      ? new Stripe(AppConfig.STRIPE_SECRET_KEY)
+      : null;
+  }
+
+  private getRequiredOrganisationId(): ObjectId {
+    if (!this.organisationId) {
+      throw new Error("Organisation ID is required for this billing operation");
+    }
+    return this.organisationId;
+  }
+
+  private getStripeClient(): Stripe {
+    if (!this.stripe) {
+      throw new Error("Stripe billing is not configured: STRIPE_SECRET_KEY is missing");
+    }
+    return this.stripe;
+  }
+
+  private buildLineItemQuantities(
+    lineItems: readonly BillingCheckoutLineItemInput[]
+  ): LineItemQuantities {
+    const quantities: LineItemQuantities = {};
+
+    for (const item of lineItems) {
+      const quantity =
+        item.productCode === "platform"
+          ? 1
+          : Math.max(0, Math.floor(item.quantity));
+      if (quantity <= 0) {
+        continue;
+      }
+      const catalogKey = PRODUCT_CODE_TO_CATALOG_KEY[item.productCode];
+      quantities[catalogKey] = (quantities[catalogKey] ?? 0) + quantity;
+    }
+
+    if ((quantities["platform-base"] ?? 0) <= 0) {
+      throw new Error("Platform is required for checkout");
+    }
+
+    return quantities;
+  }
+
+  private buildSummaryLineItems(
+    lineItemQuantities: LineItemQuantities,
+    catalogMap: Map<BillingCatalogKey, BillingCatalogItem>
+  ) {
+    return (Object.entries(lineItemQuantities) as Array<
+      [BillingCatalogKey, number | undefined]
+    >)
+      .filter(([, quantity]) => Boolean(quantity && quantity > 0))
+      .map(([key, quantity]) => {
+        const item = catalogMap.get(key);
+        return {
+          code: key,
+          label: item?.name ?? key,
+          quantity: quantity ?? 0,
+          unitAmountCents: item?.unitAmount ?? 0,
+          totalAmountCents: (item?.unitAmount ?? 0) * (quantity ?? 0),
+        };
+      });
+  }
+
+  private async getCatalogMap(): Promise<Map<BillingCatalogKey, BillingCatalogItem>> {
+    await this.repository.ensureCatalogSeed();
+    const catalog = await this.repository.getCatalogItems();
+    const map = new Map<BillingCatalogKey, BillingCatalogItem>();
+    for (const item of catalog) {
+      map.set(item.key, item);
+    }
+    return map;
+  }
+
+  private computeSubtotal(
+    lineItemQuantities: LineItemQuantities,
+    catalogMap: Map<BillingCatalogKey, BillingCatalogItem>
+  ): number {
+    let subtotal = 0;
+    for (const [key, quantity] of Object.entries(lineItemQuantities) as Array<
+      [BillingCatalogKey, number | undefined]
+    >) {
+      if (!quantity || quantity <= 0) {
+        continue;
+      }
+      const item = catalogMap.get(key);
+      if (!item) {
+        continue;
+      }
+      subtotal += item.unitAmount * quantity;
+    }
+    return subtotal;
+  }
+
+  private async ensureStripePriceForCatalogItem(item: BillingCatalogItem): Promise<string> {
+    if (item.stripePriceId) {
+      return item.stripePriceId;
+    }
+
+    const stripe = this.getStripeClient();
+
+    const product = await stripe.products.create({
+      name: item.name,
+      description: item.description,
+      metadata: {
+        ...item.metadata,
+        billingCatalogKey: item.key,
+      },
+    });
+
+    const price = await stripe.prices.create({
+      product: product.id,
+      currency: "zar",
+      unit_amount: item.unitAmount,
+      recurring: { interval: "month" },
+      metadata: {
+        ...item.metadata,
+        billingCatalogKey: item.key,
+      },
+    });
+
+    await this.repository.updateCatalogStripeIds(item.key, product.id, price.id);
+    return price.id;
+  }
+
+  private async ensureStripeLineItems(
+    lineItemQuantities: LineItemQuantities
+  ): Promise<Array<{ price: string; quantity: number }>> {
+    const catalogMap = await this.getCatalogMap();
+    const stripeLineItems: Array<{ price: string; quantity: number }> = [];
+
+    for (const [key, quantity] of Object.entries(lineItemQuantities) as Array<
+      [BillingCatalogKey, number | undefined]
+    >) {
+      if (!quantity || quantity <= 0) {
+        continue;
+      }
+      const catalogItem = catalogMap.get(key);
+      if (!catalogItem) {
+        continue;
+      }
+      const priceId = await this.ensureStripePriceForCatalogItem(catalogItem);
+      stripeLineItems.push({ price: priceId, quantity });
+    }
+
+    return stripeLineItems;
+  }
+
+  private getReturnUrl(
+    explicitUrl: string | undefined,
+    fallback: string | undefined,
+    configUrl: string | undefined
+  ): string {
+    const resolved = explicitUrl ?? fallback ?? configUrl;
+    if (!resolved) {
+      throw new Error("Missing billing return URL for Stripe session");
+    }
+    return resolved;
+  }
+
+  private toOptionalTrimmedString(value: string | null | undefined): string | undefined {
+    if (typeof value !== "string") {
+      return undefined;
+    }
+    const trimmed = value.trim();
+    return trimmed.length > 0 ? trimmed : undefined;
+  }
+
+  private async ensureStripeCustomer(
+    account: BillingAccountDocument | null
+  ): Promise<string> {
+    const stripe = this.getStripeClient();
+    const organisationId = this.getRequiredOrganisationId();
+    const organisation = await this.repository.getOrganisationBillingProfile();
+    const customerName = this.toOptionalTrimmedString(organisation?.clientName);
+    const customerEmail = this.toOptionalTrimmedString(organisation?.clientEmail);
+
+    if (account?.stripeCustomerId) {
+      await stripe.customers.update(account.stripeCustomerId, {
+        name: customerName,
+        email: customerEmail,
+        metadata: {
+          organisationId: organisationId.toString(),
+        },
+      });
+      return account.stripeCustomerId;
+    }
+
+    const customer = await stripe.customers.create({
+      name: customerName,
+      email: customerEmail,
+      metadata: { organisationId: organisationId.toString() },
+    });
+    return customer.id;
+  }
+
+  private applyOverridesToFeatures(
+    features: BillingFeatures,
+    overrides: BillingOverrideDocument[]
+  ): BillingFeatures {
+    const nextFeatures: BillingFeatures = { ...features };
+    for (const override of overrides) {
+      if (override.features.intelligence !== undefined) {
+        nextFeatures.intelligence = override.features.intelligence;
+      }
+      if (override.features.accessControl !== undefined) {
+        nextFeatures.accessControl = override.features.accessControl;
+      }
+      if (override.features.patrolManagement !== undefined) {
+        nextFeatures.patrolManagement = override.features.patrolManagement;
+      }
+      if (override.features.groupAgents !== undefined) {
+        nextFeatures.groupAgents = override.features.groupAgents;
+      }
+    }
+    return nextFeatures;
+  }
+
+  private async getUsageSnapshot() {
+    const [platformUsers, accessControlUsers, patrolUsers, activeAgentGroups] =
+      await Promise.all([
+        this.repository.countPlatformUsers(),
+        this.repository.countStaffBySkills(Array.from(ACCESS_CONTROL_SKILLS)),
+        this.repository.countStaffByRegex(PATROL_SKILL_REGEX),
+        this.repository.countActiveAgentGroups(),
+      ]);
+
+    return {
+      platformUsers,
+      accessControlUsers,
+      patrolUsers,
+      activeAgentGroups,
+    };
+  }
+
+  private calculateEntitlementsFromAccount(
+    account: BillingAccountDocument | null,
+    overrides: BillingOverrideDocument[]
+  ): Omit<BillingEntitlementsDocument, "_id" | "updatedAt"> {
+    const lineItems = account?.lineItemQuantities ?? {};
+    const platformQuantity = lineItems["platform-base"] ?? 0;
+    const additionalSeatQuantity = lineItems["platform-additional-seat"] ?? 0;
+    let platform = platformQuantity > 0;
+    let includedSeats = platformQuantity * 2;
+    let additionalSeats = additionalSeatQuantity;
+    let maxSeats = includedSeats + additionalSeats;
+
+    let features: BillingFeatures = {
+      intelligence: (lineItems["intelligence"] ?? 0) > 0,
+      accessControl: (lineItems["access-control"] ?? 0) > 0,
+      patrolManagement: (lineItems["patrol-management"] ?? 0) > 0,
+      groupAgents: (lineItems["group-agents"] ?? 0) > 0,
+    };
+
+    for (const override of overrides) {
+      if (override.features.platform !== undefined) {
+        platform = override.features.platform;
+      }
+      if (override.features.maxSeats !== undefined) {
+        maxSeats = override.features.maxSeats;
+      }
+    }
+
+    features = this.applyOverridesToFeatures(features, overrides);
+
+    if (!platform && !overrides.some((item) => item.features.maxSeats !== undefined)) {
+      includedSeats = 0;
+      additionalSeats = 0;
+      maxSeats = 0;
+    }
+
+    return {
+      organisationId: this.getRequiredOrganisationId(),
+      source: "computed",
+      platform,
+      includedSeats,
+      additionalSeats,
+      maxSeats,
+      features,
+      overridden: overrides.length > 0,
+      overrideIds: overrides
+        .map((override) => override._id)
+        .filter((value): value is ObjectId => Boolean(value)),
+      computedAt: new Date(),
+    };
+  }
+
+  private async mapSubscriptionToLineItems(
+    subscription: Stripe.Subscription
+  ): Promise<LineItemQuantities> {
+    const catalogItems = await this.repository.getCatalogItems();
+    const catalogByPrice = new Map<string, BillingCatalogKey>();
+    for (const item of catalogItems) {
+      if (item.stripePriceId) {
+        catalogByPrice.set(item.stripePriceId, item.key);
+      }
+    }
+
+    const lineItems: LineItemQuantities = {};
+    for (const item of subscription.items.data) {
+      const key = catalogByPrice.get(item.price.id);
+      if (!key) {
+        continue;
+      }
+      const quantity = item.quantity ?? 1;
+      lineItems[key] = (lineItems[key] ?? 0) + quantity;
+    }
+
+    return lineItems;
+  }
+
+  private async syncSubscriptionToAccount(
+    subscription: Stripe.Subscription,
+    organisationId: ObjectId
+  ): Promise<void> {
+    const scopedRepository = new BillingRepository({ organisationId });
+    await scopedRepository.ensureCatalogSeed();
+    const lineItems = await this.mapSubscriptionToLineItems(subscription);
+    const platformQty = lineItems["platform-base"] ?? 0;
+    const additionalSeats = lineItems["platform-additional-seat"] ?? 0;
+    const seatCount = platformQty * 2 + additionalSeats;
+    const currentPeriodEndEpoch = subscription.items.data.reduce(
+      (latest, item) => Math.max(latest, item.current_period_end ?? 0),
+      0
+    );
+
+    await scopedRepository.upsertBillingAccount({
+      stripeCustomerId:
+        typeof subscription.customer === "string"
+          ? subscription.customer
+          : subscription.customer.id,
+      stripeSubscriptionId: subscription.id,
+      status: normalizeSubscriptionStatus(subscription.status),
+      currentPeriodEnd:
+        currentPeriodEndEpoch > 0
+          ? new Date(currentPeriodEndEpoch * 1000)
+          : undefined,
+      lineItemQuantities: lineItems,
+      seatCount,
+      lastSyncedAt: new Date(),
+    });
+
+    const scopedService = new BillingService({ organisationId });
+    await scopedService.recalculateEntitlements("stripe-subscription-sync");
+  }
+
+  async getSummary(): Promise<BillingSummaryResponse> {
+    await this.repository.ensureCatalogSeed();
+    const [account, entitlements, latestDraft] = await Promise.all([
+      this.repository.getBillingAccount(),
+      this.repository.getEntitlements(),
+      this.repository.getLatestCheckoutDraft(),
+    ]);
+
+    return { account, entitlements, latestDraft };
+  }
+
+  async getEntitlements(): Promise<BillingEntitlementsDocument | null> {
+    const existingEntitlements = await this.repository.getEntitlements();
+    if (existingEntitlements) {
+      return existingEntitlements;
+    }
+
+    return this.recalculateEntitlements("initial-bootstrap");
