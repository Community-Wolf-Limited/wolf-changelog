+/**
+ * Approve and apply a pending patrol change proposal (control room). Verifies payload hash when present.
+ */
+export async function applyPatrolChangeProposal(
+  proposalId: string,
+  organizationId: string,
+  reviewerUserId: string
+): Promise<{ ok: true; proposal: unknown } | { ok: false; error: ApplyProposalError }> {
+  const p = await PatrolChangeProposalModel.findOne({
+    _id: new Types.ObjectId(proposalId),
+    organizationId: new Types.ObjectId(organizationId),
+    status: "pending",
+  });
+  if (!p) return { ok: false, error: "not_found" };
+
+  const payload: Record<string, unknown> = p.payload;
+  if (p.payloadCanonicalHash) {
+    const h = canonicalJsonHash(payload);
+    if (h !== p.payloadCanonicalHash) return { ok: false, error: "hash_mismatch" };
+  }
+
+  const orgOid = new Types.ObjectId(organizationId);
+  const reviewerOid = new Types.ObjectId(reviewerUserId);
+  const staffOid = p.staffId;
+
+  try {
+    const step = await dispatchProposalApply(p, payload, organizationId, orgOid, reviewerOid, staffOid);
+    if ("error" in step) {
+      return { ok: false, error: step.error };
+    }
+    const newTargetId = step.newTargetId;
+
+    p.status = "applied";
+    p.reviewedByUserId = reviewerOid;
+    p.reviewedAt = new Date();
+    p.appliedAt = new Date();
+    if (newTargetId) p.targetEntityId = new Types.ObjectId(newTargetId);
+    await p.save();
+
+    await appendPatrolFieldAudit({
+      organizationId,
+      eventType: "proposal_applied",
+      actorUserId: reviewerOid,
+      proposalId: p._id,
+      metadata: { entity: p.entity, action: p.action },
+    });
+
+    return { ok: true, proposal: p.toObject() };
+  } catch (e) {
+    console.error("applyPatrolChangeProposal", e);
+    return { ok: false, error: "apply_failed" };
+  }
