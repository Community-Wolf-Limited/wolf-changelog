+  orgOid: Types.ObjectId,
+  reviewerOid: Types.ObjectId
+): Promise<ProposalStepResult> {
+  const tid = resolveProposalTargetId(p, payload);
+  if (!tid) return { error: "bad_payload" };
+  const patrol = await PatrolModel.findOne({ _id: new Types.ObjectId(tid), organizationId: orgOid });
+  if (!patrol) return { error: "not_found" };
+  patrol.deletedAt = new Date();
+  patrol.deletedByUserId = reviewerOid;
+  patrol.deletionReason = typeof payload.reason === "string" ? payload.reason : "proposal_deleted";
+  patrol.isActive = false;
+  await patrol.save();
+  await appendPatrolFieldAudit({
+    organizationId,
+    eventType: "soft_delete",
+    actorUserId: reviewerOid,
