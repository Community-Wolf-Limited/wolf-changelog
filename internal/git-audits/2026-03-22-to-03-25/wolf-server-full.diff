+
+function getMobileCreatorUserId(): Types.ObjectId {
+  const mobileCreator = process.env.MOBILE_CREATOR_USER_ID;
+  if (mobileCreator) return new Types.ObjectId(mobileCreator);
+  return new Types.ObjectId("000000000000000000000000");
+}
+
+function resolveProposalTargetId(
+  proposal: { targetEntityId?: Types.ObjectId | null },
+  payload: Record<string, unknown>
+): string | null {
+  if (proposal.targetEntityId) return proposal.targetEntityId.toString();
+  const t = payload.targetId ?? payload._id ?? payload.id;
+  if (typeof t === "string" && /^[a-fA-F0-9]{24}$/.test(t)) return t;
+  return null;
+}
+
+export type ApplyProposalError =
+  | "not_found"
+  | "hash_mismatch"
+  | "bad_payload"
+  | "unsupported"
+  | "apply_failed";
+
+type ProposalStepResult = { newTargetId?: string } | { error: ApplyProposalError };
+
+type NormalizedRouteCheckpoint = {
+  number: number;
+  name: string;
+  description: string;
+  location: { latitude: number; longitude: number };
+  estimatedTimeMinutes: number;
+  instructions: string;
+  terrainType: TerrainType;
+  walkingSpeedKmh: number;
+  radiusMeters: number;
+};
+
+function normalizeRouteCheckpointsFromPayload(checkpoints: unknown[]): NormalizedRouteCheckpoint[] {
+  const cps = checkpoints as { name?: string; latitude?: number; longitude?: number; radiusMeters?: number }[];
+  return cps.map((cp, i) => ({
+    number: i + 1,
+    name: cp.name || `Checkpoint ${i + 1}`,
+    description: "",
+    location: { latitude: Number(cp.latitude), longitude: Number(cp.longitude) },
+    estimatedTimeMinutes: 2,
+    instructions: "",
+    terrainType: TerrainType.FLAT,
+    walkingSpeedKmh: 4,
+    radiusMeters: cp.radiusMeters ?? 10,
+  }));
+}
+
+function buildRouteSegmentsAndStats(normalizedCheckpoints: NormalizedRouteCheckpoint[]) {
+  let totalDistance = 0;
+  const routeSegments: {
+    from: number;
+    to: number;
+    distance: number;
+    terrainType: string;
+    walkingSpeedKmh: number;
+    estimatedTimeMinutes: number;
+    coordinates: [number, number][];
+  }[] = [];
+  for (let i = 0; i < normalizedCheckpoints.length - 1; i++) {
+    const from = normalizedCheckpoints[i].location;
+    const to = normalizedCheckpoints[i + 1].location;
+    const dist = calculateDistance(from.latitude, from.longitude, to.latitude, to.longitude) * 1000;
+    totalDistance += dist;
+    routeSegments.push({
+      from: i + 1,
+      to: i + 2,
+      distance: dist,
+      terrainType: TerrainType.FLAT,
+      walkingSpeedKmh: 4,
+      estimatedTimeMinutes: Math.ceil((dist / 1000) / (4 / 60)),
+      coordinates: [
+        [from.longitude, from.latitude],
+        [to.longitude, to.latitude],
+      ],
+    });
+  }
+  const totalWalkingTime = routeSegments.reduce((s, r) => s + r.estimatedTimeMinutes, 0);
+  const stats = {
+    totalDistance,
+    totalWalkingTime,
+    totalStationaryTime: normalizedCheckpoints.length * 2,
+    totalTime: totalWalkingTime + normalizedCheckpoints.length * 2,
+    totalSteps: Math.ceil(totalDistance / 0.7),
+    areaSize: 0,
+    averageSpeed: 4,
+    checkpointCount: normalizedCheckpoints.length,
+    dominantTerrain: TerrainType.FLAT,
+  };
+  return { routeSegments, stats };
+}
+
+async function applySiteCreateStep(
+  payload: Record<string, unknown>,
+  orgOid: Types.ObjectId,
+  staffOid: Types.ObjectId,
+  deviceId: string | undefined
+): Promise<ProposalStepResult> {
+  const siteName = payload.siteName;
+  const lat = payload.latitude;
+  const lng = payload.longitude;
+  if (typeof siteName !== "string" || lat == null || lng == null) {
+    return { error: "bad_payload" };
+  }
+  const address = `GPS: ${Number(lat).toFixed(6)}, ${Number(lng).toFixed(6)}`;
+  const site = await Site.create({
+    siteName: siteName.trim(),
+    clientId: orgOid,
+    location: { address, latitude: Number(lat), longitude: Number(lng) },
+    createdByStaffId: staffOid,
+    sourceDeviceId: deviceId,
+    ...(typeof payload.description === "string" && payload.description.trim()
+      ? { description: payload.description.trim() }
+      : {}),
+  });
+  return { newTargetId: site._id.toString() };
+}
+
+async function applySiteDeleteStep(
+  p: PatrolChangeProposalDocument,
+  payload: Record<string, unknown>,
+  organizationId: string,
+  orgOid: Types.ObjectId,
+  reviewerOid: Types.ObjectId
+): Promise<ProposalStepResult> {
+  const tid = resolveProposalTargetId(p, payload);
+  if (!tid) return { error: "bad_payload" };
+  const site = await Site.findOne({ _id: new Types.ObjectId(tid), clientId: orgOid });
+  if (!site) return { error: "not_found" };
+  site.deletedAt = new Date();
+  site.deletedByUserId = reviewerOid;
+  site.deletionReason = typeof payload.reason === "string" ? payload.reason : "proposal_deleted";
+  site.lastUpdated = new Date();
+  await site.save();
+  await appendPatrolFieldAudit({
+    organizationId,
+    eventType: "soft_delete",
+    actorUserId: reviewerOid,
+    proposalId: p._id,
+    metadata: { entity: "site", entityId: tid },
+  });
+  return {};
+}
+
+async function applyPatrolRouteCreateStep(
+  payload: Record<string, unknown>,
+  orgOid: Types.ObjectId,
+  staffOid: Types.ObjectId,
+  deviceId: string | undefined
+): Promise<ProposalStepResult> {
+  const name = payload.name;
+  const siteId = payload.siteId;
+  const checkpoints = payload.checkpoints;
+  const description = payload.description;
+  if (
+    typeof name !== "string" ||
+    typeof siteId !== "string" ||
+    !Array.isArray(checkpoints) ||
+    checkpoints.length < 1
+  ) {
+    return { error: "bad_payload" };
+  }
+  const creatorId = getMobileCreatorUserId();
+  const displayOptions = {
+    showConnectingLines: true,
+    closeLoop: false,
+    showDistanceLabels: false,
+    showRouteStats: true,
+    showAnimatedLines: true,
+    showCheckpointIcons: true,
+    showSegmentDetails: false,
+    showTerrainColors: true,
+    followRoad: true,
+  };
+  const normalizedCheckpoints = normalizeRouteCheckpointsFromPayload(checkpoints);
+  const { routeSegments, stats } = buildRouteSegmentsAndStats(normalizedCheckpoints);
+  const routeType =
+    payload.routeType === "linear" || payload.routeType === "circular" ? payload.routeType : "linear";
+  const routePayload: Record<string, unknown> = {
+    name: name.trim(),
+    description:
+      typeof description === "string" && description.trim() ? description.trim() : name.trim(),
+    clientId: orgOid,
+    siteId: new Types.ObjectId(siteId),
+    routeType,
+    checkpoints: normalizedCheckpoints,
+    displayOptions,
+    routeSegments,
+    stats,
+    createdBy: creatorId,
+    updatedBy: creatorId,
+    createdByStaffId: staffOid,
+    sourceDeviceId: deviceId,
+  };
+  const patrolMode = payload.patrolMode;
+  if (patrolMode === "rigid" || patrolMode === "semi_rigid" || patrolMode === "random") {
+    routePayload.patrolMode = patrolMode;
+  }
+  if (payload.checkpointFlexibility && typeof payload.checkpointFlexibility === "object") {
+    routePayload.checkpointFlexibility = payload.checkpointFlexibility;
+  }
+  const route = await PatrolRoute.create(routePayload);
+  return { newTargetId: route._id.toString() };
+}
+
+async function applyPatrolRouteDeleteStep(
+  p: PatrolChangeProposalDocument,
+  payload: Record<string, unknown>,
+  organizationId: string,
+  orgOid: Types.ObjectId,
+  reviewerOid: Types.ObjectId
+): Promise<ProposalStepResult> {
+  const tid = resolveProposalTargetId(p, payload);
+  if (!tid) return { error: "bad_payload" };
+  const route = await PatrolRoute.findOne({ _id: new Types.ObjectId(tid), clientId: orgOid });
+  if (!route) return { error: "not_found" };
+  route.deletedAt = new Date();
+  route.deletedByUserId = reviewerOid;
+  route.deletionReason = typeof payload.reason === "string" ? payload.reason : "proposal_deleted";
+  await route.save();
+  await appendPatrolFieldAudit({
+    organizationId,
+    eventType: "soft_delete",
+    actorUserId: reviewerOid,
+    proposalId: p._id,
+    metadata: { entity: "patrol_route", entityId: tid },
+  });
+  return {};
+}
+
+async function applyPatrolScheduleDeleteStep(
+  p: PatrolChangeProposalDocument,
+  payload: Record<string, unknown>,
+  organizationId: string,
+  orgOid: Types.ObjectId,
+  reviewerOid: Types.ObjectId
+): Promise<ProposalStepResult> {
+  const tid = resolveProposalTargetId(p, payload);
+  if (!tid) return { error: "bad_payload" };
+  const row = await PatrolSchedule.findOne({ _id: new Types.ObjectId(tid), organizationId: orgOid });
+  if (!row) return { error: "not_found" };
+  row.deletedAt = new Date();
+  row.deletedByUserId = reviewerOid;
+  row.deletionReason = typeof payload.reason === "string" ? payload.reason : "proposal_deleted";
+  row.isActive = false;
