+
+export type PatrolFieldAuditEventType =
+  | "grant_created"
+  | "grant_approved"
+  | "grant_denied"
+  | "grant_revoked"
+  | "grant_device_acknowledged"
+  | "grant_version_bump"
+  | "proposal_created"
+  | "proposal_approved"
+  | "proposal_rejected"
+  | "proposal_applied"
+  | "soft_delete"
+  | "restore"
+  /** Device app created site via POST /device-auth/sites (direct write, not proposal flow). */
+  | "device_site_created"
+  /** Device app created route via POST /device-auth/patrol-routes. */
+  | "device_route_created"
+  /** Device app started patrol event via POST /device-auth/patrol-events. */
+  | "device_patrol_event_created"
+  /** Device app assigned staff to a patrol (org-wide grant). */
+  | "device_patrol_staff_assigned"
+  | "device_site_updated"
+  | "device_route_updated"
+  | "device_site_deleted"
+  | "device_route_deleted";
+
+export interface PatrolFieldAuditLogDocument {
+  _id: import("mongodb").ObjectId;
+  organizationId: import("mongodb").ObjectId;
+  eventType: PatrolFieldAuditEventType;
+  actorUserId?: import("mongodb").ObjectId | null;
+  actorStaffId?: import("mongodb").ObjectId | null;
+  deviceId?: string | null;
+  grantId?: import("mongodb").ObjectId | null;
+  proposalId?: import("mongodb").ObjectId | null;
+  fromVersion?: number | null;
+  toVersion?: number | null;
+  metadata?: Record<string, unknown>;
+  createdAt: Date;
+}
+
+const patrolFieldAuditSchema = new Schema<PatrolFieldAuditLogDocument>(
+  {
+    organizationId: { type: Schema.Types.ObjectId, required: true, ref: "Organisation", index: true },
+    eventType: { type: String, required: true, index: true },
+    actorUserId: { type: Schema.Types.ObjectId, ref: "User", default: null },
+    actorStaffId: { type: Schema.Types.ObjectId, ref: "Staff", default: null },
+    deviceId: { type: String, default: null },
+    grantId: { type: Schema.Types.ObjectId, default: null },
+    proposalId: { type: Schema.Types.ObjectId, default: null },
+    fromVersion: { type: Number, default: null },
+    toVersion: { type: Number, default: null },
+    metadata: { type: Schema.Types.Mixed, default: {} },
+    createdAt: { type: Date, default: Date.now, index: true },
+  },
+  {
+    collection: DbConfig.PATROL_FIELD_AUDIT_LOGS_COLLECTION,
+    autoIndex: false,
+  }
+);
+
+patrolFieldAuditSchema.index({ organizationId: 1, createdAt: -1 });
+
+const PatrolFieldAuditLogModel = db.model<PatrolFieldAuditLogDocument>(
+  "PatrolFieldAuditLog",
+  patrolFieldAuditSchema,
+  DbConfig.PATROL_FIELD_AUDIT_LOGS_COLLECTION
+);
+
+export default PatrolFieldAuditLogModel;
diff --git a/server/device-auth/patrol-field-governance.route.ts b/server/device-auth/patrol-field-governance.route.ts
