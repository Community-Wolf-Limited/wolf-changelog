+import { Types } from "mongoose";
+import StaffModel from "../schemas/staff.schema.js";
+import { getPatrolEventsSocketService } from "../patrol/events/patrol-socket-registry.js";
+import { sendExpoPushToStaffDevices } from "./push-notification.service.js";
+
+async function staffName(staffId: string): Promise<string> {
+  const s = await StaffModel.findById(staffId).select("name").lean();
+  return s?.name ?? "Guard";
+}
+
+export async function notifyPatrolConfigSiteCreated(params: {
+  organizationId: string;
+  staffId: string;
+  siteId: string;
+  siteName: string;
+}): Promise<void> {
+  const name = await staffName(params.staffId);
+  getPatrolEventsSocketService()?.emitPatrolGrantEvent(params.organizationId, "patrol-config:site-created", {
+    siteId: params.siteId,
+    siteName: params.siteName,
+    staffId: params.staffId,
+    staffName: name,
+    createdAt: new Date().toISOString(),
+  });
+}
+
+export async function notifyPatrolConfigRouteCreated(params: {
+  organizationId: string;
+  staffId: string;
+  routeId: string;
+  routeName: string;
+}): Promise<void> {
+  const name = await staffName(params.staffId);
+  getPatrolEventsSocketService()?.emitPatrolGrantEvent(params.organizationId, "patrol-config:route-created", {
+    routeId: params.routeId,
+    routeName: params.routeName,
+    staffId: params.staffId,
+    staffName: name,
+    createdAt: new Date().toISOString(),
+  });
+}
+
+export async function notifyPatrolGrantRequestCreated(params: {
+  organizationId: string;
+  staffId: string;
+  grantId: string;
+}): Promise<void> {
+  const name = await staffName(params.staffId);
+  getPatrolEventsSocketService()?.emitPatrolGrantEvent(params.organizationId, "patrol-grant:request-created", {
+    grantId: params.grantId,
+    staffId: params.staffId,
+    staffName: name,
+    requestedAt: new Date().toISOString(),
+  });
+}
+
+export async function notifyPatrolGrantApprovedForDevice(params: {
+  organizationId: string;
+  staffId: string;
+  grantId: string;
+}): Promise<void> {
+  await sendExpoPushToStaffDevices({
+    organizationId: params.organizationId,
+    staffId: params.staffId,
+    title: "Field access approved",
+    body: "Open Wolf Patrol and tap Accept on the Access tab.",
+    data: { type: "patrol_grant_approved", grantId: params.grantId },
+  });
+}
+
+export async function notifyPatrolGrantDeniedForDevice(params: {
+  organizationId: string;
+  staffId: string;
+}): Promise<void> {
+  await sendExpoPushToStaffDevices({
+    organizationId: params.organizationId,
+    staffId: params.staffId,
+    title: "Access request update",
+    body: "Your patrol field access request was not approved. Contact your control room.",
+    data: { type: "patrol_grant_denied" },
+  });
+}
+
+export async function notifyPatrolGrantRevokedForDevice(params: {
+  organizationId: string;
+  staffId: string;
+}): Promise<void> {
+  await sendExpoPushToStaffDevices({
+    organizationId: params.organizationId,
+    staffId: params.staffId,
+    title: "Field access revoked",
+    body: "Your patrol field access was revoked. Open the app for details.",
+    data: { type: "patrol_grant_revoked" },
+  });
+}
+
+export async function notifyPatrolGrantAcknowledgedForEnterprise(params: {
+  organizationId: string;
+  staffId: string;
+  grantId: Types.ObjectId | string;
+}): Promise<void> {
+  const name = await staffName(params.staffId);
+  getPatrolEventsSocketService()?.emitPatrolGrantEvent(params.organizationId, "patrol-grant:acknowledged", {
+    grantId: typeof params.grantId === "string" ? params.grantId : params.grantId.toString(),
+    staffId: params.staffId,
+    staffName: name,
+    acknowledgedAt: new Date().toISOString(),
+  });
+}
