diff --git a/server/scripts/compare-atlas-dev-prod-databases.ts b/server/scripts/compare-atlas-dev-prod-databases.ts
new file mode 100644
index 0000000..2748579
--- /dev/null
+++ b/server/scripts/compare-atlas-dev-prod-databases.ts
@@ -0,0 +1,179 @@
+/**
+ * One-shot Atlas inspection: compare collection names + estimated counts
+ * between *-development and *-production databases on the same cluster.
+ *
+ * Usage (from wolf-server):
+ *   npx tsx server/scripts/compare-atlas-dev-prod-databases.ts
+ *   npx tsx server/scripts/compare-atlas-dev-prod-databases.ts --names-only
+ *   npx tsx server/scripts/compare-atlas-dev-prod-databases.ts --filter=alert
+ *
+ * Env: any one Atlas SRV string for the cluster (same host for both DBs), e.g.
+ * DATABASE_URI, WOLF_PACK_DATABASE_URI, DATABASE_URI_PRODUCTION, MONGODB_URI.
+ * Loads .env from wolf-server/ when the script path is under server/scripts/.
+ */
+
+import { config } from "dotenv";
+import { dirname, resolve } from "node:path";
+import { fileURLToPath } from "node:url";
+import type { Db } from "mongodb";
+import { MongoClient } from "mongodb";
+
+const __dirname = dirname(fileURLToPath(import.meta.url));
+config({ path: resolve(__dirname, "../../.env") });
+
+const PAIRS: [string, string][] = [
+  ["enterprise-wolf-development", "enterprise-wolf-production"],
+  ["community-wolf-development", "community-wolf-production"],
+];
+
+function getUri(): string {
+  const candidates = [
+    process.env.MONGODB_URI,
+    process.env.DATABASE_URI,
+    process.env.WOLF_PACK_DATABASE_URI,
+    process.env.DATABASE_URI_PRODUCTION,
+    process.env.DATABASE_URI_DEVELOPMENT,
+    process.env.DATABASE_URI_DEV,
+  ];
+  for (const c of candidates) {
+    const s = (c ?? "").trim();
+    if (s.startsWith("mongodb://") || s.startsWith("mongodb+srv://")) {
+      return s;
+    }
+  }
+  return "";
+}
+
+function parseArgs() {
+  const argv = process.argv.slice(2);
+  let namesOnly = false;
+  let filterSubstr: string | null = null;
+  for (const a of argv) {
+    if (a === "--names-only" || a === "--no-counts") namesOnly = true;
+    if (a.startsWith("--filter=")) filterSubstr = a.slice("--filter=".length).toLowerCase();
+  }
+  return { namesOnly, filterSubstr };
+}
+
+function diff(a: string[], b: string[]) {
+  const setB = new Set(b);
+  const setA = new Set(a);
+  return {
+    onlyA: a.filter((x) => !setB.has(x)),
+    onlyB: b.filter((x) => !setA.has(x)),
+    both: a.filter((x) => setB.has(x)),
+  };
+}
+
+async function listSortedCollectionNames(db: Db, filterSubstr: string | null): Promise<string[]> {
+  const names = (await db.listCollections().toArray()).map((c) => c.name);
+  names.sort((a, b) => a.localeCompare(b));
+  if (!filterSubstr) {
+    return names;
+  }
+  return names.filter((n) => n.toLowerCase().includes(filterSubstr));
+}
+
+function printCountTable(pad: number, rows: { name: string; dev: number; prod: number }[]): void {
+  console.log(
+    "\n" +
+      "collection".padEnd(pad) +
+      "dev est.count".padStart(16) +
+      "prod est.count".padStart(16)
+  );
+  console.log("-".repeat(pad + 32));
+  for (const r of rows) {
+    const countsMatch = r.dev === r.prod;
+    const mismatch = countsMatch ? "" : " *";
+    console.log(
+      (r.name + mismatch).padEnd(pad) +
+        String(r.dev).padStart(16) +
+        String(r.prod).padStart(16)
+    );
+  }
+  console.log("\n* = counts differ (data volume; expected between envs)\n");
+}
+
+async function comparePair(
+  client: MongoClient,
+  devName: string,
+  prodName: string,
+  namesOnly: boolean,
+  filterSubstr: string | null
+): Promise<void> {
+  console.log("=".repeat(72));
+  console.log(`PAIR: ${devName}  <->  ${prodName}`);
+  console.log("=".repeat(72));
+
+  const devDb = client.db(devName);
+  const prodDb = client.db(prodName);
+
+  const devCols = await listSortedCollectionNames(devDb, filterSubstr);
+  const prodCols = await listSortedCollectionNames(prodDb, filterSubstr);
+
+  const { onlyA, onlyB, both } = diff(devCols, prodCols);
+
+  console.log(`\nCollections only in ${devName}: (${onlyA.length})`);
+  console.log(onlyA.length ? onlyA.join("\n") : "  (none)");
+
+  console.log(`\nCollections only in ${prodName}: (${onlyB.length})`);
+  console.log(onlyB.length ? onlyB.join("\n") : "  (none)");
+
+  console.log(`\nCollections in BOTH: (${both.length})`);
+
+  if (namesOnly) {
+    console.log(both.length ? both.join("\n") : "  (none)");
+    return;
+  }
+
+  if (both.length === 0) {
+    console.log("  (none)");
+    return;
+  }
+
+  const rows: { name: string; dev: number; prod: number }[] = [];
+  for (const name of both) {
+    const [d, p] = await Promise.all([
+      devDb.collection(name).estimatedDocumentCount(),
+      prodDb.collection(name).estimatedDocumentCount(),
+    ]);
+    rows.push({ name, dev: d, prod: p });
+  }
+  rows.sort((a, b) => a.name.localeCompare(b.name));
+
+  const pad = Math.max(12, ...rows.map((r) => r.name.length)) + 2;
+  printCountTable(pad, rows);
+}
+
+async function main() {
+  const uri = getUri();
+  if (!uri) {
+    console.error(
+      "No MongoDB URI found. Set one of: MONGODB_URI, DATABASE_URI, WOLF_PACK_DATABASE_URI, DATABASE_URI_PRODUCTION, DATABASE_URI_DEVELOPMENT (wolf-server/.env)."
+    );
+    process.exit(1);
+  }
+
+  const { namesOnly, filterSubstr } = parseArgs();
+  const client = new MongoClient(uri);
+
+  try {
+    await client.connect();
+    console.log("Connected (URI not printed).\n");
+
+    for (const [devName, prodName] of PAIRS) {
+      await comparePair(client, devName, prodName, namesOnly, filterSubstr);
+    }
+
+    console.log("Done.");
+  } finally {
+    await client.close();
+  }
+}
+
+try {
+  await main();
+} catch (e) {
+  console.error(e);
+  process.exit(1);
+}
