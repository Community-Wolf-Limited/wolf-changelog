+type NormalizedCheckpoint = {
+  number: number;
+  name: string;
+  description: string;
+  location: { latitude: number; longitude: number };
+  estimatedTimeMinutes: number;
+  instructions: string;
+  terrainType: TerrainType;
+  walkingSpeedKmh: number;
+  radiusMeters: number;
+};
+
+function buildRouteSegmentsAndStatsFromNormalized(normalizedCheckpoints: NormalizedCheckpoint[]): {
+  routeSegments: {
+    from: number;
+    to: number;
+    distance: number;
+    terrainType: string;
+    walkingSpeedKmh: number;
+    estimatedTimeMinutes: number;
+    coordinates: [number, number][];
+  }[];
+  stats: {
+    totalDistance: number;
+    totalWalkingTime: number;
+    totalStationaryTime: number;
+    totalTime: number;
+    totalSteps: number;
+    areaSize: number;
+    averageSpeed: number;
+    checkpointCount: number;
+    dominantTerrain: TerrainType;
+  };
+} {
+  let totalDistance = 0;
+  const routeSegments: {
+    from: number;
+    to: number;
+    distance: number;
+    terrainType: string;
+    walkingSpeedKmh: number;
+    estimatedTimeMinutes: number;
+    coordinates: [number, number][];
+  }[] = [];
+  for (let i = 0; i < normalizedCheckpoints.length - 1; i++) {
+    const from = normalizedCheckpoints[i].location;
+    const to = normalizedCheckpoints[i + 1].location;
+    const dist = calculateDistance(from.latitude, from.longitude, to.latitude, to.longitude) * 1000;
+    totalDistance += dist;
+    routeSegments.push({
+      from: i + 1,
+      to: i + 2,
+      distance: dist,
+      terrainType: TerrainType.FLAT,
+      walkingSpeedKmh: 4,
+      estimatedTimeMinutes: Math.ceil((dist / 1000) / (4 / 60)),
+      coordinates: [
+        [from.longitude, from.latitude],
+        [to.longitude, to.latitude],
+      ],
+    });
+  }
+  const totalWalkingTime = routeSegments.reduce((s, r) => s + r.estimatedTimeMinutes, 0);
+  const stats = {
+    totalDistance,
+    totalWalkingTime,
+    totalStationaryTime: normalizedCheckpoints.length * 2,
+    totalTime: totalWalkingTime + normalizedCheckpoints.length * 2,
+    totalSteps: Math.ceil(totalDistance / 0.7),
+    areaSize: 0,
+    averageSpeed: 4,
+    checkpointCount: normalizedCheckpoints.length,
+    dominantTerrain: TerrainType.FLAT,
+  };
+  return { routeSegments, stats };
+}
+
+type DevicePatrolRoutePatchBody = {
+  name?: string;
+  description?: string;
+  patrolMode?: string;
+  routeType?: string;
+  checkpoints?: { name?: string; latitude?: number; longitude?: number; radiusMeters?: number }[];
+  checkpointFlexibility?: Record<string, unknown>;
+};
+
+function applyDevicePatrolRoutePatchScalarFields(
+  route: InstanceType<typeof PatrolRoute>,
+  body: DevicePatrolRoutePatchBody
+): void {
+  if (typeof body.name === "string" && body.name.trim()) route.name = body.name.trim();
+  if (typeof body.description === "string") {
+    route.description = body.description.trim() || route.name;
+  }
+  if (body.patrolMode && ["rigid", "semi_rigid", "random"].includes(body.patrolMode)) {
+    route.set("patrolMode", body.patrolMode);
+  }
+  if (body.routeType === "linear" || body.routeType === "circular") {
+    route.routeType = body.routeType === "circular" ? RouteType.CIRCULAR : RouteType.LINEAR;
+  }
+  if (body.checkpointFlexibility && typeof body.checkpointFlexibility === "object") {
+    route.set("checkpointFlexibility", body.checkpointFlexibility);
+  }
+}
+
+function applyDevicePatrolRouteCheckpointsFromPatchBody(
+  route: InstanceType<typeof PatrolRoute>,
+  checkpoints: DevicePatrolRoutePatchBody["checkpoints"]
+): void {
+  if (!Array.isArray(checkpoints) || checkpoints.length < 1) return;
+  const normalizedCheckpoints: NormalizedCheckpoint[] = checkpoints.map(
+    (cp: { name?: string; latitude?: number; longitude?: number; radiusMeters?: number }, i: number) => ({
+      number: i + 1,
+      name: cp.name || `Checkpoint ${i + 1}`,
+      description: "",
+      location: { latitude: Number(cp.latitude), longitude: Number(cp.longitude) },
+      estimatedTimeMinutes: 2,
+      instructions: "",
+      terrainType: TerrainType.FLAT,
+      walkingSpeedKmh: 4,
+      radiusMeters: cp.radiusMeters ?? 10,
+    })
+  );
+  const { routeSegments, stats } = buildRouteSegmentsAndStatsFromNormalized(normalizedCheckpoints);
+  route.checkpoints = normalizedCheckpoints as typeof route.checkpoints;
+  route.routeSegments = routeSegments as typeof route.routeSegments;
+  route.stats = stats as typeof route.stats;
+}
