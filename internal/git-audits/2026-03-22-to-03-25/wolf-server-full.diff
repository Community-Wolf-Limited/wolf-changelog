+    if (!r) return { ok: false, error: "not_found" };
+  } else if (entity === "patrol_schedule") {
+    const r = await PatrolSchedule.findOneAndUpdate(
+      { _id: eid, organizationId: oid, deletedAt: { $ne: null } },
+      {
+        $set: {
+          deletedAt: null,
+          deletedByStaffId: null,
+          deletedByUserId: null,
+          deletionReason: null,
+          isActive: true,
+        },
