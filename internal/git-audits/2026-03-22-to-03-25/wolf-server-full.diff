+import { Types } from "mongoose";
+import { Expo } from "expo-server-sdk";
+import type { ExpoPushMessage, ExpoPushTicket } from "expo-server-sdk";
+import DeviceRegistrationModel from "./device-registration.schema.js";
+import logger from "../logger.js";
+
+function createExpoClient(): InstanceType<typeof Expo> {
+  const accessToken = process.env.EXPO_ACCESS_TOKEN?.trim();
+  if (accessToken) {
+    return new Expo({ accessToken });
+  }
+  // Expo Push API works without an access token for standard project sends.
+  return new Expo();
+}
+
+function isErrorTicket(t: ExpoPushTicket): t is Extract<ExpoPushTicket, { status: "error" }> {
+  return t.status === "error";
+}
+
+/**
+ * Send Expo push notifications to all active device registrations for a staff member in an org.
+ * No-op when there are no valid Expo push tokens on file.
+ */
+export async function sendExpoPushToStaffDevices(params: {
+  organizationId: string;
+  staffId: string;
+  title: string;
+  body: string;
+  data?: Record<string, unknown>;
+}): Promise<void> {
+  const expo = createExpoClient();
+
+  const regs = await DeviceRegistrationModel.find({
+    organizationId: new Types.ObjectId(params.organizationId),
+    staffId: new Types.ObjectId(params.staffId),
+    isActive: true,
+    expoPushToken: { $exists: true, $nin: [null, ""] },
+  })
+    .select("expoPushToken")
+    .lean();
+
+  const tokens = regs
+    .map((r) => r.expoPushToken)
+    .filter((t): t is string => typeof t === "string" && t.length > 0 && Expo.isExpoPushToken(t));
+
+  if (tokens.length === 0) {
+    return;
+  }
+
+  const messages: ExpoPushMessage[] = tokens.map((to) => ({
+    to,
+    sound: "default",
+    title: params.title,
+    body: params.body,
+    data: params.data ?? {},
+  }));
+
+  const chunks = expo.chunkPushNotifications(messages);
+  for (const chunk of chunks) {
+    try {
+      const tickets = await expo.sendPushNotificationsAsync(chunk);
+      const errs = tickets.filter(isErrorTicket);
+      if (errs.length > 0) {
+        logger.warn("Expo push partial failure", {
+          errors: errs.map((e) => e.message),
+        });
+      }
+    } catch (err) {
+      logger.error("Expo push send failed", {
+        error: err instanceof Error ? err.message : String(err),
+      });
+    }
+  }
+}
