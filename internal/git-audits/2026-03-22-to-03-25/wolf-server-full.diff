+import { Response, NextFunction } from "express";
+import { DeviceAuthRequest } from "./device-auth.middleware.js";
+import { loadActivePatrolGrant, patrolGrantRequired } from "./device-field-patrol.service.js";
+
+/**
+ * Loads active patrol-field grant for the authenticated device (if any).
+ */
+export async function loadPatrolGrantMiddleware(
+  req: DeviceAuthRequest,
+  res: Response,
+  next: NextFunction
+): Promise<void> {
+  if (!req.deviceAuth) {
+    next();
+    return;
+  }
+  try {
+    const g = await loadActivePatrolGrant(req.deviceAuth.staffId, req.deviceAuth.organizationId);
+    req.patrolGrant = g
+      ? {
+          grantId: g.grantId,
+          scope: g.scope,
+          grantVersion: g.grantVersion,
+          status: g.status,
+          expiresAt: g.expiresAt,
+          needsDeviceAcknowledgment: g.needsDeviceAcknowledgment,
+          trackingMode: g.trackingMode ?? "always",
+        }
+      : null;
+  } catch (err) {
+    console.error("loadPatrolGrantMiddleware:", err);
+    req.patrolGrant = null;
+  }
+  next();
+}
+
+export type MinPatrolScope = "own_device_created" | "org_wide";
+
+/**
+ * Requires an active grant with optional minimum scope and matching X-Grant-Version header.
+ * Skipped entirely when DEVICE_PATROL_GRANT_REQUIRED=false (legacy / dev).
+ */
+export function requirePatrolConfigWrite(minScope: MinPatrolScope) {
+  return (req: DeviceAuthRequest, res: Response, next: NextFunction): void => {
+    if (!patrolGrantRequired()) {
+      next();
+      return;
+    }
+    const g = req.patrolGrant;
+    if (g?.status !== "active") {
+      res.status(403).json({
+        success: false,
+        code: "PERMISSION_REQUIRED",
+        error: "Patrol field access not granted. Request access from control room.",
+      });
+      return;
+    }
+    if (g.needsDeviceAcknowledgment) {
+      res.status(403).json({
+        success: false,
+        code: "GRANT_ACK_REQUIRED",
+        error: "Accept field access on this device (Access tab) before editing patrol configuration.",
+      });
+      return;
+    }
+    if (minScope === "org_wide" && g.scope !== "org_wide") {
+      res.status(403).json({
+        success: false,
+        code: "INSUFFICIENT_SCOPE",
+        error: "This action requires org-wide access.",
+      });
+      return;
+    }
+    const header = req.header("X-Grant-Version");
+    const v = header == null ? Number.NaN : Number.parseInt(header, 10);
+    if (Number.isNaN(v) || v !== g.grantVersion) {
+      res.status(409).json({
+        success: false,
+        code: "GRANT_STALE",
+        expectedVersion: g.grantVersion,
+        error: "Access was updated by control room. Refresh capabilities and try again.",
+      });
+      return;
+    }
+    next();
+  };
+}
+
+/**
+ * Org-wide scope for read-only device endpoints (no X-Grant-Version).
+ * When DEVICE_PATROL_GRANT_REQUIRED=false, allows any authenticated device.
+ */
+export function requireOrgWidePatrolRead() {
+  return (req: DeviceAuthRequest, res: Response, next: NextFunction): void => {
+    if (!patrolGrantRequired()) {
+      next();
+      return;
+    }
+    const g = req.patrolGrant;
+    if (g?.status !== "active") {
+      res.status(403).json({
+        success: false,
+        code: "PERMISSION_REQUIRED",
+        error: "Patrol field access not granted. Request access from control room.",
+      });
+      return;
+    }
+    if (g.needsDeviceAcknowledgment) {
+      res.status(403).json({
+        success: false,
+        code: "GRANT_ACK_REQUIRED",
+        error: "Accept field access on this device (Access tab) first.",
+      });
+      return;
+    }
+    if (g.scope !== "org_wide") {
+      res.status(403).json({
+        success: false,
+        code: "INSUFFICIENT_SCOPE",
+        error: "This action requires org-wide field access.",
+      });
+      return;
+    }
+    next();
+  };
+}
