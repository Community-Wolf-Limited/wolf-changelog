+          deletedByStaffId: null,
+          deletedByUserId: null,
+          deletionReason: null,
+          lastUpdated: new Date(),
+        },
+      },
+      { new: true }
+    );
+    if (!r) return { ok: false, error: "not_found" };
+  } else if (entity === "patrol_route") {
+    const r = await PatrolRoute.findOneAndUpdate(
+      { _id: eid, clientId: oid, deletedAt: { $ne: null } },
+      {
+        $set: {
+          deletedAt: null,
+          deletedByStaffId: null,
+          deletedByUserId: null,
+          deletionReason: null,
+        },
+      },
+      { new: true }
