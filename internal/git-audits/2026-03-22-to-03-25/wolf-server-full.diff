+import { Schema } from "mongoose";
+import { db } from "../db.js";
+import { DbConfig } from "../db.config.js";
+
+export type DeviceGrantScope = "own_device_created" | "org_wide";
+export type DeviceGrantStatus = "pending" | "active" | "revoked" | "denied" | "expired";
+/** Live GPS: always stream when app is open, or only during active patrol. */
+export type DeviceGrantTrackingMode = "always" | "patrol_only";
+
+export interface DevicePermissionGrantDocument {
+  _id: import("mongodb").ObjectId;
+  organizationId: import("mongodb").ObjectId;
+  staffId: import("mongodb").ObjectId;
+  deviceId?: string;
+  scope: DeviceGrantScope;
+  status: DeviceGrantStatus;
+  grantVersion: number;
+  requestedReason?: string;
+  requestedAt: Date;
+  expiresAt?: Date | null;
+  approvedByUserId?: import("mongodb").ObjectId | null;
+  approvedAt?: Date | null;
+  deniedReason?: string | null;
+  revokedAt?: Date | null;
+  revokedByUserId?: import("mongodb").ObjectId | null;
+  revokeReason?: string | null;
+  notes?: string;
+  /** When true, grant was approved but this device must acknowledge before patrol config writes apply. */
+  requiresDeviceAck?: boolean;
+  deviceAcknowledgedAt?: Date | null;
+  /** Control room: how aggressively the patrol app streams idle GPS (default always). */
+  trackingMode?: DeviceGrantTrackingMode;
+  createdAt: Date;
+  updatedAt: Date;
+}
+
+const devicePermissionGrantSchema = new Schema<DevicePermissionGrantDocument>(
+  {
+    organizationId: { type: Schema.Types.ObjectId, required: true, ref: "Organisation", index: true },
+    staffId: { type: Schema.Types.ObjectId, required: true, ref: "Staff", index: true },
+    deviceId: { type: String, trim: true, required: false },
+    scope: {
+      type: String,
+      enum: ["own_device_created", "org_wide"],
+      required: true,
+    },
+    status: {
+      type: String,
+      enum: ["pending", "active", "revoked", "denied", "expired"],
+      required: true,
+      index: true,
+    },
+    grantVersion: { type: Number, required: true, default: 0, min: 0 },
+    requestedReason: { type: String, trim: true, maxlength: 2000 },
+    requestedAt: { type: Date, default: Date.now },
+    expiresAt: { type: Date, default: null },
+    approvedByUserId: { type: Schema.Types.ObjectId, ref: "User", default: null },
+    approvedAt: { type: Date, default: null },
+    deniedReason: { type: String, default: null },
+    revokedAt: { type: Date, default: null },
+    revokedByUserId: { type: Schema.Types.ObjectId, ref: "User", default: null },
+    revokeReason: { type: String, default: null },
+    notes: { type: String, trim: true, maxlength: 2000 },
+    requiresDeviceAck: { type: Boolean, default: false },
+    deviceAcknowledgedAt: { type: Date, default: null },
+    trackingMode: {
+      type: String,
+      enum: ["always", "patrol_only"],
+      default: "always",
+    },
+  },
+  {
+    timestamps: true,
+    collection: DbConfig.DEVICE_PERMISSION_GRANTS_COLLECTION,
+    autoIndex: false,
+  }
+);
+
+devicePermissionGrantSchema.index({ organizationId: 1, staffId: 1, status: 1 });
+devicePermissionGrantSchema.index({ organizationId: 1, createdAt: -1 });
+
+const DevicePermissionGrantModel = db.model<DevicePermissionGrantDocument>(
+  "DevicePermissionGrant",
+  devicePermissionGrantSchema,
+  DbConfig.DEVICE_PERMISSION_GRANTS_COLLECTION
+);
+
+export default DevicePermissionGrantModel;
