+import { ObjectId } from "mongodb";
+import { db } from "../db.js";
+import { DbConfig } from "../db.config.js";
+import {
+  BILLING_CATALOG_SEED,
+  BillingAccountDocument,
+  BillingCatalogItem,
+  BillingCheckoutDraftDocument,
+  BillingEntitlementsDocument,
+  BillingEventLogDocument,
+  BillingOverrideDocument,
+} from "./billing.type.js";
+
+interface OrganisationBillingProfile {
+  readonly _id: ObjectId;
+  readonly clientName?: string;
+  readonly clientEmail?: string;
+}
+
+export class BillingRepository {
+  private readonly organisationId?: ObjectId;
+
+  constructor({ organisationId }: { organisationId?: ObjectId }) {
+    this.organisationId = organisationId;
+  }
+
+  getOrganisationId(): ObjectId {
+    if (!this.organisationId) {
+      throw new Error("Organisation ID is required for this billing operation");
+    }
+    return this.organisationId;
+  }
+
+  private requireOrganisationId(): ObjectId {
+    if (!this.organisationId) {
+      throw new Error("Organisation ID is required for this billing operation");
+    }
+    return this.organisationId;
+  }
+
+  private get catalogCollection() {
+    return db.collection<BillingCatalogItem>(DbConfig.BILLING_CATALOG_COLLECTION);
+  }
+
+  private get accountCollection() {
+    return db.collection<BillingAccountDocument>(DbConfig.BILLING_ACCOUNTS_COLLECTION);
+  }
+
+  private get checkoutDraftCollection() {
+    return db.collection<BillingCheckoutDraftDocument>(
+      DbConfig.BILLING_CHECKOUT_DRAFTS_COLLECTION
+    );
+  }
+
+  private get entitlementsCollection() {
+    return db.collection<BillingEntitlementsDocument>(
+      DbConfig.BILLING_ENTITLEMENTS_COLLECTION
+    );
+  }
+
+  private get eventLogCollection() {
+    return db.collection<BillingEventLogDocument>(DbConfig.BILLING_EVENT_LOG_COLLECTION);
+  }
+
+  private get overridesCollection() {
+    return db.collection<BillingOverrideDocument>(DbConfig.BILLING_OVERRIDES_COLLECTION);
+  }
+
+  async ensureCatalogSeed(): Promise<void> {
+    const now = new Date();
+
+    await Promise.all(
+      BILLING_CATALOG_SEED.map((item) =>
+        this.catalogCollection.updateOne(
+          { key: item.key },
+          {
+            $set: {
+              name: item.name,
+              description: item.description,
+              currency: item.currency,
+              interval: item.interval,
+              unitAmount: item.unitAmount,
+              includedSeats: item.includedSeats,
+              active: item.active,
+              metadata: item.metadata,
+              updatedAt: now,
+            },
+            $setOnInsert: { createdAt: now },
+          },
+          { upsert: true }
+        )
+      )
+    );
+  }
+
+  async getCatalogItems(): Promise<BillingCatalogItem[]> {
+    return this.catalogCollection.find({ active: true }).toArray();
+  }
+
+  async getCatalogItemByKey(key: BillingCatalogItem["key"]): Promise<BillingCatalogItem | null> {
+    return this.catalogCollection.findOne({ key });
+  }
+
+  async updateCatalogStripeIds(
+    key: BillingCatalogItem["key"],
+    stripeProductId: string,
+    stripePriceId: string
+  ): Promise<void> {
+    await this.catalogCollection.updateOne(
+      { key },
+      {
+        $set: {
+          stripeProductId,
+          stripePriceId,
+          updatedAt: new Date(),
+        },
+      }
+    );
+  }
+
+  async getBillingAccount(): Promise<BillingAccountDocument | null> {
+    const organisationId = this.requireOrganisationId();
+    return this.accountCollection.findOne({ organisationId });
+  }
+
+  async upsertBillingAccount(
+    update: Partial<BillingAccountDocument>
+  ): Promise<BillingAccountDocument | null> {
+    const organisationId = this.requireOrganisationId();
+    const now = new Date();
+    const setOnInsert: Partial<BillingAccountDocument> = {
+      createdAt: now,
+    };
+
+    if (update.status === undefined) {
+      setOnInsert.status = "none";
+    }
+
+    if (update.lineItemQuantities === undefined) {
+      setOnInsert.lineItemQuantities = {};
+    }
+
+    if (update.seatCount === undefined) {
+      setOnInsert.seatCount = 2;
+    }
+
+    await this.accountCollection.updateOne(
+      { organisationId },
+      {
+        $set: {
+          ...update,
+          organisationId,
+          updatedAt: now,
+        },
+        $setOnInsert: setOnInsert,
+      },
+      { upsert: true }
+    );
+
+    return this.getBillingAccount();
+  }
+
+  async findAccountBySubscriptionId(
+    stripeSubscriptionId: string
+  ): Promise<BillingAccountDocument | null> {
+    return this.accountCollection.findOne({ stripeSubscriptionId });
+  }
+
+  async findAccountByCustomerId(
+    stripeCustomerId: string
+  ): Promise<BillingAccountDocument | null> {
+    return this.accountCollection.findOne({ stripeCustomerId });
+  }
+
+  async getOrganisationBillingProfile(): Promise<OrganisationBillingProfile | null> {
+    const organisationId = this.requireOrganisationId();
+    return db.collection<OrganisationBillingProfile>(DbConfig.ORGANISATION_COLLECTION!).findOne(
+      { _id: organisationId },
+      {
+        projection: {
+          _id: 1,
+          clientName: 1,
+          clientEmail: 1,
+        },
+      }
+    );
+  }
+
+  async createCheckoutDraft(
+    payload: Omit<BillingCheckoutDraftDocument, "_id" | "createdAt" | "updatedAt">
+  ): Promise<BillingCheckoutDraftDocument> {
+    const now = new Date();
+    const insertResult = await this.checkoutDraftCollection.insertOne({
+      ...payload,
+      createdAt: now,
+      updatedAt: now,
+    });
+
+    const draft = await this.checkoutDraftCollection.findOne({
+      _id: insertResult.insertedId,
+    });
+
+    if (!draft) {
+      throw new Error("Failed to create checkout draft");
+    }
+
+    return draft;
+  }
+
+  async getCheckoutDraftById(draftId: ObjectId): Promise<BillingCheckoutDraftDocument | null> {
+    const organisationId = this.requireOrganisationId();
+    return this.checkoutDraftCollection.findOne({
+      _id: draftId,
+      organisationId,
+    });
+  }
+
+  async getLatestCheckoutDraft(): Promise<BillingCheckoutDraftDocument | null> {
+    const organisationId = this.requireOrganisationId();
+    return this.checkoutDraftCollection.findOne(
+      { organisationId },
+      { sort: { createdAt: -1 } }
+    );
+  }
+
+  async markDraftCheckoutCreated(
+    draftId: ObjectId,
+    stripeCheckoutSessionId: string
+  ): Promise<void> {
+    const organisationId = this.requireOrganisationId();
+    await this.checkoutDraftCollection.updateOne(
+      { _id: draftId, organisationId },
+      {
+        $set: {
+          status: "checkout-created",
+          stripeCheckoutSessionId,
+          updatedAt: new Date(),
+        },
+      }
+    );
+  }
+
+  async upsertEntitlements(
+    payload: Omit<BillingEntitlementsDocument, "_id" | "updatedAt">
+  ): Promise<BillingEntitlementsDocument | null> {
+    const organisationId = this.requireOrganisationId();
+    await this.entitlementsCollection.updateOne(
+      { organisationId },
+      {
+        $set: {
+          ...payload,
+          updatedAt: new Date(),
+        },
+      },
+      { upsert: true }
+    );
+
+    return this.getEntitlements();
+  }
+
+  async getEntitlements(): Promise<BillingEntitlementsDocument | null> {
+    const organisationId = this.requireOrganisationId();
+    return this.entitlementsCollection.findOne({ organisationId });
+  }
+
+  async createOverride(
+    payload: Omit<BillingOverrideDocument, "_id" | "createdAt" | "updatedAt">
+  ): Promise<BillingOverrideDocument> {
+    const now = new Date();
+    const result = await this.overridesCollection.insertOne({
+      ...payload,
+      createdAt: now,
+      updatedAt: now,
+    });
+
+    const override = await this.overridesCollection.findOne({ _id: result.insertedId });
+    if (!override) {
+      throw new Error("Failed to persist billing override");
+    }
+
+    return override;
+  }
+
+  async getActiveOverrides(): Promise<BillingOverrideDocument[]> {
+    const organisationId = this.requireOrganisationId();
+    const now = new Date();
+    return this.overridesCollection
+      .find({
+        organisationId,
+        isActive: true,
+        $or: [{ expiresAt: { $exists: false } }, { expiresAt: { $gt: now } }],
+      })
+      .sort({ createdAt: -1 })
+      .toArray();
+  }
+
+  async createEventLog(
+    payload: Omit<BillingEventLogDocument, "_id" | "createdAt">
+  ): Promise<ObjectId> {
+    const result = await this.eventLogCollection.insertOne({
+      ...payload,
+      createdAt: new Date(),
+    });
+    return result.insertedId;
+  }
+
+  async createGlobalEventLog(
+    payload: Omit<BillingEventLogDocument, "_id" | "createdAt" | "organisationId">
+  ): Promise<ObjectId> {
+    const result = await this.eventLogCollection.insertOne({
+      ...payload,
+      createdAt: new Date(),
+    });
+    return result.insertedId;
+  }
+
+  async markEventProcessed(eventLogId: ObjectId): Promise<void> {
+    await this.eventLogCollection.updateOne(
+      { _id: eventLogId },
+      {
+        $set: {
+          status: "processed",
+          processedAt: new Date(),
+        },
+      }
+    );
+  }
+
+  async markEventFailed(eventLogId: ObjectId, errorMessage: string): Promise<void> {
+    await this.eventLogCollection.updateOne(
+      { _id: eventLogId },
+      {
+        $set: {
+          status: "failed",
+          error: errorMessage,
+          processedAt: new Date(),
+        },
+      }
+    );
+  }
+
+  async countPlatformUsers(): Promise<number> {
+    const organisationId = this.requireOrganisationId();
+    return db
+      .collection(DbConfig.USERS_COLLECTION!)
+      .countDocuments({ organisationId });
+  }
+
+  async countStaffBySkills(skills: string[]): Promise<number> {
+    const organisationId = this.requireOrganisationId();
+    if (skills.length === 0) {
+      return 0;
+    }
+
+    return db.collection(DbConfig.STAFF_COLLECTION!).countDocuments({
+      clientId: organisationId,
+      deletedAt: null,
+      $or: [
+        { assignedSkills: { $in: skills } },
+        { inheritedSkills: { $in: skills } },
+      ],
+    });
+  }
+
+  async countStaffByRegex(regex: RegExp): Promise<number> {
+    const organisationId = this.requireOrganisationId();
+    return db.collection(DbConfig.STAFF_COLLECTION!).countDocuments({
+      clientId: organisationId,
+      deletedAt: null,
+      $or: [{ assignedSkills: regex }, { inheritedSkills: regex }],
+    });
+  }
+
+  async countActiveAgentGroups(): Promise<number> {
+    const organisationId = this.requireOrganisationId();
+    return db.collection(DbConfig.AGENT_GROUP_COLLECTION!).countDocuments({
+      clientId: organisationId,
+      status: "active",
+    });
+  }
+}
