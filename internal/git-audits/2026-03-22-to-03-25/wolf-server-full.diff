diff --git a/vitest.config.ts b/vitest.config.ts
new file mode 100644
index 0000000..b2e701f
--- /dev/null
+++ b/vitest.config.ts
@@ -0,0 +1,36 @@
+import { defineConfig } from "vitest/config";
+
+/**
+ * Default DATABASE_URI so modules that validate config at import time (e.g. admin dashboard)
+ * load under Vitest without requiring a real cluster.
+ *
+ * Default `npm test` runs **unit** suites only (no live MongoDB / Mapbox / real admin DB).
+ * Integration: `RUN_INTEGRATION_TESTS=true npm run test` (needs DATABASE_URI to a real cluster).
+ */
+process.env.DATABASE_URI ??= "mongodb://127.0.0.1:27017/vitest";
+
+const runIntegration = process.env.RUN_INTEGRATION_TESTS === "true";
+
+export default defineConfig({
+  test: {
+    environment: "node",
+    testTimeout: 15_000,
+    hookTimeout: 30_000,
+    exclude: [
+      "**/node_modules/**",
+      "**/dist/**",
+      ...(runIntegration
+        ? []
+        : [
+            "**/*.integration.test.ts",
+            "test/gateKeeper/gateKeeper.test.ts",
+            /** Require a reachable MongoDB (local or Atlas); run with RUN_INTEGRATION_TESTS=true */
+            "test/alertFlow.test.ts",
+            "test/dashboard/dashboard.test.ts",
+            /** Real DB + Mapbox/network — use RUN_INTEGRATION_TESTS=true */
+            "server/adminDashboard/**/access-control-analytics.unit.test.ts",
+            "server/safetyRouting/__tests__/hexGraphRouter.test.ts",
+          ]),
+    ],
+  },
+});
