+
+export type StaffLivePositionSource = "patrol" | "heartbeat";
+
+export interface StaffLivePositionDocument {
+  _id: import("mongodb").ObjectId;
+  organizationId: import("mongodb").ObjectId;
+  staffId: import("mongodb").ObjectId;
+  location: {
+    latitude: number;
+    longitude: number;
+    accuracy?: number;
+    altitude?: number;
+    heading?: number;
+    speed?: number;
+    provider?: string;
+  };
+  eventId: import("mongodb").ObjectId | null;
+  source: StaffLivePositionSource;
+  timestamp: Date;
+  updatedAt: Date;
+}
+
+const staffLivePositionSchema = new Schema<StaffLivePositionDocument>(
+  {
+    organizationId: { type: Schema.Types.ObjectId, required: true, ref: "Organisation", index: true },
+    staffId: { type: Schema.Types.ObjectId, required: true, ref: "Staff", index: true },
+    location: {
+      latitude: { type: Number, required: true },
+      longitude: { type: Number, required: true },
+      accuracy: { type: Number },
+      altitude: { type: Number },
+      heading: { type: Number },
+      speed: { type: Number },
+      provider: { type: String },
+    },
+    eventId: { type: Schema.Types.ObjectId, default: null },
+    source: { type: String, enum: ["patrol", "heartbeat"], required: true },
+    timestamp: { type: Date, required: true },
+    updatedAt: { type: Date, required: true },
+  },
+  {
+    collection: DbConfig.STAFF_LIVE_POSITIONS_COLLECTION,
+    autoIndex: false,
+    timestamps: false,
+  }
+);
+
+staffLivePositionSchema.index({ organizationId: 1, staffId: 1 }, { unique: true });
+/** Expire stale positions after 30 minutes (MongoDB TTL). */
+staffLivePositionSchema.index({ updatedAt: 1 }, { expireAfterSeconds: 1800 });
