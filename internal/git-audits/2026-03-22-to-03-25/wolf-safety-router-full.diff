+func TestIsOriginAllowed(t *testing.T) {
+	exact := map[string]bool{
+		testOriginCW:           true,
+		"http://localhost:8080": true,
+	}
+	wildcards := []string{".communitywolf.com"}
+
+	tests := []struct {
+		origin string
+		want   bool
+	}{
+		{testOriginCW, true},
+		{testOriginMap, true},
+		{"https://platform.communitywolf.com", true},
+		{"https://preview-investors.communitywolf.com", true},
+		{"http://localhost:8080", true},
+		{"https://evil.com", false},
+		{"https://notcommunitywolf.com", false},
+		{"https://communitywolf.com.evil.com", false},
+		{"", false},
+	}
+
+	for _, tt := range tests {
+		got := isOriginAllowed(tt.origin, exact, wildcards)
+		if got != tt.want {
+			t.Errorf("isOriginAllowed(%q) = %v, want %v", tt.origin, got, tt.want)
+		}
+	}
+}
