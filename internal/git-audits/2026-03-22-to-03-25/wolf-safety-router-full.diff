+func TestCorsMiddlewareWildcard(t *testing.T) {
+	ok := http.HandlerFunc(func(w http.ResponseWriter, _ *http.Request) { w.WriteHeader(http.StatusOK) })
+	h := corsMiddleware([]string{"https://*.communitywolf.com", testOriginCW}, ok)
+
+	req := httptest.NewRequest(http.MethodGet, testHexesAll, nil)
+	req.Header.Set("Origin", testOriginMap)
+	rec := httptest.NewRecorder()
+	h.ServeHTTP(rec, req)
+
+	if got := rec.Header().Get(headerAllowOrigin); got != testOriginMap {
+		t.Errorf("CORS: got %q, want %s", got, testOriginMap)
+	}
+}
+
+func TestCorsMiddlewareRejectsUnknown(t *testing.T) {
+	ok := http.HandlerFunc(func(w http.ResponseWriter, _ *http.Request) { w.WriteHeader(http.StatusOK) })
+	h := corsMiddleware([]string{"https://*.communitywolf.com"}, ok)
+
+	req := httptest.NewRequest(http.MethodGet, testHexesAll, nil)
+	req.Header.Set("Origin", "https://evil.com")
+	rec := httptest.NewRecorder()
+	h.ServeHTTP(rec, req)
+
+	if got := rec.Header().Get(headerAllowOrigin); got != "" {
+		t.Errorf("CORS should be empty for unknown origin, got %q", got)
+	}
+}
