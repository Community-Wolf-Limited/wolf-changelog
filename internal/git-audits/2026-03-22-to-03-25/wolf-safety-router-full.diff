+func setCORSHeaders(w http.ResponseWriter, r *http.Request, cfg corsConfig) {
+	if cfg.allowAll {
+		w.Header().Set("Access-Control-Allow-Origin", "*")
+	} else {
+		origin := r.Header.Get("Origin")
+		if origin != "" && isOriginAllowed(origin, cfg.exactOrigins, cfg.wildcardSuffixes) {
+			w.Header().Set("Access-Control-Allow-Origin", origin)
+			w.Header().Set("Vary", "Origin")
+		}
+	}
+	w.Header().Set("Access-Control-Allow-Methods", "GET, POST, DELETE, OPTIONS")
+	w.Header().Set("Access-Control-Allow-Headers", "Content-Type, Authorization, X-API-Key")
+	w.Header().Set("Access-Control-Expose-Headers", "X-Hex-Count, Content-Length, Content-Encoding, X-Request-ID")
+}
+
+func isOriginAllowed(origin string, exact map[string]bool, wildcardSuffixes []string) bool {
+	if exact[origin] {
+		return true
+	}
+	schemeEnd := strings.Index(origin, "://")
+	if schemeEnd < 0 {
+		return false
+	}
+	host := origin[schemeEnd+3:]
+	for _, suffix := range wildcardSuffixes {
+		if strings.HasSuffix(host, suffix) {
+			return true
+		}
+	}
+	return false
+}
