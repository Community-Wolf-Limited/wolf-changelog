+  isCurrent: () => boolean
+): Promise<{ totalOsm: number; errors: string[] }> {
+  const { orgId, lat, lng, radiusKm, token, signal } = ctx;
+  try {
+    return await streamOsmPois(orgId, lat, lng, radiusKm, token, onBatch, signal);
+  } catch (streamErr) {
+    if (!isCurrent()) throw streamErr;
+    if (POI_DEBUG) console.warn("[POI] OSM stream failed, trying JSON fallback:", streamErr);
+    const jsonPois = await fetchOsmPoisJson(orgId, lat, lng, radiusKm, token, signal);
+    if (jsonPois.length > 0 && isCurrent()) onBatch(jsonPois);
+    return { totalOsm: jsonPois.length, errors: [] };
+  }
