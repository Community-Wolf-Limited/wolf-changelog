+const ZAR_FORMATTER = new Intl.NumberFormat("en-ZA", {
+  style: "currency",
+  currency: "ZAR",
+  maximumFractionDigits: 0,
+});
+
+function formatZar(value: number): string {
+  return ZAR_FORMATTER.format(value);
+}
+
+function formatSignedZar(value: number): string {
+  if (value > 0) {
+    return `+${formatZar(value)}`;
+  }
+  if (value < 0) {
+    return `-${formatZar(Math.abs(value))}`;
+  }
+  return formatZar(0);
+}
