+  const next: BuilderQuantities = { ...INITIAL_BUILDER_QUANTITIES };
+  let foundMappedItem = false;
+
+  for (const item of sourceSummary.lineItems) {
+    const mappedCode = SUMMARY_CODE_TO_BUILDER_CODE[item.code];
+    if (!mappedCode) {
+      continue;
+    }
+
+    const quantity = Number.isFinite(item.quantity) ? Math.max(0, Math.floor(item.quantity)) : 0;
+    next[mappedCode] = quantity;
+    foundMappedItem = true;
+  }
+
+  // Platform is mandatory in the checkout model.
+  next.platform = Math.max(1, next.platform);
+
+  return foundMappedItem ? next : null;
