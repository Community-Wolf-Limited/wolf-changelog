+/**
+ * API base for fetch() and POI NDJSON stream URLs.
+ * - Dev: VITE_API_URL → local wolf-server; use Vite `/api` proxy when targeting localhost:4000.
+ * - Prod (Vercel): prefer same-origin `/api` so rewrites proxy to wolf-data-api — avoids SPA catch-all
+ *   returning HTML for `/api/...` when VITE_API_URL mistakenly points at the frontend host.
+ */
+function normalizeApiBase(trimmed: string): string {
+  const t = trimmed.replace(/\/+$/, "");
+  return t.endsWith("/api") ? t : `${t}/api`;
+}
+
+function resolveApiBase(): string {
+  const rawBase = (import.meta.env.VITE_API_URL as string | undefined)?.trim();
+
+  if (import.meta.env.DEV) {
+    if (!rawBase) {
+      return "/api";
+    }
+    const baseWithApi = normalizeApiBase(rawBase);
+    if (
+      baseWithApi.startsWith("http://localhost:4000") ||
+      baseWithApi.startsWith("http://127.0.0.1:4000")
+    ) {
+      return "/api";
+    }
+    return baseWithApi;
+  }
+
   if (!rawBase) {
-    throw new Error(
-      "VITE_API_URL is not defined. Please set it in your environment variables. " +
-      "This is required for all environments (development, staging, production)."
-    );
+    return "/api";
