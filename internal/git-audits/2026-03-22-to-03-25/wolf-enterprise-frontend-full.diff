+  const baseQuery: Record<string, string> = {
+    lat: lat.toString(),
+    lng: lng.toString(),
+    radius: osmRadius.toString(),
+    onlyCoordinates: "true",
+    limit: String(OSM_LIMIT),
+  };
+
+  let lastErr: unknown;
+  for (const [path, query] of [
+    [`/${orgId}/poi/osm`, baseQuery] as const,
+    [`/${orgId}/poi`, { ...baseQuery, source: "osm" }] as const,
+  ]) {
+    try {
+      const res = await api.get<POIListResponse>(path, {
+        token,
+        query,
+        timeoutMs: 30000,
+        signal,
+      });
+      return (res?.pois ?? []).map((p) => ({ ...p, source: "osm" as const }));
+    } catch (e) {
+      lastErr = e;
+    }
+  }
+  throw lastErr;
