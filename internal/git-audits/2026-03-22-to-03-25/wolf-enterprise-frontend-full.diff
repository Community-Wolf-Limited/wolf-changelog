diff --git a/src/components/BillingFeatureGate.tsx b/src/components/BillingFeatureGate.tsx
new file mode 100644
index 0000000..6d6bb1e
--- /dev/null
+++ b/src/components/BillingFeatureGate.tsx
@@ -0,0 +1,139 @@
+import { useAuth } from "@clerk/react-router";
+import { Navigate, useLocation } from "react-router-dom";
+import { useEffect, useMemo, useState } from "react";
+import { AlertTriangle, CreditCard } from "lucide-react";
+import { Alert, AlertDescription, AlertTitle } from "@/components/ui/alert";
+import { Button } from "@/components/ui/button";
+import LoadingScreen from "@/components/LoadingScreen";
+import { useOrganisation } from "@/hooks/useOrganisation";
+import { fetchBillingEntitlements } from "@/utils/billing-api";
+import type { BillingEntitlement } from "@/types/billing.type";
+import { UserRole } from "@/types/user.type";
+
+interface BillingFeatureGateProps {
+  readonly requiredEntitlementKeys: string[];
+  readonly featureName: string;
+  readonly children: React.ReactNode;
+}
+
+/**
+ * Guard a route behind billing entitlements while keeping the current
+ * global-admin-first operating model for phase 1.
+ */
+export default function BillingFeatureGate({
+  requiredEntitlementKeys,
+  featureName,
+  children,
+}: BillingFeatureGateProps) {
+  const location = useLocation();
+  const { getToken } = useAuth();
+  const { currentOrganisation, user, isLoading } = useOrganisation();
+  const [entitlements, setEntitlements] = useState<BillingEntitlement[] | null>(null);
+  const [isLoadingEntitlements, setIsLoadingEntitlements] = useState(true);
+  const [entitlementError, setEntitlementError] = useState<string | null>(null);
+
+  const isGlobalAdmin = user?.role === UserRole.ADMIN;
+
+  useEffect(() => {
+    let isMounted = true;
+
+    async function loadEntitlements() {
+      if (!currentOrganisation?._id) {
+        if (isMounted) {
+          setEntitlements([]);
+          setIsLoadingEntitlements(false);
+        }
+        return;
+      }
+
+      try {
+        setIsLoadingEntitlements(true);
+        setEntitlementError(null);
+        const token = await getToken();
+        const nextEntitlements = await fetchBillingEntitlements(
+          currentOrganisation._id,
+          token
+        );
+        if (isMounted) {
+          setEntitlements(nextEntitlements);
+        }
+      } catch (error) {
+        if (isMounted) {
+          setEntitlementError(
+            error instanceof Error
+              ? error.message
+              : "Failed to load billing entitlements."
+          );
+          setEntitlements([]);
+        }
+      } finally {
+        if (isMounted) {
+          setIsLoadingEntitlements(false);
+        }
+      }
+    }
+
+    void loadEntitlements();
+
+    return () => {
+      isMounted = false;
+    };
+  }, [currentOrganisation?._id, getToken]);
+
+  const entitlementMap = useMemo(() => {
+    return new Map((entitlements ?? []).map((item) => [item.key, item]));
+  }, [entitlements]);
+
+  const hasAccess = useMemo(() => {
+    return requiredEntitlementKeys.every((key) => entitlementMap.get(key)?.enabled);
+  }, [entitlementMap, requiredEntitlementKeys]);
+
+  if (isLoading || isLoadingEntitlements) {
+    return <LoadingScreen />;
+  }
+
+  if (hasAccess) {
+    return <>{children}</>;
+  }
+
+  if (isGlobalAdmin) {
+    return (
+      <Navigate
+        to="/settings/billing"
+        replace
+        state={{
+          from: location.pathname,
+          featureName,
+          requiredEntitlementKeys,
+        }}
+      />
+    );
+  }
+
+  return (
+    <div className="min-h-screen bg-background flex items-center justify-center p-6">
+      <div className="w-full max-w-xl space-y-4">
+        <Alert variant="destructive">
+          <AlertTriangle className="h-4 w-4" />
+          <AlertTitle>{featureName} is not available for this organisation</AlertTitle>
+          <AlertDescription>
+            {entitlementError
+              ? `Billing status could not be verified: ${entitlementError}`
+              : "Your organisation does not currently have billing access for this feature."}
+          </AlertDescription>
+        </Alert>
+        <Alert>
+          <CreditCard className="h-4 w-4" />
+          <AlertTitle>Contact your administrator</AlertTitle>
+          <AlertDescription>
+            Ask a Community Wolf administrator to update billing and enable access for
+            this product.
+          </AlertDescription>
+        </Alert>
+        <Button asChild variant="outline">
+          <a href="/">Back to Dashboard</a>
+        </Button>
+      </div>
+    </div>
+  );
+}
