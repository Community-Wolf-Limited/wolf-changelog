+
+function normaliseLifecycleState(
+  statusValue: string | null,
+  unpaid: boolean,
+  trial: boolean,
+  gracePeriod: boolean,
+  overLimit: boolean
+): BillingLifecycleState {
+  if (unpaid) {
+    return "unpaid";
+  }
+  if (overLimit) {
+    return "over-limit";
+  }
+  if (gracePeriod) {
+    return "grace-period";
+  }
+  if (trial) {
+    return "trial";
+  }
+
+  if (!statusValue) {
+    return "unknown";
+  }
+
+  const normalizedStatus = statusValue.toLowerCase();
+  if (normalizedStatus === "active") {
+    return "active";
+  }
+  if (normalizedStatus.includes("trial")) {
+    return "trial";
+  }
+  if (normalizedStatus.includes("grace")) {
+    return "grace-period";
+  }
+  if (
+    normalizedStatus === "past_due" ||
+    normalizedStatus === "unpaid" ||
+    normalizedStatus === "incomplete" ||
+    normalizedStatus === "payment_failed"
+  ) {
+    return "unpaid";
+  }
+  if (normalizedStatus.includes("over_limit")) {
+    return "over-limit";
+  }
+  return "unknown";
+}
+
+function normaliseSummaryLineItems(payload: unknown): BillingSummaryLineItem[] {
+  if (!Array.isArray(payload)) {
+    return [];
+  }
+
+  return payload
+    .map((item): BillingSummaryLineItem | null => {
+      if (!isRecord(item)) {
+        return null;
+      }
+
+      const code =
+        getString(item, ["code", "productCode", "product"]) ?? "unknown";
+      const label =
+        getString(item, ["label", "name", "productName"]) ?? "Unknown item";
+      const quantity = getNumber(item, ["quantity", "qty"]) ?? 0;
+
+      const totalCents = getNumber(item, ["totalAmountCents"]);
+      const totalAmount =
+        totalCents !== null
+          ? totalCents / 100
+          : (getNumber(item, ["totalAmountZar", "totalAmount", "amount"]) ?? 0);
+
+      const unitCents = getNumber(item, ["unitAmountCents"]);
+      const unitAmount =
+        unitCents !== null
+          ? unitCents / 100
+          : (getNumber(item, ["unitAmountZar", "unitAmount", "price"]) ?? 0);
+
+      return {
+        code,
+        label,
+        quantity,
+        unitAmountZar: unitAmount,
+        totalAmountZar: totalAmount,
+      };
+    })
+    .filter((item): item is BillingSummaryLineItem => item !== null);
+}
+
+function normaliseBillingSummary(payload: unknown): BillingSummary {
+  const data = unwrapApiEnvelope(payload);
+  if (!isRecord(data)) {
+    throw new Error("Invalid billing summary response shape.");
+  }
+
+  const lineItems = normaliseSummaryLineItems(
+    getArray(data, ["lineItems", "items", "subscriptionItems"])
+  );
+
+  const subtotalCents = getNumber(data, [
+    "monthlySubtotalCents",
+    "subtotalCents",
+    "amountDueCents",
+  ]);
+  const monthlySubtotalZar =
+    subtotalCents !== null
+      ? subtotalCents / 100
+      : (getNumber(data, [
+          "monthlySubtotalZar",
+          "monthlySubtotal",
+          "subtotal",
+          "amountDue",
+        ]) ??
+        lineItems.reduce((total, item) => total + item.totalAmountZar, 0));
+
+  const seatsIncluded =
+    getNumber(data, ["seatsIncluded", "includedSeats"]) ??
+    getNumber(data, ["seatLimit"]);
+  const seatsUsed =
+    getNumber(data, ["seatsUsed", "usedSeats"]) ?? getNumber(data, ["seatUsage"]);
+  const seatsOverLimit =
+    getNumber(data, ["seatsOverLimit", "overLimitSeats"]) ??
+    (seatsIncluded !== null && seatsUsed !== null && seatsUsed > seatsIncluded
+      ? seatsUsed - seatsIncluded
+      : 0);
+
+  const statusLabel =
+    getString(data, ["statusLabel", "status", "billingStatus", "state"]) ??
+    "Unknown";
+
+  const isUnpaid =
+    getBoolean(data, ["isUnpaid", "pastDue", "paymentFailed"]) ??
+    false;
+  const isTrial = getBoolean(data, ["isTrial", "trial"]) ?? false;
+  const isGracePeriod =
+    getBoolean(data, ["isGracePeriod", "gracePeriod"]) ?? false;
+  const isOverLimit =
+    getBoolean(data, ["isOverLimit", "overLimit"]) ?? seatsOverLimit > 0;
+
+  return {
+    state: normaliseLifecycleState(
+      statusLabel,
+      isUnpaid,
+      isTrial,
+      isGracePeriod,
+      isOverLimit
+    ),
+    statusLabel,
+    currency: getString(data, ["currency"]) ?? "ZAR",
+    monthlySubtotalZar,
+    seatsIncluded,
+    seatsUsed,
+    seatsOverLimit,
+    trialEndsAt: getString(data, ["trialEndsAt", "trialEndDate"]),
+    graceEndsAt: getString(data, ["graceEndsAt", "gracePeriodEndsAt"]),
+    currentPeriodEndsAt: getString(data, [
+      "currentPeriodEndsAt",
+      "currentPeriodEnd",
+      "periodEndsAt",
+    ]),
+    billingMode:
+      (getString(data, ["billingMode"]) as BillingSummary["billingMode"] | null) ?? "none",
+    usingOverrides: getBoolean(data, ["usingOverrides"]) ?? false,
+    usage: isRecord(data.usage)
+      ? {
+          platformUsers: getNumber(data.usage, ["platformUsers"]) ?? 0,
+          accessControlUsers: getNumber(data.usage, ["accessControlUsers"]) ?? 0,
+          patrolUsers: getNumber(data.usage, ["patrolUsers"]) ?? 0,
+          activeAgentGroups: getNumber(data.usage, ["activeAgentGroups"]) ?? 0,
+        }
+      : null,
+    latestDraft: isRecord(data.latestDraft)
+      ? {
+          draftId: getString(data.latestDraft, ["draftId"]) ?? "",
+          status: getString(data.latestDraft, ["status"]) ?? "unknown",
+          createdAt: getString(data.latestDraft, ["createdAt"]) ?? "",
+          updatedAt: getString(data.latestDraft, ["updatedAt"]) ?? "",
+          seatCount: getNumber(data.latestDraft, ["seatCount"]) ?? 0,
+          amountSubtotalZar:
+            (getNumber(data.latestDraft, ["amountSubtotalCents"]) ?? 0) / 100,
+          stripeCheckoutSessionId:
+            getString(data.latestDraft, ["stripeCheckoutSessionId"]) ?? null,
+        }
+      : null,
+    lineItems,
+  };
+}
+
+function normaliseEntitlements(payload: unknown): BillingEntitlement[] {
+  const data = unwrapApiEnvelope(payload);
+
+  if (Array.isArray(data)) {
+    return data
+      .map((entry): BillingEntitlement | null => {
+        if (!isRecord(entry)) {
+          return null;
+        }
+
+        const key = getString(entry, ["key", "code", "feature"]) ?? "unknown";
+        const label = getString(entry, ["label", "name", "title"]) ?? key;
+        const usage = getNumber(entry, ["usage", "used", "usedCount"]);
+        const limit = getNumber(entry, ["limit", "max", "allowed"]);
+        const explicitOverLimit = getBoolean(entry, ["overLimit", "isOverLimit"]);
+        const overLimit =
+          explicitOverLimit ??
+          (usage !== null && limit !== null && usage > limit);
+
+        const statusText =
+          getString(entry, ["status", "state"]) ?? (overLimit ? "over-limit" : "active");
+        const enabled = getBoolean(entry, ["enabled", "active"]) ?? true;
+
+        const status = !enabled
+          ? "inactive"
+          : normaliseLifecycleState(
+              statusText,
+              statusText.toLowerCase() === "unpaid",
+              statusText.toLowerCase().includes("trial"),
+              statusText.toLowerCase().includes("grace"),
+              overLimit
+            );
+
+        return {
+          key,
+          label,
+          status,
+          enabled,
+          usage,
+          limit,
+          overLimit,
+        };
+      })
+      .filter((entry): entry is BillingEntitlement => entry !== null);
+  }
+
+  if (!isRecord(data)) {
+    return [];
+  }
+
+  const entitlementsData = getArray(data, ["entitlements", "items", "features"]);
+  if (!entitlementsData) {
+    return [];
+  }
+
+  return entitlementsData
+    .map((entry): BillingEntitlement | null => {
+      if (!isRecord(entry)) {
+        return null;
+      }
+
+      const key = getString(entry, ["key", "code", "feature"]) ?? "unknown";
+      const label = getString(entry, ["label", "name", "title"]) ?? key;
+      const usage = getNumber(entry, ["usage", "used", "usedCount"]);
+      const limit = getNumber(entry, ["limit", "max", "allowed"]);
+      const explicitOverLimit = getBoolean(entry, ["overLimit", "isOverLimit"]);
+      const overLimit =
+        explicitOverLimit ??
+        (usage !== null && limit !== null && usage > limit);
+
+      const statusText =
+        getString(entry, ["status", "state"]) ?? (overLimit ? "over-limit" : "active");
+      const enabled = getBoolean(entry, ["enabled", "active"]) ?? true;
+
+      const status = !enabled
+        ? "inactive"
+        : normaliseLifecycleState(
+            statusText,
+            statusText.toLowerCase() === "unpaid",
+            statusText.toLowerCase().includes("trial"),
+            statusText.toLowerCase().includes("grace"),
+            overLimit
+          );
+
+      return {
+        key,
+        label,
+        status,
+        enabled,
+        usage,
+        limit,
+        overLimit,
+      };
+    })
+    .filter((entry): entry is BillingEntitlement => entry !== null);
+}
+
+function normaliseBillingDrift(payload: unknown): BillingDriftSummary {
+  const data = unwrapApiEnvelope(payload);
+  if (!isRecord(data)) {
+    throw new Error("Invalid billing drift response shape.");
+  }
+
+  const statusRaw = getString(data, ["status"]) ?? "in-sync";
+  const status =
+    statusRaw === "underbilled" || statusRaw === "overbilled" || statusRaw === "in-sync"
+      ? statusRaw
+      : "in-sync";
+
+  const actualSubtotalCents = getNumber(data, ["actualMonthlySubtotalCents"]) ?? 0;
+  const expectedSubtotalCents = getNumber(data, ["expectedMonthlySubtotalCents"]) ?? 0;
+  const monthlyDeltaCents = getNumber(data, ["monthlyDeltaCents"]) ?? 0;
+
+  const driftItemsRaw = getArray(data, ["lineItemDrift"]) ?? [];
+  const lineItemDrift = driftItemsRaw
+    .map((entry) => {
+      if (!isRecord(entry)) {
+        return null;
+      }
+
+      const unitAmountCents = getNumber(entry, ["unitAmountCents"]) ?? 0;
+      const actualSubtotalItemCents = getNumber(entry, ["actualSubtotalCents"]) ?? 0;
+      const expectedSubtotalItemCents = getNumber(entry, ["expectedSubtotalCents"]) ?? 0;
+      const subtotalDeltaCents = getNumber(entry, ["subtotalDeltaCents"]) ?? 0;
+
+      return {
+        code: getString(entry, ["code"]) ?? "unknown",
+        label: getString(entry, ["label"]) ?? "Unknown item",
+        unitAmountZar: unitAmountCents / 100,
+        actualQuantity: getNumber(entry, ["actualQuantity"]) ?? 0,
+        expectedQuantity: getNumber(entry, ["expectedQuantity"]) ?? 0,
+        quantityDelta: getNumber(entry, ["quantityDelta"]) ?? 0,
+        actualSubtotalZar: actualSubtotalItemCents / 100,
+        expectedSubtotalZar: expectedSubtotalItemCents / 100,
+        subtotalDeltaZar: subtotalDeltaCents / 100,
+      };
+    })
+    .filter((entry): entry is BillingDriftSummary["lineItemDrift"][number] => entry !== null);
+
+  const usage = isRecord(data.usage)
+    ? {
+        platformUsers: getNumber(data.usage, ["platformUsers"]) ?? 0,
+        accessControlUsers: getNumber(data.usage, ["accessControlUsers"]) ?? 0,
+        patrolUsers: getNumber(data.usage, ["patrolUsers"]) ?? 0,
+        activeAgentGroups: getNumber(data.usage, ["activeAgentGroups"]) ?? 0,
+      }
+    : {
+        platformUsers: 0,
+        accessControlUsers: 0,
+        patrolUsers: 0,
+        activeAgentGroups: 0,
+      };
+
+  return {
+    status,
+    currency: getString(data, ["currency"]) ?? "ZAR",
+    actualMonthlySubtotalZar: actualSubtotalCents / 100,
+    expectedMonthlySubtotalZar: expectedSubtotalCents / 100,
+    monthlyDeltaZar: monthlyDeltaCents / 100,
+    usage,
+    generatedAt: getString(data, ["generatedAt"]) ?? "",
+    lineItemDrift,
+  };
+}
+
+function getRequiredToken(token: string | null): string {
+  if (!token) {
+    throw new Error("Missing auth token for billing API request.");
+  }
+  return token;
+}
+
+function getRequiredSessionUrl(payload: unknown, requestType: string): string {
+  const data = unwrapApiEnvelope(payload);
+  if (!isRecord(data)) {
+    throw new Error(`Invalid ${requestType} response shape.`);
+  }
+
+  const url = getString(data, ["url", "checkoutUrl", "sessionUrl"]);
+  if (!url) {
+    throw new Error(`No redirect URL returned from ${requestType}.`);
+  }
+  return url;
+}
+
+function getRequiredDraftId(payload: unknown): string {
+  const data = unwrapApiEnvelope(payload);
+  if (!isRecord(data)) {
+    throw new Error("Invalid checkout draft response shape.");
+  }
+
+  const draftId = getString(data, ["draftId", "id"]);
+  if (!draftId) {
+    throw new Error("Checkout draft response did not include a draft ID.");
+  }
+  return draftId;
+}
+
+export async function fetchBillingSummary(
+  organisationId: string,
+  token: string | null
+): Promise<BillingSummary> {
+  const authToken = getRequiredToken(token);
+  const response = await api.get<unknown>(`/${organisationId}/billing/summary`, {
+    token: authToken,
+  });
+  return normaliseBillingSummary(response);
+}
+
+export async function fetchBillingEntitlements(
+  organisationId: string,
+  token: string | null
+): Promise<BillingEntitlement[]> {
+  const authToken = getRequiredToken(token);
+  const response = await api.get<unknown>(`/${organisationId}/billing/entitlements`, {
+    token: authToken,
+  });
+  return normaliseEntitlements(response);
+}
+
+export async function fetchBillingDrift(
+  organisationId: string,
+  token: string | null
+): Promise<BillingDriftSummary> {
+  const authToken = getRequiredToken(token);
+  const response = await api.get<unknown>(`/${organisationId}/billing/drift`, {
+    token: authToken,
+  });
+  return normaliseBillingDrift(response);
+}
+
+export async function createBillingCheckoutDraft(
+  organisationId: string,
+  token: string | null,
+  lineItems: readonly BillingCheckoutLineItem[]
+): Promise<CheckoutDraftResult> {
+  const authToken = getRequiredToken(token);
+  const response = await api.post<
+    { lineItems: readonly BillingCheckoutLineItem[] },
+    unknown
+  >(`/${organisationId}/billing/checkout-draft`, {
+    token: authToken,
+    data: { lineItems },
+  });
+  return { draftId: getRequiredDraftId(response) };
+}
+
+export async function createBillingCheckoutSession(
+  organisationId: string,
+  token: string | null,
+  draftId: string
+): Promise<CheckoutSessionResult> {
+  const authToken = getRequiredToken(token);
+  const response = await api.post<{ draftId: string }, unknown>(
+    `/${organisationId}/billing/checkout-session`,
+    {
+      token: authToken,
+      data: { draftId },
+    }
+  );
+
+  return {
+    url: getRequiredSessionUrl(response, "checkout session"),
+  };
+}
+
+export async function regenerateBillingCheckoutSession(
+  organisationId: string,
+  token: string | null,
+  draftId?: string
+): Promise<BillingSessionResult> {
+  const authToken = getRequiredToken(token);
+  const response = await api.post<{ draftId?: string }, unknown>(
+    `/${organisationId}/billing/checkout-session/regenerate`,
+    {
+      token: authToken,
+      data: draftId ? { draftId } : {},
+    }
+  );
+
+  const data = unwrapApiEnvelope(response);
+  const responseDraftId = isRecord(data)
+    ? getString(data, ["draftId"])
+    : null;
+
+  return {
+    url: getRequiredSessionUrl(response, "checkout session regeneration"),
+    draftId: responseDraftId ?? undefined,
+  };
+}
+
+export async function createBillingPortalSession(
+  organisationId: string,
+  token: string | null
+): Promise<PortalSessionResult> {
+  const authToken = getRequiredToken(token);
+  const response = await api.post<Record<string, never>, unknown>(
+    `/${organisationId}/billing/portal-session`,
+    {
+      token: authToken,
+      data: {},
+    }
+  );
+
+  return {
+    url: getRequiredSessionUrl(response, "portal session"),
+  };
+}
+
+export async function createBillingDriftMigrationCheckout(
+  organisationId: string,
+  token: string | null
+): Promise<BillingDriftMigrationResult> {
+  const authToken = getRequiredToken(token);
+  const response = await api.post<Record<string, never>, unknown>(
+    `/${organisationId}/billing/migrate-from-drift`,
+    {
+      token: authToken,
+      data: {},
+    }
+  );
+
+  const data = unwrapApiEnvelope(response) as DriftMigrationCheckoutResponse;
+  const url = getRequiredSessionUrl(response, "drift migration checkout");
+  const draftId = typeof data?.draftId === "string" ? data.draftId : undefined;
+  const drift = normaliseBillingDrift(data?.drift);
+
+  return {
+    url,
+    draftId,
+    drift,
+  };
+}
