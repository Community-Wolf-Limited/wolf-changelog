+import { useCallback, useEffect, useRef, useState } from "react";
+import mapboxgl from "mapbox-gl";
+import "mapbox-gl/dist/mapbox-gl.css";
+import "../../patrol-events/components/map/mapbox-modal-precision.css";
+import { api } from "@/utils/api";
+import { useAuth } from "@clerk/clerk-react";
+import {
+  Dialog,
+  DialogContent,
+  DialogDescription,
+  DialogHeader,
+  DialogTitle,
+} from "@/components/ui/dialog";
+import { Label } from "@/components/ui/label";
+import { Switch } from "@/components/ui/switch";
+import { Loader2 } from "lucide-react";
+import type { PatrolEvent } from "@/types/patrol.type";
+import type { GuardLiveLocation } from "@/pages/enterprise/patrol-events/components/LiveTrackingTab";
+
+const MAPBOX_TOKEN = import.meta.env.VITE_MAPBOX_TOKEN as string | undefined;
+if (globalThis.window !== undefined && MAPBOX_TOKEN) {
+  mapboxgl.accessToken = MAPBOX_TOKEN;
+}
+
+async function fetchPatrolEventDetail(
+  orgId: string,
+  eventId: string,
+  token: string
+): Promise<PatrolEvent | null> {
+  try {
+    const raw = await api.get<PatrolEvent | { data?: PatrolEvent }>(`${orgId}/patrol-events/${eventId}`, { token });
+    if (raw && typeof raw === "object" && "data" in raw && raw.data) {
+      return raw.data;
+    }
+    if (raw && typeof raw === "object" && "_id" in raw) {
+      return raw as PatrolEvent;
+    }
+    return null;
+  } catch {
+    return null;
+  }
+}
+
+interface BreadcrumbPoint {
+  latitude: number;
+  longitude: number;
+  accuracy?: number;
+  timestamp: string;
+}
+
+export interface StaffLiveMapModalProps {
+  readonly open: boolean;
+  readonly onOpenChange: (open: boolean) => void;
+  readonly organizationId: string;
+  readonly staffId: string | null;
+  readonly staffName: string;
+  readonly live: GuardLiveLocation | null;
+}
+
+export default function StaffLiveMapModal({
+  open,
+  onOpenChange,
+  organizationId,
+  staffId,
+  staffName,
+  live,
+}: StaffLiveMapModalProps) {
+  const { getToken } = useAuth();
+  const mapContainerRef = useRef<HTMLDivElement | null>(null);
+  const mapRef = useRef<mapboxgl.Map | null>(null);
+  const markerRef = useRef<mapboxgl.Marker | null>(null);
+  const [mapReady, setMapReady] = useState(false);
+  const [mapError, setMapError] = useState<string | null>(null);
+  const [layerLive, setLayerLive] = useState(true);
+  const [layerRoute, setLayerRoute] = useState(true);
+  const [layerTrail, setLayerTrail] = useState(false);
+  const [routeLoading, setRouteLoading] = useState(false);
+  const [trailLoading, setTrailLoading] = useState(false);
+
+  useEffect(() => {
+    if (!open || !MAPBOX_TOKEN) {
+      if (!MAPBOX_TOKEN) setMapError("VITE_MAPBOX_TOKEN is not set");
+      return;
+    }
+    if (!mapContainerRef.current || mapRef.current) return;
+
+    const map = new mapboxgl.Map({
+      container: mapContainerRef.current,
+      style: "mapbox://styles/mapbox/streets-v12",
+      center: [28, -26],
+      zoom: 10,
+    });
+    map.addControl(new mapboxgl.NavigationControl(), "top-right");
+    mapRef.current = map;
+
+    map.on("load", () => {
+      if (!map.getSource("route-line")) {
+        map.addSource("route-line", {
+          type: "geojson",
+          data: { type: "FeatureCollection", features: [] },
+        });
+        map.addLayer({
+          id: "route-line-layer",
+          type: "line",
+          source: "route-line",
+          layout: { "line-join": "round", "line-cap": "round" },
+          paint: { "line-color": "#2563eb", "line-width": 4, "line-opacity": 0.85 },
+        });
+      }
+      if (!map.getSource("trail-line")) {
+        map.addSource("trail-line", {
+          type: "geojson",
+          data: { type: "FeatureCollection", features: [] },
+        });
+        map.addLayer({
+          id: "trail-line-layer",
+          type: "line",
+          source: "trail-line",
+          layout: { "line-join": "round", "line-cap": "round" },
+          paint: {
+            "line-color": "#a855f7",
+            "line-width": 3,
+            "line-opacity": 0.75,
+            "line-dasharray": [2, 2],
+          },
+        });
+      }
+      setMapReady(true);
+    });
+
+    return () => {
+      markerRef.current?.remove();
+      markerRef.current = null;
+      map.remove();
+      mapRef.current = null;
+      setMapReady(false);
+    };
+  }, [open]);
+
+  const applyRouteLayer = useCallback(
+    async (eventId: string) => {
+      const map = mapRef.current;
+      if (!map || !mapReady) return;
+      const token = await getToken();
+      if (!token) return;
+      setRouteLoading(true);
+      try {
+        const ev = await fetchPatrolEventDetail(organizationId, eventId, token);
+        const checkpoints = ev?.routeSnapshot?.checkpoints;
+        const coords: [number, number][] = [];
+        if (Array.isArray(checkpoints)) {
+          for (const c of checkpoints) {
+            const loc = c?.location as { latitude?: number; longitude?: number } | undefined;
+            if (loc?.latitude != null && loc?.longitude != null) {
+              coords.push([loc.longitude, loc.latitude]);
+            }
+          }
+        }
+        const raw = map.getSource("route-line");
+        if (raw?.type !== "geojson") return;
+        const geoSrc: mapboxgl.GeoJSONSource = raw;
+        if (coords.length >= 2) {
+          geoSrc.setData({
+            type: "Feature",
+            properties: {},
+            geometry: { type: "LineString", coordinates: coords },
+          });
+        } else {
+          geoSrc.setData({ type: "FeatureCollection", features: [] });
+        }
+      } finally {
+        setRouteLoading(false);
+      }
+    },
+    [getToken, organizationId, mapReady]
+  );
+
+  const applyTrailLayer = useCallback(
+    async (eventId: string) => {
+      const map = mapRef.current;
+      if (!map || !mapReady) return;
+      const token = await getToken();
+      if (!token) return;
+      setTrailLoading(true);
+      try {
+        const body = await api.get<{ success: boolean; data: { points: BreadcrumbPoint[] } }>(
+          `/patrol-events/${eventId}/breadcrumbs`,
+          { query: { organizationId }, token }
+        );
+        const pts = body?.data?.points ?? [];
+        const coords: [number, number][] = pts.map((p) => [p.longitude, p.latitude]);
+        const raw = map.getSource("trail-line");
+        if (raw?.type !== "geojson") return;
+        const geoSrc: mapboxgl.GeoJSONSource = raw;
+        if (coords.length >= 2) {
+          geoSrc.setData({
+            type: "Feature",
+            properties: {},
+            geometry: { type: "LineString", coordinates: coords },
+          });
+        } else {
+          geoSrc.setData({ type: "FeatureCollection", features: [] });
+        }
+      } finally {
+        setTrailLoading(false);
+      }
+    },
+    [getToken, organizationId, mapReady]
+  );
+
+  useEffect(() => {
+    if (!open || !mapReady || !live?.eventId) return;
+    void applyRouteLayer(live.eventId);
+  }, [open, mapReady, live?.eventId, applyRouteLayer]);
+
+  useEffect(() => {
+    if (!open || !mapReady || !live?.eventId || !layerTrail) return;
+    void applyTrailLayer(live.eventId);
+  }, [open, mapReady, live?.eventId, layerTrail, applyTrailLayer]);
+
+  useEffect(() => {
+    const map = mapRef.current;
+    if (!map || !mapReady) return;
+    if (map.getLayer("route-line-layer")) {
+      map.setLayoutProperty("route-line-layer", "visibility", layerRoute ? "visible" : "none");
+    }
+  }, [mapReady, layerRoute]);
+
+  useEffect(() => {
+    const map = mapRef.current;
+    if (!map || !mapReady) return;
+    if (map.getLayer("trail-line-layer")) {
+      map.setLayoutProperty("trail-line-layer", "visibility", layerTrail ? "visible" : "none");
+    }
+  }, [mapReady, layerTrail]);
+
+  useEffect(() => {
+    const map = mapRef.current;
+    if (!map || !mapReady || !live) return;
+
+    markerRef.current?.remove();
+    markerRef.current = null;
+
+    if (!layerLive) {
+      return;
+    }
+
+    const el = document.createElement("div");
+    el.className = "rounded-full w-4 h-4 bg-emerald-500 border-2 border-white shadow-md";
+    const marker = new mapboxgl.Marker({ element: el })
+      .setLngLat([live.location.longitude, live.location.latitude])
+      .addTo(map);
+    markerRef.current = marker;
+
+    map.flyTo({
+      center: [live.location.longitude, live.location.latitude],
+      zoom: 15,
+    });
+  }, [mapReady, live, layerLive]);
+
+  const lastSeen =
+    live?.timestamp == null
