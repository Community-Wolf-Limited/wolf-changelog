diff --git a/src/hooks/use-patrol-field-grant-socket.ts b/src/hooks/use-patrol-field-grant-socket.ts
new file mode 100644
index 0000000..e10c50e
--- /dev/null
+++ b/src/hooks/use-patrol-field-grant-socket.ts
@@ -0,0 +1,145 @@
+import { useEffect, useRef } from 'react';
+import { io, type Socket } from 'socket.io-client';
+import { useOrganisation } from '@/hooks/useOrganisation';
+import { useAuth } from '@clerk/clerk-react';
+import { logger } from '@/utils/logger';
+
+export interface PatrolGrantRequestPayload {
+  grantId: string;
+  staffId: string;
+  staffName: string;
+  requestedAt?: string;
+}
+
+export interface PatrolGrantAckPayload {
+  grantId: string;
+  staffId: string;
+  staffName: string;
+  acknowledgedAt?: string;
+}
+
+export interface PatrolConfigSitePayload {
+  siteId: string;
+  siteName: string;
+  staffId: string;
+  staffName: string;
+  createdAt?: string;
+}
+
+export interface PatrolConfigRoutePayload {
+  routeId: string;
+  routeName: string;
+  staffId: string;
+  staffName: string;
+  createdAt?: string;
+}
+
+interface Options {
+  enabled?: boolean;
+  onRequest?: (payload: PatrolGrantRequestPayload) => void;
+  onAck?: (payload: PatrolGrantAckPayload) => void;
+  onSiteCreated?: (payload: PatrolConfigSitePayload) => void;
+  onRouteCreated?: (payload: PatrolConfigRoutePayload) => void;
+  onConnectionChange?: (connected: boolean) => void;
+}
+
+function getSocketUrl(): string {
+  const apiUrl = import.meta.env.VITE_API_URL as string | undefined;
+  if (!apiUrl) {
+    return import.meta.env.VITE_WS_URL || 'https://wolf-data-api-staging.onrender.com';
+  }
+  return apiUrl.replace(/\/+$/, '').replace(/\/api$/, '');
+}
+
+/**
+ * Listens for patrol field grant governance and config events on the same Socket.IO server as patrol events.
+ */
+export function usePatrolFieldGrantSocket({
+  enabled = true,
+  onRequest,
+  onAck,
+  onSiteCreated,
+  onRouteCreated,
+  onConnectionChange,
+}: Options): void {
+  const { currentOrganisation } = useOrganisation();
+  const { getToken } = useAuth();
+  const socketRef = useRef<Socket | null>(null);
+  const cbRef = useRef({ onRequest, onAck, onSiteCreated, onRouteCreated, onConnectionChange });
+
+  useEffect(() => {
+    cbRef.current = { onRequest, onAck, onSiteCreated, onRouteCreated, onConnectionChange };
+  }, [onRequest, onAck, onSiteCreated, onRouteCreated, onConnectionChange]);
+
+  useEffect(() => {
+    if (!enabled || !currentOrganisation?._id) {
+      return;
+    }
+
+    let cancelled = false;
+
+    const run = async () => {
+      try {
+        const token = await getToken();
+        if (!token || cancelled) return;
+
+        const socketUrl = getSocketUrl();
+        const socket = io(socketUrl, {
+          query: {
+            orgId: currentOrganisation._id,
+            token,
+          },
+          transports: ['websocket', 'polling'],
+          reconnection: true,
+        });
+
+        socketRef.current = socket;
+
+        socket.on('connect', () => {
+          cbRef.current.onConnectionChange?.(true);
+        });
+        socket.on('disconnect', () => {
+          cbRef.current.onConnectionChange?.(false);
+        });
+
+        socket.on('patrol-grant:request-created', (payload: PatrolGrantRequestPayload) => {
+          logger.log('[Patrol Grant Socket] request-created', payload);
+          cbRef.current.onRequest?.(payload);
+        });
+
+        socket.on('patrol-grant:acknowledged', (payload: PatrolGrantAckPayload) => {
+          logger.log('[Patrol Grant Socket] acknowledged', payload);
+          cbRef.current.onAck?.(payload);
+        });
+
+        socket.on('patrol-config:site-created', (payload: PatrolConfigSitePayload) => {
+          logger.log('[Patrol Grant Socket] site-created', payload);
+          cbRef.current.onSiteCreated?.(payload);
+        });
+
+        socket.on('patrol-config:route-created', (payload: PatrolConfigRoutePayload) => {
+          logger.log('[Patrol Grant Socket] route-created', payload);
+          cbRef.current.onRouteCreated?.(payload);
+        });
+
+        socket.on('connect_error', (err) => {
+          logger.warn('[Patrol Grant Socket] connect_error', err?.message ?? err);
+        });
+      } catch (e) {
+        logger.warn('[Patrol Grant Socket] setup failed', e);
+      }
+    };
+
+    void run();
+
+    return () => {
+      cancelled = true;
+      if (socketRef.current) {
+        socketRef.current.removeAllListeners();
+        socketRef.current.disconnect();
+        socketRef.current = null;
+      }
+      cbRef.current.onConnectionChange?.(false);
+    };
+  }, [enabled, currentOrganisation?._id, getToken]);
+}
