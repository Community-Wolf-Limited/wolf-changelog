+export type BillingLifecycleState =
+  | "active"
+  | "trial"
+  | "unpaid"
+  | "grace-period"
+  | "over-limit"
+  | "unknown";
+
+export type BillingProductCode =
+  | "platform"
+  | "platform-additional-seat"
+  | "intelligence"
+  | "access-control"
+  | "patrol-management"
+  | "group-agents";
+
+export interface BillingProductDefinition {
+  readonly code: BillingProductCode;
+  readonly name: string;
+  readonly description: string;
+  readonly unitPriceZar: number;
+  readonly billingPeriod: "month";
+  readonly includedSeats: number;
+}
+
+export interface BillingCheckoutLineItem {
+  readonly productCode: BillingProductCode;
+  readonly quantity: number;
+}
+
+export interface BillingSummaryLineItem {
+  readonly code: string;
+  readonly label: string;
+  readonly quantity: number;
+  readonly unitAmountZar: number;
+  readonly totalAmountZar: number;
+}
+
+export interface BillingSummary {
+  readonly state: BillingLifecycleState;
+  readonly statusLabel: string;
+  readonly currency: string;
+  readonly monthlySubtotalZar: number;
+  readonly seatsIncluded: number | null;
+  readonly seatsUsed: number | null;
+  readonly seatsOverLimit: number;
+  readonly trialEndsAt: string | null;
+  readonly graceEndsAt: string | null;
+  readonly currentPeriodEndsAt: string | null;
+  readonly billingMode: "stripe" | "manual" | "none";
+  readonly usingOverrides: boolean;
+  readonly usage: {
+    readonly platformUsers: number;
+    readonly accessControlUsers: number;
+    readonly patrolUsers: number;
+    readonly activeAgentGroups: number;
+  } | null;
+  readonly latestDraft: {
+    readonly draftId: string;
+    readonly status: string;
+    readonly createdAt: string;
+    readonly updatedAt: string;
+    readonly seatCount: number;
+    readonly amountSubtotalZar: number;
+    readonly stripeCheckoutSessionId: string | null;
+  } | null;
+  readonly lineItems: BillingSummaryLineItem[];
+}
+
+export interface BillingEntitlement {
+  readonly key: string;
+  readonly label: string;
+  readonly status: BillingLifecycleState | "inactive";
+  readonly enabled: boolean;
+  readonly usage: number | null;
+  readonly limit: number | null;
+  readonly overLimit: boolean;
+}
+
+export interface BillingSessionResult {
+  readonly url: string;
+  readonly draftId?: string;
+}
+
+export type BillingDriftStatus = "underbilled" | "overbilled" | "in-sync";
+
+export interface BillingDriftLineItem {
+  readonly code: string;
+  readonly label: string;
+  readonly unitAmountZar: number;
+  readonly actualQuantity: number;
+  readonly expectedQuantity: number;
+  readonly quantityDelta: number;
+  readonly actualSubtotalZar: number;
+  readonly expectedSubtotalZar: number;
+  readonly subtotalDeltaZar: number;
+}
+
+export interface BillingDriftSummary {
+  readonly status: BillingDriftStatus;
+  readonly currency: string;
+  readonly actualMonthlySubtotalZar: number;
+  readonly expectedMonthlySubtotalZar: number;
+  readonly monthlyDeltaZar: number;
+  readonly usage: {
+    readonly platformUsers: number;
+    readonly accessControlUsers: number;
+    readonly patrolUsers: number;
+    readonly activeAgentGroups: number;
+  };
+  readonly generatedAt: string;
+  readonly lineItemDrift: BillingDriftLineItem[];
+}
+
+export interface BillingDriftMigrationResult extends BillingSessionResult {
+  readonly drift: BillingDriftSummary;
+}
