+import { useCallback, useEffect, useMemo, useRef, useState } from "react";
+import mapboxgl from "mapbox-gl";
+import "mapbox-gl/dist/mapbox-gl.css";
+import { api } from "@/utils/api";
+import { useAuth } from "@clerk/clerk-react";
+import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
+import { Badge } from "@/components/ui/badge";
+import { Button } from "@/components/ui/button";
+import { Radio, Loader2, MapPin } from "lucide-react";
+import type { PatrolEvent } from "@/types/patrol.type";
+
+const MAPBOX_TOKEN = import.meta.env.VITE_MAPBOX_TOKEN as string | undefined;
+if (globalThis.window !== undefined && MAPBOX_TOKEN) {
+  mapboxgl.accessToken = MAPBOX_TOKEN;
+}
+
+export interface GuardLiveLocation {
+  eventId: string;
+  staffId: string;
+  location: { latitude: number; longitude: number; accuracy?: number };
+  timestamp: string;
+}
+
+const STALE_MS = 2 * 60 * 1000;
+
+function formatRelativeTime(iso: string): string {
+  const t = new Date(iso).getTime();
+  const s = Math.floor((Date.now() - t) / 1000);
+  if (s < 60) return `${s}s ago`;
+  if (s < 3600) return `${Math.floor(s / 60)}m ago`;
+  return `${Math.floor(s / 3600)}h ago`;
+}
+
+function isStale(iso: string): boolean {
+  return Date.now() - new Date(iso).getTime() > STALE_MS;
+}
+
+interface LiveTrackingTabProps {
+  readonly organizationId: string;
+  readonly guardLiveByStaff: Record<string, GuardLiveLocation>;
+}
+
+async function fetchPatrolEventDetail(
+  orgId: string,
+  eventId: string,
+  token: string
+): Promise<PatrolEvent | null> {
+  try {
+    const raw = await api.get<PatrolEvent | { data?: PatrolEvent }>(
+      `${orgId}/patrol-events/${eventId}`,
+      { token }
+    );
+    if (raw && typeof raw === "object" && "data" in raw && raw.data) {
+      return raw.data;
+    }
+    if (raw && typeof raw === "object" && "_id" in raw) {
+      return raw;
+    }
+    return null;
+  } catch {
+    return null;
+  }
+}
+
+export default function LiveTrackingTab({ organizationId, guardLiveByStaff }: LiveTrackingTabProps) {
+  const { getToken } = useAuth();
+  const mapContainerRef = useRef<HTMLDivElement | null>(null);
+  const mapRef = useRef<mapboxgl.Map | null>(null);
+  const markersRef = useRef<mapboxgl.Marker[]>([]);
+  const [mapReady, setMapReady] = useState(false);
+  const [staffNames, setStaffNames] = useState<Record<string, string>>({});
+  const [eventNames, setEventNames] = useState<Record<string, string>>({});
+  const eventLabelFetched = useRef<Set<string>>(new Set());
+  const [selectedStaffId, setSelectedStaffId] = useState<string | null>(null);
+  const [routeLoading, setRouteLoading] = useState(false);
+  const [mapError, setMapError] = useState<string | null>(null);
+
+  useEffect(() => {
+    let cancelled = false;
+    void (async () => {
+      try {
+        const token = await getToken();
+        if (!token) return;
+        const res = await api.get<{ data?: Array<{ _id: string; name: string }> }>(
+          `/staff?organizationId=${organizationId}`,
+          { token }
+        );
+        const rows = res.data;
+        if (cancelled || !Array.isArray(rows)) return;
+        const map: Record<string, string> = {};
+        for (const r of rows) {
+          if (r?._id && r.name) map[r._id] = r.name;
+        }
+        setStaffNames(map);
+      } catch {
+        /* non-fatal */
+      }
+    })();
+    return () => {
+      cancelled = true;
+    };
+  }, [getToken, organizationId]);
+
+  const entries = useMemo(() => Object.values(guardLiveByStaff), [guardLiveByStaff]);
+
+  useEffect(() => {
+    void (async () => {
+      const token = await getToken();
+      if (!token) return;
+      for (const e of entries) {
+        if (!e.eventId) continue;
+        if (eventLabelFetched.current.has(e.eventId)) continue;
+        eventLabelFetched.current.add(e.eventId);
+        const ev = await fetchPatrolEventDetail(organizationId, e.eventId, token);
+        const label =
+          ev?.routeSnapshot?.name && typeof ev.routeSnapshot.name === "string"
+            ? ev.routeSnapshot.name
+            : `Event ${e.eventId.slice(-6)}`;
+        setEventNames((prev) => ({ ...prev, [e.eventId]: label }));
+      }
+    })();
+  }, [entries, getToken, organizationId]);
+
+  useEffect(() => {
+    if (!MAPBOX_TOKEN) {
