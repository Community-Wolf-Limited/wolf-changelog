+      : new Date(live.timestamp).toLocaleString();
+
+  return (
+    <Dialog open={open} onOpenChange={onOpenChange}>
+      <DialogContent className="max-w-4xl w-[95vw] max-h-[90vh] overflow-y-auto mapbox-modal-fix">
+        <DialogHeader>
+          <DialogTitle className="flex flex-wrap items-center gap-2">
+            Live map · {staffName}
+          </DialogTitle>
+          <DialogDescription>
+            Last update: {lastSeen}
+            {live?.eventId ? ` · Event ${live.eventId.slice(-8)}` : ""}
+          </DialogDescription>
+        </DialogHeader>
+
+        <div className="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between flex-wrap">
+          <div className="flex flex-wrap items-center gap-6">
+            <div className="flex items-center gap-2">
+              <Switch id="layer-live" checked={layerLive} onCheckedChange={setLayerLive} />
+              <Label htmlFor="layer-live">Live position</Label>
+            </div>
+            <div className="flex items-center gap-2">
+              <Switch
+                id="layer-route"
+                checked={layerRoute}
+                onCheckedChange={setLayerRoute}
+                disabled={live?.eventId == null}
+              />
+              <Label htmlFor="layer-route">Planned route</Label>
+            </div>
+            <div className="flex items-center gap-2">
+              <Switch
+                id="layer-trail"
+                checked={layerTrail}
+                onCheckedChange={setLayerTrail}
+                disabled={live?.eventId == null}
+              />
+              <Label htmlFor="layer-trail">GPS trail</Label>
+            </div>
+          </div>
+          {(routeLoading || trailLoading) && (
+            <div className="flex items-center gap-2 text-xs text-muted-foreground">
+              <Loader2 className="h-3 w-3 animate-spin" />
+              Loading layers…
+            </div>
+          )}
+        </div>
+
+        {mapError ? <p className="text-sm text-destructive">{mapError}</p> : null}
+
+        <div className="relative rounded-lg overflow-hidden border border-border min-h-[360px] w-full">
+          <div ref={mapContainerRef} className="absolute inset-0 w-full h-full min-h-[360px]" />
+          {live == null && mapError == null ? (
+            <div className="absolute inset-0 flex items-center justify-center bg-muted/80 text-sm text-muted-foreground p-4 text-center">
+              No live GPS for this guard yet. When they run a patrol and the app streams location, the map will update.
+            </div>
+          ) : null}
+        </div>
+      </DialogContent>
+    </Dialog>
