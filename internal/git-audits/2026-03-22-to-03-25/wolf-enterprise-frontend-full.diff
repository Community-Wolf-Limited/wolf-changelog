+import { useMemo } from "react";
+import { Button } from "@/components/ui/button";
+import { Badge } from "@/components/ui/badge";
+import { MapPin, Radio } from "lucide-react";
+import type { GuardLiveLocation } from "@/pages/enterprise/patrol-events/components/LiveTrackingTab";
+
+interface GrantRow {
+  _id: string;
+  status: string;
+  scope: string;
+  grantVersion: number;
+  staffId: string;
+}
+
+interface StaffLiveTrackingListProps {
+  readonly organizationId: string;
+  readonly grants: GrantRow[];
+  readonly staffNameById: Record<string, string>;
+  readonly guardLiveByStaff: Record<string, GuardLiveLocation>;
+  readonly onSelectStaff: (staffId: string) => void;
+}
+
+export default function StaffLiveTrackingList({
+  organizationId: _organizationId,
+  grants,
+  staffNameById,
+  guardLiveByStaff,
+  onSelectStaff,
+}: StaffLiveTrackingListProps) {
+  const activeGrants = useMemo(
+    () => grants.filter((g) => g.status === "active"),
+    [grants]
+  );
+
+  if (activeGrants.length === 0) {
+    return (
+      <p className="text-sm text-muted-foreground">
+        No active field-access grants. Approve a request on the Requests tab to see staff here for live tracking.
+      </p>
+    );
+  }
+
+  return (
+    <ul className="space-y-2">
+      {activeGrants.map((g) => {
+        const name = staffNameById[g.staffId] ?? `Staff ${g.staffId.slice(-6)}`;
+        const live = guardLiveByStaff[g.staffId];
+        const isLive = Boolean(live);
+        return (
+          <li key={g._id}>
+            <Button
+              variant="outline"
+              className="w-full justify-between h-auto py-3 px-4"
+              onClick={() => onSelectStaff(g.staffId)}
+            >
+              <span className="flex items-center gap-2 text-left">
+                <MapPin className="h-4 w-4 shrink-0 text-muted-foreground" />
+                <span>
+                  <span className="font-medium block">{name}</span>
+                  <span className="text-xs text-muted-foreground">Scope: {g.scope.replaceAll("_", " ")} · v{g.grantVersion}</span>
+                </span>
+              </span>
+              <span className="flex items-center gap-2 shrink-0">
+                {isLive ? (
+                  <Badge variant="secondary" className="gap-1 text-emerald-800">
+                    <Radio className="h-3 w-3" />
+                    Live
+                  </Badge>
+                ) : (
+                  <Badge variant="outline" className="text-muted-foreground">
+                    No GPS yet
+                  </Badge>
+                )}
+              </span>
+            </Button>
+          </li>
+        );
+      })}
+    </ul>
+  );
+}
