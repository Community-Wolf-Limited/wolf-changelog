+}
+
+async function fetchPatrolEventDetail(
+  orgId: string,
+  eventId: string,
+  token: string
+): Promise<PatrolEvent | null> {
+  if (!eventId) return null;
+  try {
+    const raw = await api.get<PatrolEvent | { data?: PatrolEvent }>(
+      `${orgId}/patrol-events/${eventId}`,
+      { token }
+    );
+    if (raw && typeof raw === "object" && "data" in raw && raw.data) {
+      return raw.data;
+    }
+    if (raw && typeof raw === "object" && "_id" in raw) {
+      return raw as PatrolEvent;
+    }
+    return null;
+  } catch {
+    return null;
+  }
+}
+
+export default function FieldAccessLiveMap({
+  organizationId,
+  grants,
+  staffNameById,
+  guardLiveByStaff,
+  setGuardLiveByStaff,
+  onGrantsRefresh,
+}: FieldAccessLiveMapProps) {
+  const { getToken } = useAuth();
+  const mapContainerRef = useRef<HTMLDivElement | null>(null);
+  const mapRef = useRef<mapboxgl.Map | null>(null);
+  const markersRef = useRef<mapboxgl.Marker[]>([]);
+  const [mapReady, setMapReady] = useState(false);
+  const [eventNames, setEventNames] = useState<Record<string, string>>({});
+  const eventLabelFetched = useRef<Set<string>>(new Set());
+  const [selectedStaffId, setSelectedStaffId] = useState<string | null>(null);
+  const [routeLoading, setRouteLoading] = useState(false);
+  const [mapError, setMapError] = useState<string | null>(null);
+  const [trackingBusy, setTrackingBusy] = useState<string | null>(null);
+
+  const activeGrants = useMemo(
+    () => grants.filter((g) => g.status === "active"),
+    [grants]
+  );
+
+  const entries = useMemo(() => Object.values(guardLiveByStaff), [guardLiveByStaff]);
+
+  useEffect(() => {
+    let cancelled = false;
+    void (async () => {
+      try {
+        const token = await getToken();
+        if (!token) return;
+        const res = await api.get<{ success: boolean; data: { positions: Array<{
+          staffId: string;
+          eventId: string | null;
+          location: { latitude: number; longitude: number; accuracy?: number };
+          timestamp: string;
+        }> } }>(
+          `${organizationId}/patrol-field-governance/staff-positions`,
+          { token }
+        );
+        if (cancelled) return;
+        const positions = res.data?.positions ?? [];
+        setGuardLiveByStaff((prev) => {
+          const next = { ...prev };
+          for (const p of positions) {
+            const existing = prev[p.staffId];
+            const tNew = new Date(p.timestamp).getTime();
+            const tOld = existing ? new Date(existing.timestamp).getTime() : 0;
+            if (!existing || tNew >= tOld) {
+              next[p.staffId] = {
+                staffId: p.staffId,
+                eventId: p.eventId ?? "",
+                location: p.location,
+                timestamp: p.timestamp,
+              };
+            }
+          }
+          return next;
+        });
+      } catch {
+        /* non-fatal */
+      }
+    })();
+    return () => {
+      cancelled = true;
+    };
+  }, [getToken, organizationId, setGuardLiveByStaff]);
+
+  useEffect(() => {
+    void (async () => {
+      const token = await getToken();
+      if (!token) return;
+      for (const e of entries) {
+        if (!e.eventId) continue;
+        if (eventLabelFetched.current.has(e.eventId)) continue;
+        eventLabelFetched.current.add(e.eventId);
+        const ev = await fetchPatrolEventDetail(organizationId, e.eventId, token);
+        const label =
+          ev?.routeSnapshot?.name && typeof ev.routeSnapshot.name === "string"
+            ? ev.routeSnapshot.name
+            : `Event ${e.eventId.slice(-6)}`;
+        setEventNames((prev) => ({ ...prev, [e.eventId]: label }));
+      }
+    })();
+  }, [entries, getToken, organizationId]);
+
+  useEffect(() => {
+    if (!MAPBOX_TOKEN) {
+      setMapError("VITE_MAPBOX_TOKEN is not set");
+      return;
+    }
+    if (!mapContainerRef.current || mapRef.current) return;
+
+    const map = new mapboxgl.Map({
+      container: mapContainerRef.current,
+      style: "mapbox://styles/mapbox/streets-v12",
+      center: [28, -26],
+      zoom: 10,
+    });
+    map.addControl(new mapboxgl.NavigationControl(), "top-right");
+    mapRef.current = map;
+
+    map.on("load", () => {
+      if (!map.getSource("route-line")) {
+        map.addSource("route-line", {
+          type: "geojson",
+          data: { type: "FeatureCollection", features: [] },
+        });
+        map.addLayer({
+          id: "route-line-layer",
+          type: "line",
+          source: "route-line",
+          layout: { "line-join": "round", "line-cap": "round" },
+          paint: { "line-color": "#2563eb", "line-width": 4, "line-opacity": 0.85 },
+        });
+      }
+      setMapReady(true);
+    });
+
+    return () => {
+      markersRef.current.forEach((m) => m.remove());
+      markersRef.current = [];
+      map.remove();
+      mapRef.current = null;
+      setMapReady(false);
+    };
+  }, []);
+
+  const drawRouteForEvent = useCallback(
+    async (eventId: string) => {
+      const map = mapRef.current;
+      if (!map || !mapReady || !eventId) return;
+      const token = await getToken();
+      if (!token) return;
+      setRouteLoading(true);
+      try {
+        const ev = await fetchPatrolEventDetail(organizationId, eventId, token);
+        const checkpoints = ev?.routeSnapshot?.checkpoints;
+        const coords: [number, number][] = [];
+        if (Array.isArray(checkpoints)) {
+          for (const c of checkpoints) {
+            const loc = c?.location as { latitude?: number; longitude?: number } | undefined;
+            if (loc?.latitude != null && loc?.longitude != null) {
+              coords.push([loc.longitude, loc.latitude]);
+            }
+          }
+        }
+        const raw = map.getSource("route-line");
+        if (raw?.type !== "geojson") return;
+        const geoSrc: mapboxgl.GeoJSONSource = raw;
+        if (coords.length >= 2) {
+          geoSrc.setData({
+            type: "Feature",
+            properties: {},
+            geometry: { type: "LineString", coordinates: coords },
+          });
+          const bounds = coords.reduce(
+            (b, c) => b.extend(c),
+            new mapboxgl.LngLatBounds(coords[0], coords[0])
+          );
+          map.fitBounds(bounds, { padding: 60, maxZoom: 16 });
+        } else if (coords.length === 1) {
+          geoSrc.setData({ type: "FeatureCollection", features: [] });
+          map.flyTo({ center: coords[0], zoom: 15 });
+        } else {
+          geoSrc.setData({ type: "FeatureCollection", features: [] });
+        }
+      } finally {
+        setRouteLoading(false);
+      }
+    },
+    [getToken, organizationId, mapReady]
+  );
+
+  useEffect(() => {
+    const map = mapRef.current;
+    if (!map || !mapReady) return;
+
+    markersRef.current.forEach((m) => m.remove());
+    markersRef.current = [];
+
+    for (const g of entries) {
+      const name = staffNameById[g.staffId] ?? `Staff ${g.staffId.slice(-6)}`;
+      const el = document.createElement("div");
+      el.className =
+        "rounded-full w-4 h-4 bg-emerald-500 border-2 border-white shadow-md cursor-pointer";
+      el.title = name;
+      const marker = new mapboxgl.Marker({ element: el })
+        .setLngLat([g.location.longitude, g.location.latitude])
+        .setPopup(
+          new mapboxgl.Popup({ offset: 12 }).setHTML(
+            `<strong>${name}</strong><br/>${formatRelativeTime(g.timestamp)}`
+          )
+        )
+        .addTo(map);
+      el.addEventListener("click", () => {
+        setSelectedStaffId(g.staffId);
+        void drawRouteForEvent(g.eventId);
+      });
+      markersRef.current.push(marker);
+    }
+
+    if (entries.length > 0) {
+      const coords = entries.map((e) => [e.location.longitude, e.location.latitude] as [number, number]);
+      const bounds = coords.reduce(
+        (b, c) => b.extend(c),
+        new mapboxgl.LngLatBounds(coords[0], coords[0])
+      );
+      map.fitBounds(bounds, { padding: 60, maxZoom: 14, duration: 0 });
+    }
+  }, [entries, staffNameById, mapReady, drawRouteForEvent]);
+
+  const patchTrackingMode = useCallback(
+    async (grantId: string, mode: "always" | "patrol_only") => {
+      setTrackingBusy(grantId);
+      try {
+        const token = await getToken();
+        if (!token) return;
+        await api.patch<{ trackingMode: string }, { success: boolean }>(
+          `${organizationId}/patrol-field-governance/grants/${grantId}/tracking-mode`,
+          { data: { trackingMode: mode }, token }
+        );
+        toast({ title: "Tracking mode updated", description: `Set to ${mode === "always" ? "always on" : "patrol only"}.` });
+        await onGrantsRefresh?.();
+      } catch {
+        toast({ title: "Update failed", variant: "destructive" });
+      } finally {
+        setTrackingBusy(null);
+      }
+    },
+    [getToken, organizationId, onGrantsRefresh]
+  );
+
+  return (
+    <div className="space-y-4">
+      {mapError ? <p className="text-sm text-destructive">{mapError}</p> : null}
+      <div className="grid grid-cols-1 lg:grid-cols-3 gap-4">
+        <div className="lg:col-span-2 relative rounded-lg overflow-hidden border border-border min-h-[360px]">
+          <div ref={mapContainerRef} className="absolute inset-0 w-full h-full" />
+          {routeLoading ? (
+            <div className="absolute top-2 left-2 flex items-center gap-2 bg-background/90 px-2 py-1 rounded text-xs">
+              <Loader2 className="h-3 w-3 animate-spin" />
+              Loading route…
+            </div>
+          ) : null}
+        </div>
+        <div className="space-y-2 max-h-[480px] overflow-y-auto">
+          <p className="text-xs text-muted-foreground px-1 flex items-center gap-1">
+            <Radio className="h-3 w-3" />
+            Last update &gt; 2 min = stale. Toggle idle GPS per guard (device picks up on next capabilities refresh).
+          </p>
+          {activeGrants.length === 0 ? (
+            <p className="text-sm text-muted-foreground px-1 py-4">
+              No active field-access grants. Approve a request on the Requests tab to see staff here.
+            </p>
+          ) : (
+            activeGrants.map((g) => {
+              const live = guardLiveByStaff[g.staffId];
+              const name = staffNameById[g.staffId] ?? `Staff …${g.staffId.slice(-6)}`;
+              const selected = selectedStaffId === g.staffId;
+              const mode = g.trackingMode === "patrol_only" ? "patrol_only" : "always";
+              const busy = trackingBusy === g._id;
+
+              if (!live) {
+                return (
+                  <div
+                    key={g._id}
+                    className="rounded-md border p-3 space-y-3"
+                  >
+                    <div className="flex w-full items-center justify-between gap-2">
+                      <span className="font-medium flex items-center gap-1">
+                        <MapPin className="h-3 w-3 shrink-0" />
+                        {name}
+                      </span>
+                      <Badge variant="outline" className="text-muted-foreground">
+                        No GPS yet
+                      </Badge>
+                    </div>
+                    <span className="text-xs text-muted-foreground block">Scope: {g.scope.replaceAll("_", " ")}</span>
+                    <div className="flex items-center justify-between gap-2 border-t pt-2">
+                      <Label htmlFor={`track-${g._id}`} className="text-xs">
+                        Idle GPS
+                      </Label>
+                      <div className="flex items-center gap-2">
+                        {busy ? <Loader2 className="h-3 w-3 animate-spin" /> : null}
+                        <Switch
+                          id={`track-${g._id}`}
+                          checked={mode === "always"}
+                          disabled={busy}
+                          onCheckedChange={(checked) =>
+                            void patchTrackingMode(g._id, checked ? "always" : "patrol_only")
+                          }
+                        />
+                      </div>
+                    </div>
+                    <p className="text-[11px] text-muted-foreground">
+                      {mode === "always"
+                        ? "App streams location when open (no patrol required)."
+                        : "GPS only during an active patrol."}
+                    </p>
+                  </div>
+                );
+              }
+
+              const stale = isStale(live.timestamp);
+              return (
+                <div
+                  key={g._id}
+                  className={`rounded-md border w-full text-left ${selected ? "bg-secondary/60" : "bg-background"}`}
+                >
+                  <button
+                    type="button"
+                    className="w-full justify-start h-auto py-3 px-3 flex flex-col items-stretch gap-2 rounded-t-md hover:bg-muted/50"
+                    onClick={() => {
+                      setSelectedStaffId(g.staffId);
+                      void drawRouteForEvent(live.eventId);
+                      const m = mapRef.current;
+                      if (m) {
+                        m.flyTo({
+                          center: [live.location.longitude, live.location.latitude],
+                          zoom: 15,
+                        });
+                      }
+                    }}
+                  >
+                    <div className="flex w-full items-center justify-between gap-2">
+                      <span className="font-medium flex items-center gap-1">
+                        <MapPin className="h-3 w-3 shrink-0" />
+                        {name}
+                      </span>
+                      {stale ? (
+                        <Badge variant="outline" className="text-amber-700 border-amber-600/40">
+                          Stale
+                        </Badge>
+                      ) : (
+                        <Badge variant="secondary" className="text-emerald-800">
+                          Live
+                        </Badge>
+                      )}
+                    </div>
+                    <span className="text-xs text-muted-foreground w-full text-left">
+                      {live.eventId ? eventNames[live.eventId] ?? "Patrol" : "Idle / heartbeat"} ·{" "}
+                      {formatRelativeTime(live.timestamp)}
+                    </span>
+                  </button>
+                  <div className="flex items-center justify-between gap-2 border-t px-3 py-2">
+                    <Label htmlFor={`track-live-${g._id}`} className="text-xs">
+                      Idle GPS
+                    </Label>
+                    <div className="flex items-center gap-2">
+                      {busy ? <Loader2 className="h-3 w-3 animate-spin" /> : null}
+                      <Switch
+                        id={`track-live-${g._id}`}
+                        checked={mode === "always"}
+                        disabled={busy}
+                        onCheckedChange={(checked) => {
+                          void patchTrackingMode(g._id, checked ? "always" : "patrol_only");
+                        }}
+                      />
+                    </div>
+                  </div>
+                </div>
+              );
+            })
+          )}
+        </div>
+      </div>
+    </div>
+  );
+}
