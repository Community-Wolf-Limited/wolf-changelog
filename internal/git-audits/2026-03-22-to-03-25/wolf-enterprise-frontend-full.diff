@@ -0,0 +1,292 @@
+/**
+ * INTERNAL ENGINEERING AUDIT ONLY — not investor- or customer-facing changelog.
+ * Outputs changelog/internal/from-main/YYYY-MM-DD.mdx (commit subjects + audit YAML).
+ * External releases: hand-write changelog/YYYY-MM-DD*.mdx per .cursor/commands/changelog.md
+ *
+ *   git fetch origin main
+ *   node changelog/scripts/build-changelog-from-main-by-day.mjs
+ */
+import { execSync } from "node:child_process";
+import { writeFileSync, existsSync, readdirSync, unlinkSync, rmSync, mkdirSync } from "node:fs";
+import { join, dirname } from "node:path";
+import { fileURLToPath } from "node:url";
+
+const __dirname = dirname(fileURLToPath(import.meta.url));
+const REPO_ROOT = join(__dirname, "..", "..");
+const BASELINE = "f701e839315b18879cb44a9f3eb165f3afa29743";
+
+function git(args) {
+  return execSync(`git ${args}`, {
+    cwd: REPO_ROOT,
+    encoding: "utf8",
+    stdio: ["pipe", "pipe", "pipe"],
+  }).trim();
+}
+
+/** @returns {{ kind: string; subject: string; hash: string }} */
+function classify(hash, subject) {
+  const s = subject.trim();
+  const conv = s.match(
+    /^(feat|fix|chore|perf|refactor|docs|style|test|build|ci|revert)(?:\([^)]*\))?!?:\s*(.+)$/i
+  );
+  if (conv) {
+    return { kind: conv[1].toLowerCase(), subject: conv[2].trim(), hash };
+  }
+  if (/^Merge pull request/i.test(s)) {
+    return { kind: "merge", subject: s, hash };
+  }
+  if (/^Merge (remote|branch|origin)/i.test(s)) {
+    return { kind: "merge", subject: s, hash };
+  }
+  if (/^Revert\s/i.test(s)) {
+    return { kind: "revert", subject: s, hash };
+  }
+  return { kind: "other", subject: s, hash };
+}
+
+/** @returns {{ pr?: string; org?: string; branch?: string } | null} */
+function parseMergePr(subject) {
+  const m = subject.match(
+    /Merge pull request #(\d+) from ([^/\s]+)\/([^\s]+)/i
+  );
+  if (!m) return null;
+  return { pr: m[1], org: m[2], branch: m[3].replace(/\/+$/, "") };
+}
+
+function humanizeBranchName(branch) {
+  return branch
+    .replace(/^feature\//, "")
+    .replace(/^fix\//, "")
+    .replace(/-/g, " ")
+    .replace(/\//g, " — ");
+}
+
+function inferBoldLabel(subject) {
+  const lower = subject.toLowerCase();
+  if (/mega refactor|feature expansion/i.test(lower)) return "Platform";
+  if (lower.includes("mapbox") || lower.includes("map page")) return "Map & location";
+  if (lower.includes("live map") || lower.includes("layer") || lower.includes("precinct"))
+    return "Live map";
+  if (lower.includes("patrol")) return "Patrol";
+  if (lower.includes("hotspot")) return "Map hotspots";
+  if (lower.includes("access control")) return "Access control";
+  if (lower.includes("billing") || lower.includes("stripe")) return "Billing";
+  if (lower.includes("performance") || lower.includes("optim")) return "Performance";
+  if (lower.includes("staff")) return "Staff";
+  if (lower.includes("survey")) return "Surveys";
+  const first = subject.split(/[.:;]/)[0].trim();
+  if (first.length <= 48) {
+    return first.charAt(0).toUpperCase() + first.slice(1);
+  }
+  return subject.slice(0, 45).trim() + (subject.length > 45 ? "…" : "");
+}
+
+/** Readable sentence from conventional commit body (no hash). */
+function proseFromFeatFix(subject) {
+  let s = subject.trim();
+  if (/^mega refactor/i.test(s)) {
+    return "Broader refactor and feature expansion across the codebase.";
+  }
+  if (/;\s*/.test(s)) {
+    const parts = s.split(/;\s*/).map((p) => proseFromFeatFix(p.replace(/\.$/, "")));
+    return parts.join(" ");
+  }
+  s = s.charAt(0).toUpperCase() + s.slice(1);
+  if (!/[.!?]$/.test(s)) s += ".";
+  return s;
+}
+
+function bulletFeatFix(c) {
+  const label = inferBoldLabel(c.subject);
+  const body = proseFromFeatFix(c.subject);
+  return `- **${label}**: ${body}`;
+}
+
+function bulletMerge(c) {
+  const p = parseMergePr(c.subject);
+  if (p) {
+    if (/^staging$/i.test(p.branch)) {
+      return `- **Pull request #${p.pr}**: Staging — latest integration merged to main.`;
+    }
+    const theme = humanizeBranchName(p.branch);
+    return `- **Pull request #${p.pr}**: ${theme} — merged to main.`;
+  }
+  return `- **Integration**: ${c.subject.replace(/^Merge /, "Merged ")}.`;
+}
+
+function bulletChorePerfRefactorDocs(c) {
+  const label =
+    c.kind === "perf"
+      ? "Performance"
+      : c.kind === "chore"
+        ? "Maintenance"
+        : c.kind === "refactor"
+          ? "Code quality"
+          : c.kind === "docs"
+            ? "Documentation"
+            : c.kind === "style"
+              ? "UI polish"
+              : c.kind === "test"
+                ? "Tests"
+                : c.kind === "build"
+                  ? "Build"
+                  : c.kind === "ci"
+                    ? "CI"
+                    : "Maintenance";
+  return `- **${label}**: ${proseFromFeatFix(c.subject)}`;
+}
+
+function bulletRevert(c) {
+  return `- **Revert**: ${proseFromFeatFix(c.subject.replace(/^Revert\s+/i, ""))}`;
+}
+
+function bulletOther(c) {
+  return `- **Update**: ${proseFromFeatFix(c.subject)}`;
+}
+
+function deriveDescription(commits) {
+  const n = commits.length;
+  return `Engineering digest: ${n} commit${n === 1 ? "" : "s"} on main this day (internal — not for investors).`;
+}
+
+function escapeYaml(s) {
+  return JSON.stringify(s);
+}
+
+const log = git(
+  `log ${BASELINE}..origin/main --reverse --format="%ai|%h|%s"`
+);
+
+/** @type {Record<string, Array<{ iso: string } & ReturnType<typeof classify>>>} */
+const byDay = {};
+
+for (const line of log.split("\n")) {
+  if (!line.trim()) continue;
+  const i = line.indexOf("|");
+  const j = line.indexOf("|", i + 1);
+  if (i < 0 || j < 0) continue;
+  const iso = line.slice(0, i).trim();
+  const h = line.slice(i + 1, j).trim();
+  const subj = line.slice(j + 1).trim();
+  const day = iso.split(" ")[0];
+  const c = classify(h, subj);
+  if (!byDay[day]) byDay[day] = [];
+  byDay[day].push({ iso, ...c });
+}
+
+const days = Object.keys(byDay).sort();
+const changelogDir = join(REPO_ROOT, "changelog");
+const internalFromMain = join(changelogDir, "internal", "from-main");
+
+function cleanGeneratedFromMain() {
+  const legacy = join(changelogDir, "from-main");
+  if (existsSync(legacy)) {
+    rmSync(legacy, { recursive: true, force: true });
+  }
+  for (const name of readdirSync(changelogDir)) {
+    if (name.endsWith("-from-main.mdx")) {
+      unlinkSync(join(changelogDir, name));
+    }
+  }
+  if (existsSync(internalFromMain)) {
+    for (const name of readdirSync(internalFromMain)) {
+      if (name.endsWith(".mdx")) {
+        unlinkSync(join(internalFromMain, name));
+      }
+    }
+  }
+}
+
+cleanGeneratedFromMain();
+
+mkdirSync(internalFromMain, { recursive: true });
+
+for (const day of days) {
+  const commits = byDay[day];
+  const tip = commits[commits.length - 1];
+  const title = `Main commit audit — ${day}`;
+  const description = deriveDescription(commits);
+
+  const whatsNew = [];
+  const improvements = [];
+  const bugFixes = [];
+
+  for (const c of commits) {
+    if (c.kind === "feat") {
+      whatsNew.push(bulletFeatFix(c));
+    } else if (c.kind === "merge") {
+      improvements.push(bulletMerge(c));
+    } else if (c.kind === "fix") {
+      bugFixes.push(bulletFeatFix(c));
+    } else if (c.kind === "revert") {
+      bugFixes.push(bulletRevert(c));
+    } else if (
+      ["chore", "perf", "refactor", "docs", "style", "test", "build", "ci", "other"].includes(
+        c.kind
+      )
+    ) {
+      improvements.push(
+        ["other"].includes(c.kind) ? bulletOther(c) : bulletChorePerfRefactorDocs(c)
+      );
+    }
+  }
+
+  const sections = [];
+  if (whatsNew.length) {
+    sections.push("## What's New", "", ...whatsNew, "");
+  }
+  if (improvements.length) {
+    sections.push("## Improvements", "", ...improvements, "");
+  }
+  if (bugFixes.length) {
+    sections.push("## Bug Fixes", "", ...bugFixes, "");
+  }
+
+  const tagsYaml = JSON.stringify(["Internal"]).replace(/,/g, ", ");
+
+  const auditByKind = {};
+  for (const c of commits) {
+    auditByKind[c.kind] = auditByKind[c.kind] || [];
+    auditByKind[c.kind].push(c.hash);
+  }
+
+  const mdx = `---
+title: ${escapeYaml(title)}
+description: ${escapeYaml(description)}
+date: ${escapeYaml(day)}
+tags: ${tagsYaml}
+audience: internal
+version: "1.0"
+audit:
+  sourceBranch: main
+  baselineCommit: ${BASELINE}
+  lastCommitOnDay: ${tip.hash}
+  lastCommittedAt: ${escapeYaml(tip.iso)}
+  commitCount: ${commits.length}
+  hashesByKind:
+${Object.entries(auditByKind)
+  .map(([k, arr]) => `    ${k}: [${arr.map((x) => `"${x}"`).join(", ")}]`)
+  .join("\n")}
+---
+
+> **Internal only — not for investors, partners, or public release notes.** Hand-write \`changelog/YYYY-MM-DD*.mdx\` at the repo root for external audiences (see \`changelog/README.md\` and \`.cursor/commands/changelog.md\`).
+
+${sections.join("\n")}
+
+`;
+
+  writeFileSync(join(internalFromMain, `${day}.mdx`), mdx, "utf8");
+}
+
+for (const p of [
+  join(REPO_ROOT, "changelog", "main-merge"),
+  join(REPO_ROOT, "changelog", "wolf-enterprise-frontend", "main-merge"),
+]) {
+  if (existsSync(p)) {
+    rmSync(p, { recursive: true, force: true });
+  }
+}
+
+console.log(
+  `Wrote ${days.length} internal audit file(s) to changelog/internal/from-main/ (${days.join(", ")})`
+);
